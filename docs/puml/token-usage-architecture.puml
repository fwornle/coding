@startuml token-usage-architecture
!include _standard-style.puml

top to bottom direction
title Cognitive Process Token Flow (Phase 36)

' === User Layer ===
actor "Developer" as dev

' === Session Layer ===
package "Active Sessions" {
  component [Claude Code] <<cli>> as claude
  component [OpenCode] <<cli>> as opencode
}

' === LLM Proxy ===
package "LLM Proxy :12435 (@rapid/llm-proxy 2.0)" <<core>> {
  component [Request Router] <<core>> as router
  component [SettingsStore\n(per-process pins)] <<core>> as settings
  component [canonicalizeModelName\n(MODEL_CANONICAL_MAP)] <<util>> as canon
  component [TokenUsageStore\n(logCall)] <<core>> as logger
  component [Per-Window Exporter\n(Map<window, Timer> debounce)] <<core>> as exporter
  component [currentWindow()\n(coordinator fetch + 30s cache)] <<util>> as window
  database "token-usage.db\n(SQLite, untracked,\nuser_hash + model_raw)" <<storage>> as tokendb
  file "YYYY/MM/\nDATE_HHMM-HHMM_<hash6>.json\n(per-(window, user), git-trackable)" <<storage>> as tokenjson
  file "settings.json\n(persisted pins)" <<storage>> as settingsjson
}

' === Provider Layer ===
cloud "LLM Providers" {
  component [Claude Code\nMax Subscription] <<external>> as ccmax
  component [Copilot\nSubscription] <<external>> as copilot
  component [OpenAI / Groq / Anthropic\n(API-key, public-only)] <<external>> as apikey
}

' === Cognitive Processes ===
package "Online Learning Pipeline" {
  component [ETM\nEvent-Time Monitor] <<agent>> as etm
  component [Observation Writer] <<agent>> as obswriter
  component [Consolidator Digest] <<agent>> as digest
  component [Consolidator Insight] <<agent>> as insight
}

package "Wave Analysis" {
  component [Wave-1 Agent] <<agent>> as wave1
  component [Insight Generator] <<agent>> as insightgen
  component [Content Validator] <<agent>> as validator
}

package "Health & Monitoring" {
  component [Auto-Heal FSM] <<agent>> as autoheal
  component [Constraint Monitor] <<agent>> as constraints
  component [Health Coordinator\n(low-token probes)] <<agent>> as coord
}

' === Dashboard ===
package "Health Dashboard :3032 / :3033" {
  component [Token Usage page\n(4 tabs)] <<api>> as page
  component [LLM Routing dialog\n(Settings button)] <<api>> as dialog
  component [server.js reverse-proxy] <<api>> as fwd
}

' === Flow: Sessions to Proxy ===
dev --> claude : coding session
dev --> opencode : coding session
claude --> router : LLM calls
opencode --> router : LLM calls

' === Flow: Cognitive Processes to Proxy ===
obswriter --> router : process="observation-writer"
digest --> router : process="consolidator-digest"
insight --> router : process="consolidator-insight"
wave1 --> router : process="wave1-analysis"
insightgen --> router : process="insight-generator"
validator --> router : process="content-validator"
autoheal --> router : process="auto-heal"
constraints --> router : process="constraint-check"
coord --> router : process="health-coordinator"

' === Pin lookup ===
router -[#9C27B0,thickness=2]-> settings : lookup(process)
settings -[#9C27B0,thickness=2]-> settingsjson : load + persist

' === Flow: Proxy to Providers ===
router --> ccmax : Claude Max
router --> copilot : GitHub Copilot
router --> apikey : when on public network

' === Token Logging ===
router -[#FF9800,thickness=2]-> canon : result.model\n(every response)
canon -[#FF9800,thickness=2]-> logger : {model: canonical,\n model_raw: verbatim}
logger -[#FF9800,thickness=2]-> tokendb : INSERT row\n(user_hash, model, model_raw, …)
logger -[#FF9800,thickness=2]-> exporter : schedule
exporter -[#FF9800,thickness=2]-> window : compute window key
exporter -[#FF9800,thickness=2]-> tokenjson : per-window debounced\nwrite + safety merge by\n(user_hash, id)

' === Dashboard reads ===
page -[#43A047,thickness=2,dashed]-> fwd : /api/token-usage/*
dialog -[#43A047,thickness=2,dashed]-> fwd : GET/PUT /api/llm/settings
fwd -[#43A047,thickness=2,dashed]-> router : reverse-proxy
dev --> page : view stats

' === ETM triggers ===
etm -[#757575,thickness=1,dotted]-> obswriter : session events

' === Time-window source of truth (Phase 36-01) ===
package "Health Coordinator :3034" <<infra>> {
  component [/health/state\nlsl_meta.current_window] <<api>> as coordstate
}
window -[#2196F3,thickness=2,dashed]-> coordstate : HHMM-HHMM\n(local-time, cached 30 s)

' === Cross-user hydration on boot (Phase 36-03/04) ===
tokenjson -[#9C27B0,thickness=2,dashed]-> logger : hydrateFromExports()\nrecursive walk +\nON CONFLICT(user_hash, id)\nDO NOTHING
logger -[#9C27B0,thickness=2,dashed]-> tokendb : merge peers' rows

note right of tokendb
  Schema: id, **user_hash**, timestamp, provider,
  **model** (canonical), **model_raw** (verbatim),
  process, subscription, input/output tokens,
  latency_ms, prompt_preview (XML-stripped),
  tokens_estimated.

  UNIQUE INDEX idx_token_usage_user_id
    ON token_usage(user_hash, id)
  — the cross-user merge key.

  WAL/SHM/journal all gitignored.
end note

note right of tokenjson
  Phase 36 layout: per-(date, time-window,
  user-hash) under YYYY/MM/. Mirrors LSL's
  filename convention so multi-user teams
  compose files instead of merging a
  monolith. Hydrated into the DB on every
  proxy boot.

  user_hash sourced from
  LLM_PROXY_USER_HASH wrapper export.
  Time-window sourced from coordinator's
  lsl_meta.current_window (with local
  fallback).
end note

note bottom of page
  Four tabs sharing summary cards:
    Overview (treemap with hover tooltip
              showing in/out/calls/avg
              + SVG <title> a11y fallback,
              plus donut by provider)
    By Process (sortable table)
    Timeline (2-min buckets, zero-fill,
              viewer's local timezone)
    Recent Calls (last 50, XML-stripped preview)
  Header: Settings + Refresh (busy-state).
end note

note bottom of canon
  Collapses 8 upstream spellings of
  Sonnet 4.6 / Haiku 4.5 into single
  canonical names. Unrecognized models
  pass through unchanged. Raw upstream
  identifier preserved in model_raw for
  forensic debugging.
end note

note bottom of dialog
  Per-process pin is a hard override:
  wins over body.provider, falls through
  to auto-route only if the pinned
  provider becomes unreachable.
end note

@enduml
