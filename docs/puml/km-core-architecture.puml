@startuml km-core-architecture
!include _standard-style.puml

title KM-Core Architecture — Shared Core vs Per-System Configuration

top to bottom direction

' ============================================================
' Consumer layer — A / B / C / future systems
' ============================================================
package "Consumer Systems" as consumers #FAFAFA {
  [A: coding\n(obs-api, ObservationWriter)] as sysA <<external>>
  [B: mcp-server-semantic-analysis\n(wave-analysis, agents)] as sysB <<external>>
  [C: OKM\n(RaaS / KPI-FW / business)] as sysC <<external>>
}

' ============================================================
' SHARED CORE — owned by @fwornle/km-core
' ============================================================
package "@fwornle/km-core (SHARED CORE)" as core #E8F5E8 {

  package "Types & IDs" as types_pkg #F0F0F0 {
    [Entity / Relation / Layer\nProvenanceStamp\nSerializedGraph] as t <<core>>
    [mintEntityId / parseEntityId\n(UUIDv7)] as ids <<core>>
  }

  package "Store" as store_pkg #F0F0F0 {
    [GraphKMStore\nextends EventEmitter] as store <<core>>
    [Graphology\nMultiDirectedGraph\nin-memory] as graph <<core>>
    database "LevelDB\nclassic-level" as db <<storage>>
    [JSON Exporter\n5s debounce\natomic temp+rename] as exporter <<core>>
    folder ".data/exports/\ngit-tracked" as exports <<storage>>
  }

  package "Ontology Registry (Phase 38)" as ont_pkg #F0F0F0 {
    [OntologyRegistry\nupper.json + lower-*.json\nextends-chain resolution] as registry <<core>>
    [registryBackedValidator\n(pluggable)] as validator <<core>>
    [display-overlay\n(Phase 45)] as overlay <<core>>
  }

  package "Ingest Pipeline (Phase 40)" as pipeline_pkg #F0F0F0 {
    [IngestPipeline\n4-stage extract / synth / dedup / store] as pipeline <<core>>
    [LayeredDeduplicator\nExact / Embedding / LLM] as dedup <<core>>
  }

  package "REST + Snapshots (Phase 44)" as api_pkg #F0F0F0 {
    [createKmCoreRouter\n~15 endpoints under /api/v1/] as rest <<api>>
    [Zod contracts\napi/contracts] as contracts <<api>>
    [SnapshotManager\ngit-tag snapshots] as snapshots <<core>>
  }
}

' ============================================================
' PER-SYSTEM CONFIG — NOT owned by km-core
' ============================================================
package "Per-System Configuration (NOT owned by km-core)" as per_system #FFF9E6 {
  [Ontology files\n.data/ontologies/*.json\nA: coding-ontology / C: RaaS, KPI-FW] as ontology_files <<external>>
  [LLM provider config\nB: config/workflows/*.json\nA: rapid-llm-proxy] as llm_config <<external>>
  [Ingest adapters\nA: ObservationWriter\nB: wave-controller\nC: MkDocs / Confluence] as adapters <<external>>
  [Domain dedup / scoring\nA: Jaccard 0.45 / 4-keyword\nC: src/intelligence/dedup] as domain_eval <<external>>
}

' ============================================================
' Event surface
' ============================================================
[entity:put / entity:delete\nrelation:added / relation:removed] as events <<core>>

' ============================================================
' Wiring
' ============================================================
sysA -down-> rest : POST /api/v1/entities
sysB -down-> rest : query / mutate
sysC -down-> rest : ingest / query

rest -down-> store : putEntity / putRelation
rest -right-> contracts : validates body

pipeline -down-> dedup : layer chain
pipeline -down-> store : persist survivor
store -down-> graph : in-memory
store -down-> db : durable
store -down-> exporter : on mutation
exporter -down-> exports : atomic write
store -down-> events : emits
store -right-> validator : pre-write check
validator -up-> registry : resolved class
registry -right-> overlay : display hints (Phase 45)
snapshots -right-> exports : git tag / restore

' ============================================================
' Per-system config flows IN to core surfaces (read-only)
' ============================================================
ontology_files -up-> registry : load on startup
llm_config -up-> dedup : LLM matcher (Phase 40)
adapters -up-> pipeline : entity stream
domain_eval -up-> dedup : custom thresholds

events -up-> consumers : subscribe

' ============================================================
' Trust boundary
' ============================================================
note bottom of core
  **Trust boundary**: KM-Core is the canonical persistence
  and contract layer. Per-system config files (ontologies,
  LLM, ingest adapters, dedup rules) are loaded INTO core
  surfaces but live OUTSIDE the core package.
  This boundary is the SC-2 enforcement surface.
end note

@enduml
