@startuml observation-pipeline
!include _standard-style.puml

title Observational Memory Pipeline\n(single-owner host gateway)

top to bottom direction

rectangle "Coding Agents" <<agent>> {
  component "Claude Code" as claude
  component "Copilot CLI" as copilot
  component "OpenCode" as opencode
  component "Mastracode" as mastra
}

rectangle "Enhanced Transcript Monitor\n(host, per project)" <<core>> as etm {
  component "_firePromptSetObservation()" as fire
  component "ObservationApiClient\n(HTTP shim)" as etmclient
}

rectangle "Observations API Server\n(host, localhost:12436)\nSINGLE OWNER of observations.db" <<api>> as obsapi {
  component "POST /api/observations/messages" as ep_messages
  component "ObservationWriter" as ow
  component "summarize() + sanitize()" as summarize
  component "Semantic dedup\n+ serialized write" as dedup
  component "ObservationConsolidator\n(in-process)" as oc
  component "RetrievalService\n(fastembed + Qdrant)" as rs
}

rectangle "LLM CLI Proxy\n(host, localhost:12435)" <<api>> as proxy {
  component "LLMService" as llm
}

rectangle "LLM Providers" <<external>> as providers {
  component "claude-code\n(Max subscription)" as cc
  component "copilot\n(Enterprise)" as cp
  component "groq\n(API fallback)" as groq
}

database "SQLite WAL\n.observations/\nobservations.db\n(host filesystem)" <<storage>> as db

rectangle "Git-Tracked Export" <<storage>> as export {
  component "ObservationExporter" as exporter
  file ".data/observation-export/\nobservations.json\ndigests.json\ninsights.json" as json
}

rectangle "coding-services container\n(no .observations bind mount)" <<infra>> as container {
  component "Health Dashboard API\n(port 3033)\nthin HTTP forwarders" as dashapi
  component "Dashboard UI\n(port 3032)" as ui
}

claude --> etm
copilot --> etm
opencode --> etm
mastra --> etm

fire --> etmclient : messages\n(fire-and-forget)
etmclient SYNC_LINE ep_messages : POST\n/api/observations/messages
ep_messages --> ow
ow --> summarize : LLM summarize\nvia proxy
summarize --> proxy : POST /api/complete
proxy --> llm
llm --> cc : priority 1
llm --> cp : priority 2
llm --> groq : priority 3
summarize <-- proxy : summary +\nmodel/provider/tokens
summarize --> dedup : cleaned summary
dedup DATA_LINE db : writeObservation()\n(single writer, WAL)

ow ASYNC_LINE exporter : debounced\n(10s coalesce)
exporter DATA_LINE json

oc DATA_LINE db : reads + writes\ndigests, insights
rs DATA_LINE db : keyword search\n(FTS5)

dashapi SYNC_LINE obsapi : host.docker.internal:12436\n(reads, retrieve, consolidate/run)
ui --> dashapi : fetch + poll

note right of obsapi
  **Single-owner pattern** (mirrors OKB):
  one process opens observations.db at runtime.
  Eliminates SQLite WAL/SHM corruption from
  concurrent openers across the Docker
  bind-mount boundary.
end note

@enduml
