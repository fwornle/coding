@startuml observation-pipeline
!include _standard-style.puml

title Observational Memory Pipeline

top to bottom direction

rectangle "Coding Agents" <<agent>> {
  component "Claude Code" as claude
  component "Copilot CLI" as copilot
  component "OpenCode" as opencode
  component "Mastracode" as mastra
}

rectangle "Enhanced Transcript Monitor\n(per project)" <<core>> as etm {
  component "_firePromptSetObservation()" as fire
}

rectangle "ObservationWriter" <<core>> as ow {
  component "summarize()" as summarize
  component "_sanitizeSummary()" as sanitize
  component "_serializedWrite()" as serialize
  component "writeObservation()" as write
  component "Semantic dedup\n(Jaccard + containment)" as dedup
}

rectangle "LLM CLI Proxy\n(localhost:12435)" <<api>> as proxy {
  component "LLMService" as llm
}

rectangle "LLM Providers" <<external>> as providers {
  component "claude-code\n(Max subscription)" as cc
  component "copilot\n(Enterprise)" as cp
  component "groq\n(API fallback)" as groq
}

database "SQLite WAL\n.observations/\nobservations.db" <<storage>> as db

rectangle "Git-Tracked Export" <<storage>> as export {
  component "ObservationExporter" as exporter
  file ".data/observation-export/\nobservations.json\ndigests.json\ninsights.json" as json
}

rectangle "Health Dashboard\n(localhost:3032)" <<api>> as dash {
  component "REST API\n(port 3033)" as api
  component "Dashboard UI" as ui
}

claude --> etm
copilot --> etm
opencode --> etm
mastra --> etm

fire --> summarize : messages\n(fire-and-forget)
summarize --> proxy : POST /api/complete
proxy --> llm
llm --> cc : priority 1
llm --> cp : priority 2
llm --> groq : priority 3

summarize <-- proxy : summary +\nmodel/provider/tokens
summarize --> sanitize : raw LLM output
sanitize --> serialize : cleaned summary
serialize --> dedup : write lock\n(TOCTOU prevention)
dedup --> write : if unique
write --> db

write ASYNC_LINE exporter : debounced\n(10s coalesce)
exporter DATA_LINE json

api --> db : readonly\n(auto-reconnect\non corruption)
ui --> api : fetch + poll

@enduml
