@startuml
!include /Users/Q284340/Agentic/coding/docs/puml/_standard-style.puml

package "MCP Tool Layer" {
  class MCPToolHandler <<service>> {
    +execute_workflow(params: Map): Result
    +triggerIncrementalAnalysis(): void
    +validateRequest(request: Request): boolean
  }

  class WorkflowTrigger <<service>> {
    -triggerType: TriggerTypeEnum
    -payload: Map
    +fromMCPTool(tool: MCPToolHandler): WorkflowTrigger
    +fromAutoIncremental(): WorkflowTrigger
    +getPayload(): Map
  }

  enum TriggerTypeEnum {
    MCP_EXECUTE_WORKFLOW
    AUTOMATIC_INCREMENTAL
  }
}

package "Planning Layer" {
  interface IPlanningEngine {
    +createPlan(context: AnalysisContext): WorkflowPlan
    +validatePlan(plan: WorkflowPlan): boolean
    +refinePlan(plan: WorkflowPlan): WorkflowPlan
  }

  class WorkflowPlanner <<service>> {
    -knowledgeManager: KnowledgeManager
    -contextAnalyzer: ContextAnalyzer
    +createPlan(context: AnalysisContext): WorkflowPlan
    +validatePlan(plan: WorkflowPlan): boolean
    +refinePlan(plan: WorkflowPlan): WorkflowPlan
    -resolveDependencies(steps: List): List
  }

  class WorkflowPlan {
    -planId: String
    -steps: List
    -priority: Integer
    -estimatedCost: Float
    +addStep(step: ExecutionStep): void
    +getOrderedSteps(): List
    +toExecutionContext(): ExecutionContext
  }

  class ExecutionStep {
    -stepId: String
    -stepType: String
    -dependencies: List
    -parameters: Map
    +isReady(completedSteps: Set): boolean
    +getParameters(): Map
  }

  class ContextAnalyzer <<service>> {
    +analyzeContext(trigger: WorkflowTrigger): AnalysisContext
    +detectChanges(): ChangeSet
    +buildSemanticContext(): SemanticContext
  }

  class AnalysisContext {
    -semanticContext: SemanticContext
    -changeSet: ChangeSet
    -scope: ScopeEnum
    +isIncremental(): boolean
    +getAffectedEntities(): List
  }
}

package "Execution Layer" {
  interface IExecutionEngine {
    +execute(plan: WorkflowPlan): ExecutionResult
    +pause(): void
    +resume(): void
    +cancel(): void
  }

  class WorkflowExecutor <<service>> {
    -currentPlan: WorkflowPlan
    -stepExecutors: Map
    -state: ExecutionStateEnum
    +execute(plan: WorkflowPlan): ExecutionResult
    +pause(): void
    +resume(): void
    +cancel(): void
    -executeStep(step: ExecutionStep): StepResult
    -handleFailure(step: ExecutionStep, error: Error): void
  }

  class StepExecutor <<service>> {
    -stepType: String
    +canHandle(step: ExecutionStep): boolean
    +run(step: ExecutionStep): StepResult
    +rollback(step: ExecutionStep): void
  }

  class ExecutionResult {
    -resultId: String
    -status: ExecutionStateEnum
    -stepResults: List
    -duration: Long
    -errors: List
    +isSuccess(): boolean
    +getSummary(): String
  }

  class StepResult {
    -stepId: String
    -success: boolean
    -output: Map
    -errorMessage: String
    +toMetric(): Metric
  }

  enum ExecutionStateEnum {
    PENDING
    RUNNING
    PAUSED
    COMPLETED
    FAILED
    CANCELLED
  }
}

package "Knowledge Management" {
  class KnowledgeManager <<service>> {
    -semanticIndex: SemanticIndex
    -analysisStore: AnalysisStore
    +getContext(scope: ScopeEnum): SemanticContext
    +updateKnowledge(result: ExecutionResult): void
    +queryEntities(query: String): List
  }

  class SemanticIndex {
    -entities: Map
    -relationships: Map
    +indexEntity(entity: Object): void
    +findRelated(entity Id: String): List
    +search(query: String): List
  }

  class AnalysisStore {
    -results: Map
    +persist(result: ExecutionResult): void
    +retrieve(resultId: String): ExecutionResult
    +getHistory(limit: Integer): List
  }

  class SemanticContext {
    -entities: List
    -relationships: List
    -metadata: Map
    +getEntities(): List
    +getRelationships(): List
  }

  class ChangeSet {
    -additions: List
    -modifications: List
    -deletions: List
    +isEmpty(): boolean
    +getAffectedIds(): Set
  }
}

' Relationships
MCPToolHandler --> WorkflowTrigger : creates
WorkflowTrigger --> TriggerTypeEnum : uses
WorkflowTrigger --> WorkflowPlanner : triggers

WorkflowPlanner ..|> IPlanningEngine
WorkflowPlanner --> ContextAnalyzer : uses
WorkflowPlanner --> KnowledgeManager : queries
WorkflowPlanner --> WorkflowPlan : produces

WorkflowPlan "1" --* "many" ExecutionStep : contains
ContextAnalyzer --> AnalysisContext : produces
AnalysisContext --> SemanticContext : contains
AnalysisContext --> ChangeSet : contains

WorkflowExecutor ..|> IExecutionEngine
WorkflowExecutor --> WorkflowPlan : executes
WorkflowExecutor --> StepExecutor : delegates to
WorkflowExecutor --> ExecutionResult : produces
WorkflowExecutor --> ExecutionStateEnum : tracks
StepExecutor --> StepResult : produces
ExecutionResult "1" --* "many" StepResult : aggregates

KnowledgeManager --> SemanticIndex : manages
KnowledgeManager --> AnalysisStore : manages
KnowledgeManager --> SemanticContext : provides

WorkflowExecutor --> KnowledgeManager : updates after execution

@enduml