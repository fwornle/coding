@startuml
!include /Users/Q284340/Agentic/coding/docs/puml/_standard-style.puml

package "Trigger Layer" {
  interface MCPToolInterface <<interface>> {
    +execute_workflow(name: String, params: Map): WorkflowResult
    +get_workflow_status(workflowId: String): ProgressState
    +heartbeat(): void
  }

  class IncrementalAnalysisTrigger <<service>> {
    -checkpointFile: String
    -team: String
    +trigger(): void
    +resetCheckpoint(timestamp: String): void
  }
}

package "Workflow Engine" {
  class WorkflowRunner <<service>> {
    -workflowName: String
    -asyncMode: Boolean
    -debugMode: Boolean
    -progressFile: String
    +execute(params: Map): String
    +writeProgress(state: ProgressState): void
    +writeProgressPreservingDetails(state: ProgressState): void
  }

  class WaveController <<service>> {
    -team: String
    -currentWave: Integer
    -totalWaves: Integer
    +runWave(entities: List): WaveResult
    +runDedup(): void
    +runPrediction(): void
    +runMerge(): void
  }

  enum WorkflowMode <<enum>> {
    PRODUCTION
    DEBUG
    SINGLE_STEP
  }

  class ProgressState <<file>> {
    +status: String
    +currentStep: String
    +workflowId: String
    +mockLLM: Boolean
    +singleStepMode: Boolean
    +stepPaused: Boolean
    +pid: Integer
  }
}

package "Analysis Pipeline" {
  class Coordinator <<service>> {
    -ontologySystem: OntologySystem
    -team: String
    +classifyEntities(entities: List): List
    +hasValidPreClassification(entity: Entity): Boolean
    +updateEntityType(entity: Entity, type: String): void
  }

  class OntologySystem <<service>> {
    -upperOntologyPath: String
    -lowerOntologyPath: String
    +classify(entity: Entity): String
    +listClasses(type: String): List
    +suggestExtension(team: String): void
  }

  class PersistenceAgent <<service>> {
    -graphDB: GraphDatabase
    +persistEntities(entities: List): void
    +storeEntityToGraph(entity: Entity): void
    +calculateNameSimilarity(a: String, b: String): Float
    +findFuzzyMatch(name: String, existing: List): Entity
  }

  class InsightGenerationAgent <<service>> {
    -llmProvider: String
    +generateInsight(entity: Entity): Insight
    +generateMeaningfulNameAndTitle(pattern: Pattern): NameTitle
    +buildInsightDocument(entity: Entity): String
  }
}

package "Knowledge Store" {
  class GraphDatabase <<service>> {
    -storageBackend: String
    -team: String
    +mergeNodeAttributes(id: String, attrs: Map): void
    +getEntities(filter: Map): List
    +getRelations(): List
  }

  class Entity <<file>> {
    +id: String
    +name: String
    +type: String
    +entity Type: String
    +metadata: Map
    +observations: List
  }

  class Insight <<file>> {
    +entity Name: String
    +content: String
    +confidence: Float
    +diagramPaths: List
  }
}

MCPToolInterface ..> WorkflowRunner : triggers
IncrementalAnalysisTrigger ..> WorkflowRunner : triggers

WorkflowRunner *-- ProgressState : writes
WorkflowRunner --> WaveController : delegates waves
WorkflowRunner --> WorkflowMode : uses

WaveController --> Coordinator : classifies
WaveController --> PersistenceAgent : persists
WaveController --> InsightGenerationAgent : generates

Coordinator --> OntologySystem : classifies via
Coordinator --> Entity : updates

PersistenceAgent --> GraphDatabase : stores to
PersistenceAgent --> Entity : deduplicates

InsightGenerationAgent --> Insight : produces

GraphDatabase --> Entity : contains
GraphDatabase --> Insight : contains

@enduml