@startuml
!include /coding/docs/puml/_standard-style.puml

package "Graph Database Management" {
  component "GraphDatabaseManager" as gdm <<core>>
  component "GraphDatabaseAdapter" as gda <<storage>>
  component "LlmServiceManager" as lsm <<api>>
  component "WaveAgentController" as wac <<agent>>
  component "UkbTraceReportGenerator" as utrg <<external>>
  component "VkbApiClientManager" as vacm <<external>>
}

gdm --> gda : interacts
gdm --> lsm : uses
gdm --> wac : manages
gdm --> utrg : generates
gdm --> vacm : relies

package "Database Interactions" {
  database "Graph Database" as gd
  gda --> gd : connects
}

package "API Interactions" {
  cloud "VKB API" as vkb
  vacm --> vkb : interacts
}

@enduml