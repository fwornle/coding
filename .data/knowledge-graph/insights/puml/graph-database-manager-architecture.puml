@startuml
!include /coding/docs/puml/_standard-style.puml

package "Graph Database Management" {
  component "GraphDatabaseManager" as gdm <<core>>
  component "GraphDatabaseAdapter" as gda <<storage>>
  database "LevelDB" as ldb
  component "Graphology" as graph <<api>>
}

gdm --> gda : uses
gda --> ldb : stores
gda --> graph : utilizes
gdm --> graph : relies

package "Graph Operations" {
  gda --> graph : handles
}

@enduml