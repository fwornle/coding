@startuml
!include /coding/docs/puml/_standard-style.puml

package "lib/service-starter.js" {
  component "startServiceWithRetry()" as ssr <<core>>
  component "registerService()" as rs <<core>>
}

package "Supporting Patterns" {
  component "DeferredDependencyPattern" as ddp <<core>>
  component "ClosedVocabularyPattern" as cvp <<core>>
}

package "Integrations" {
  component "MCP Constraint Monitor" as mcp <<external>>
  component "VkbApiClient" as vkb <<api>>
}

package "Runtime" {
  component "Child Processes" as cp <<agent>>
}

ssr --> rs : "registers ownership"
ssr --> cvp : "prevents vocabulary drift"
ssr --> ddp : "coordinates startup"
rs --> cp : "tracks & owns"
cp ..> rs : "cleaned up via"
mcp --> ssr : "uses"
vkb --> ddp : "implements"
ddp ..> ssr : "defers to"

@enduml