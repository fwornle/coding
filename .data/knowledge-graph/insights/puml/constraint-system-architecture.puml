@startuml
!include /Users/Q284340/Agentic/coding/docs/puml/_standard-style.puml

title ConstraintSystem - Hook-Based Enforcement Architecture

package "Hook Infrastructure" {
    component "UnifiedHookManager" as uhm <<core>>
    component "HookConfigLoader" as hcl <<core>>
}

package "Configuration Sources" {
    component "User Config\n~/.coding-tools/hooks.json" as ucfg <<external>>
    component "Project Config\n.coding/hooks.json" as pcfg <<external>>
    component "DEFAULT_CONFIG" as dcfg <<core>>
}

package "Violation Persistence" {
    component "ViolationCaptureService" as vcs <<core>>
    database "Session Log\nsession-violations.jsonl" as slog <<storage>>
    database "Violation History\nviolation-history.json" as vhist <<storage>>
}

package "Validation Agents" {
    component "ContentValidationAgent" as cva <<agent>>
}

ucfg --> hcl : "loaded first"
pcfg --> hcl : "overrides user config"
dcfg --> hcl : "fallback structure"

hcl --> uhm : "registers handlers\n(priority-sorted)"

uhm --> vcs : "routes violations\non pre/post-tool events"

vcs --> slog : "writes JSONL"
vcs --> vhist : "persists (cap 1000)"

cva --> uhm : "scoped via\nagents[] filter"

@enduml