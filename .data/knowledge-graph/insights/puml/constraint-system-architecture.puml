@startuml
!include /coding/docs/puml/_standard-style.puml

component "Claude Code Agent" as agent <<agent>>

package "Configuration" {
  component "User Hooks Config\n~/.coding-tools/hooks.json" as userCfg <<external>>
  component "Project Hooks Config\n.coding/hooks.json" as projCfg <<external>>
}

package "Hook Infrastructure" {
  component "HookConfigLoader" as hookCfg <<core>>
  component "UnifiedHookManager" as hookMgr <<core>>
}

package "Violation Persistence" {
  component "ViolationCaptureService" as vcs <<core>>
  database "session-violations.jsonl\n(.mcp-sync/)" as sessionLog <<storage>>
  database "violation-history.json\n(.mcp-sync/)" as historyJson <<storage>>
}

package "MCP Integration" {
  component "mcp-constraint-monitor" as mcpMon <<api>>
  component "Violation Dashboard" as dashboard <<cli>>
}

agent --> hookMgr : "pre/post-tool events"

userCfg --> hookCfg : "base config"
projCfg --> hookCfg : "project overrides"
hookCfg --> hookMgr : "merged handlers\n(priority-sorted)"

hookMgr --> vcs : "constraint violations\n(sanitized params)"
vcs --> sessionLog : "appends JSONL"
vcs --> historyJson : "capped at 1000 entries"

historyJson --> dashboard : "violation history"
vcs --> dashboard : "calculateStatistics()"
mcpMon ..> hookMgr : "MCP bridge"
mcpMon --> dashboard : "semantic detection\n+ hook format docs"

@enduml