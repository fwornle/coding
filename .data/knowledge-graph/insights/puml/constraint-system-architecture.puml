@startuml
!include /coding/docs/puml/_standard-style.puml

package "Configuration" {
  component "User Config\n~/.coding-tools/hooks.json" as userCfg <<storage>>
  component "Project Config\n.coding/hooks.json" as projCfg <<storage>>
  component "HookConfigLoader" as hcl <<core>>
}

package "Hook Engine" {
  component "Claude Code\nHook Mechanism" as ccHook <<external>>
  component "UnifiedHookManager" as uhm <<core>>
}

package "Violation Management" {
  component "ViolationCaptureService" as vcs <<core>>
  component "Statistics Engine\ncalculateStatistics()" as stats <<api>>
}

package "Persistence & Reporting" {
  database "Session Log\nsession-violations.jsonl" as sessionLog <<storage>>
  database "Violation History\nviolation-history.json" as historyLog <<storage>>
  component "Dashboard" as dashboard <<external>>
}

userCfg --> hcl : "provides defaults"
projCfg --> hcl : "overrides"
hcl --> uhm : "merged config\n(timeout, stopOnError)"

ccHook --> uhm : "pre/post-tool\nlifecycle events"
uhm --> vcs : "violation events\n(priority-sorted handlers)"

vcs --> sessionLog : "live stream (JSONL)"
vcs --> historyLog : "persist (cap 1000)"
vcs --> stats : "in-memory array"

historyLog --> dashboard : "history display"
stats --> dashboard : "real-time metrics\n(24h counts, severity)"

@enduml