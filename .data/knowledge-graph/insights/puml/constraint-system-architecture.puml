@startuml
!include /coding/docs/puml/_standard-style.puml

package "Configuration Layer" {
  database "User Config\n~/.coding-tools/hooks.json" as userConfig <<storage>>
  database "Project Config\n.coding/hooks.json" as projectConfig <<storage>>
  component "HookConfigLoader" as configLoader <<core>>
}

package "Hook Execution Layer" {
  component "UnifiedHookManager" as hookManager <<core>>
}

package "Violation Persistence" {
  component "ViolationCaptureService" as violationSvc <<core>>
  database "JSONL Log\nsession-violations.jsonl" as jsonlLog <<storage>>
  database "JSON History\nviolation-history.json" as jsonHistory <<storage>>
}

package "Monitoring & Integration" {
  component "MCP Constraint Monitor" as mcpMonitor <<external>>
  component "Dashboard" as dashboard <<external>>
  component "MCP Semantic Analysis" as semanticAnalysis <<external>>
}

userConfig --> configLoader : "global defaults"
projectConfig --> configLoader : "project overrides"
configLoader --> hookManager : "mergeConfigs()"
hookManager --> violationSvc : "emit violations"
violationSvc --> jsonlLog : "append-only audit"
violationSvc --> jsonHistory : "capped 1000 entries"
jsonlLog --> mcpMonitor : "stream events"
jsonHistory --> mcpMonitor : "recent violations"
mcpMonitor --> dashboard : "status & stats"
semanticAnalysis ..> hookManager : "semantic detection"

@enduml