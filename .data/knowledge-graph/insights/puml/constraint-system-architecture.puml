@startuml
!include /Users/Q284340/Agentic/coding/docs/puml/_standard-style.puml

package "Hook Interception Layer" {
  component "UnifiedHookManager" as hookMgr <<core>>
  component "HookConfigLoader" as configLoader <<core>>
}

package "Configuration Sources" {
  component "User Hooks Config\n~/.coding-tools/hooks.json" as userCfg <<external>>
  component "Project Hooks Config\n.coding/hooks.json" as projCfg <<external>>
}

package "Constraint Enforcement" {
  component "Pre-Tool Hook Handler" as preHook <<api>>
  component "Post-Tool Hook Handler" as postHook <<api>>
  component "ContentValidationAgent" as cva <<agent>>
}

package "Persistence Layer" {
  component "ViolationCaptureService" as vcs <<core>>
  database "session-violations.jsonl\n.mcp-sync/" as jsonl <<storage>>
  database "violation-history.json\n.mcp-sync/" as jsonHist <<storage>>
}

userCfg --> configLoader : "user-level config"
projCfg --> configLoader : "project-level override"
configLoader --> hookMgr : "validated handler configs"
hookMgr --> preHook : "dispatches pre-tool events"
hookMgr --> postHook : "dispatches post-tool events"
preHook --> vcs : "constraint violations"
postHook --> vcs : "constraint violations"
cva --> vcs : "EntityValidationReport scores"
vcs --> jsonl : "append JSONL stream"
vcs --> jsonHist : "capped 1000 entries"

@enduml