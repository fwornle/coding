@startuml
!include /coding/docs/puml/_standard-style.puml

package "src/mock — Types & Core Logic" {
  component "LLMMode / LLMState" as llmTypes <<core>>
  component "getLLMMode()" as getLLMMode <<api>>
}

package "Priority Resolution Chain" {
  component "perAgentOverrides[agentId]" as p1Override <<core>>
  component "globalMode" as p2Global <<core>>
  component "mockLLM boolean (Legacy)" as p3Legacy <<core>>
  component "Hardcoded 'public'" as p4Default <<core>>
}

database "Progress File" as progressFile <<storage>>

package "Consumers & Targets" {
  component "Agent Runner" as agentRunner <<agent>>
  component "Local Model Server" as localServer <<external>>
  cloud "Public LLM API" as publicLLM <<external>>
}

agentRunner --> getLLMMode : calls
agentRunner ..> llmTypes : imports via mock path

getLLMMode --> p1Override : priority 1
p1Override --> p2Global : fallthrough
p2Global --> p3Legacy : fallthrough
p3Legacy --> p4Default : fallthrough

p1Override ..> progressFile : stale state persisted

getLLMMode --> localServer : routes (local)
getLLMMode --> publicLLM : routes (public)

@enduml