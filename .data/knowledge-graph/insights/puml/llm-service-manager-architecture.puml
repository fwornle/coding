@startuml
!include /coding/docs/puml/_standard-style.puml

package "LLM Service Management" {
  component "LlmServiceManager" as lsm <<core>>
  component "GraphDatabaseAdapter" as gda <<storage>>
  component "VkbApiClientManager" as vacm <<api>>
  component "WaveAgentController" as wac <<agent>>
}

package "Database" {
  database "GraphDatabase" as gd
}

lsm --> gda : persists data
lsm --> vacm : uses api
lsm --> wac : controls
gda --> gd : stores in
lsm ..> vacm : caches

@enduml