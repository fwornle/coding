@startuml
!include /Users/Q284340/Agentic/coding/docs/puml/_standard-style.puml

left to right direction

actor "Developer" as dev
actor "MCP Client" as mcp
actor "Scheduler" as scheduler

rectangle "Planning and Execution Workflow" {

  rectangle "Workflow Triggering" {
    usecase "Execute Workflow\nvia MCP Tool" as UC1
    usecase "Trigger Incremental\nAnalysis" as UC2
    usecase "Invoke execute_workflow\nTool" as UC3
  }

  rectangle "Planning Phase" {
    usecase "Analyze Codebase\nStructure" as UC4
    usecase "Generate Execution\nPlan" as UC5
    usecase "Identify Semantic\nDependencies" as UC6
    usecase "Prioritize Analysis\nTargets" as UC7
  }

  rectangle "Execution Phase" {
    usecase "Run Semantic\nAnalysis" as UC8
    usecase "Update Knowledge\nGraph" as UC9
    usecase "Persist Analysis\nResults" as UC10
    usecase "Manage Knowledge\nBase" as UC11
  }

  rectangle "Monitoring & Reporting" {
    usecase "Track Workflow\nProgress" as UC12
    usecase "Report Execution\nStatus" as UC13
    usecase "Handle Errors &\nRetries" as UC14
  }
}

' Actor relationships
dev --> UC1
dev --> UC12
mcp --> UC3
scheduler --> UC2

' Include relationships
UC1 ..> UC3 : <<include>>
UC2 ..> UC4 : <<include>>
UC3 ..> UC5 : <<include>>

UC5 ..> UC6 : <<include>>
UC5 ..> UC7 : <<include>>

UC8 ..> UC9 : <<include>>
UC8 ..> UC10 : <<include>>
UC9 ..> UC11 : <<include>>

UC12 ..> UC13 : <<include>>

' Extend relationships
UC14 ..> UC8 : <<extend>>
UC14 ..> UC5 : <<extend>>

' Flow connections
UC4 --> UC5
UC5 --> UC8
UC8 --> UC12

@enduml