@startuml
!include /Users/Q284340/Agentic/coding/docs/puml/_standard-style.puml

package "OntologyClassificationAgent Lifecycle" {
  component "OntologyClassificationAgent" as agent <<agent>>
  component "OntologyValidator" as validator <<core>>
  component "OntologyClassifier" as classifier <<core>>
}

package "Anti-Corruption Layer" {
  component "LegacyOntologyAdapter" as adapter <<api>>
}

package "km-core (@fwornle/km-core)" {
  component "OntologyRegistry" as registry <<external>>
}

agent --> validator : "uses"
agent --> classifier : "uses"
validator --> adapter : "depends on legacy interface"
classifier --> adapter : "depends on legacy interface"
adapter --> registry : "delegates to OntologyRegistry.load()"

@enduml