@startuml
!include /coding/docs/puml/_standard-style.puml

package "LLM Mock Service (llm-mock-service.ts)" as svc {
    component "setGlobalLLMMode()" as setGlobal <<api>>
    component "setAgentLLMMode()" as setAgent <<api>>
    component "getLLMState()" as getState <<core>>
    component "Legacy Mode Mapper\n(mockLLM → modern mode)" as legacyMapper <<core>>
}

package "State Persistence (.data/)" as storage {
    database "workflow-progress.json" as wpJson <<storage>>
}

package "Mode Priority Chain" as priority {
    component "Per-Agent Override" as agentMode <<core>>
    component "Global Mode Setting" as globalMode <<core>>
    component "Hardcoded Fallback\n'public'" as fallback <<core>>
}

component "LLM Call Router" as router <<external>>

setGlobal --> wpJson : "persists global mode"
setAgent --> wpJson : "persists per-agent override"
getState --> wpJson : "reads at invocation time\n(no restart needed)"
wpJson --> legacyMapper : "legacy mockLLM\nboolean field"
legacyMapper --> globalMode : "maps to modern mode"

getState --> agentMode : "resolves — strict priority"
getState --> globalMode : "resolves — mid priority"
getState --> fallback : "resolves — lowest priority"

agentMode --> router : "overrides all"
globalMode --> router : "overrides fallback"
fallback --> router : "default route"

@enduml