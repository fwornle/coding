@startuml
!include /coding/docs/puml/_standard-style.puml

top to bottom direction

package "Configuration" {
    component "agent-profiles.json" as agentProfiles <<storage>>
    component "llm-providers.yaml" as llmProviders <<storage>>
}

package "Routing Runtime" {
    component "Task Complexity\nClassifier" as taskClassifier <<core>>
    component "ensureLLMInitialized()" as llmInit <<api>>
}

package "Provider Tiers" {
    component "Local Tier" as localTier <<external>>
    component "Remote Tier" as remoteTier <<external>>
    component "Fast Tier" as fastTier <<external>>
    component "Capable Tier" as capableTier <<external>>
}

taskClassifier --> agentProfiles : "resolves tier\nby task class"
agentProfiles ..> llmInit : "tier name"
llmProviders ..> llmInit : "tier-to-provider\nmapping"
llmInit --> localTier : "[local]"
llmInit --> remoteTier : "[remote]"
llmInit --> fastTier : "[fast]"
llmInit --> capableTier : "[capable]"

@enduml