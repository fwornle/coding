@startuml
!include /coding/docs/puml/_standard-style.puml

package "Ingestion Sources" {
  component "Git History" as git <<external>>
  component "LSL Sessions" as lsl <<external>>
  component "Code Analysis" as codeanalysis <<external>>
}

package "Orchestration Layer" {
  component "MCP Semantic Analysis Server" as mcpserver <<core>>
  component "PersistenceAgent" as persistagent <<agent>>
}

package "Storage Layer" {
  component "GraphDatabaseAdapter" as dbadapter <<core>>
  cloud "VKB HTTP API" as vkbapi <<api>>
  database "LevelDB + Graphology" as leveldb <<storage>>
}

git --> mcpserver : "ingests"
lsl --> mcpserver : "ingests"
codeanalysis --> mcpserver : "ingests"

mcpserver --> persistagent : "orchestrates extraction"
persistagent --> dbadapter : "mapEntityToSharedMemory()\n+ bi-temporal fields"
dbadapter --> vkbapi : "primary write\n(typed nodes + embeddings)"
dbadapter ..> leveldb : "fallback write\n(lock-safe)"
vkbapi --> leveldb : "semantic similarity queries"

@enduml