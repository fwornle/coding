@startuml
!include /coding/docs/puml/_standard-style.puml

top to bottom direction

package "Batch Pipeline" {
  component "OnlineLearning" as ol <<core>>
}

package "State Management" {
  component "CheckpointManager" as cm <<core>>
}

package "Storage Layer" {
  component "GraphDatabaseAdapter" as gda <<storage>>
  cloud "VKB HTTP Server" as vkb <<external>>
}

package "Export Layer" {
  component "GraphKnowledgeExporter" as gke <<core>>
  database "Per-Domain JSON Files" as json <<storage>>
}

ol --> cm : "commit hashes / session counts"
cm --> ol : "completeness scores / skip state"
ol --> gda : "entities (batch write)"
gda ..> vkb : "direct mode (must be live at startup)"
ol --> gke : "entity:stored events"
gke --> json : "debounced writes"

@enduml