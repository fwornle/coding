@startuml
!include /coding/docs/puml/_standard-style.puml

package "Extraction Sources" {
  component "Git History Ingestion" as git <<external>>
  component "LSL Session Analysis" as lsl <<external>>
  component "Code Analysis" as code <<external>>
}

package "Batch Analysis Pipeline" {
  component "batch-analysis.yaml\n(DAG Steps)" as dag <<core>>
  component "GraphDatabaseService.js" as gds <<core>>
}

package "Graph Layer" {
  component "Graphology Graph\n(isDirty / flush cycle)" as graphology <<core>>
}

package "Persistence" {
  database "LevelDB" as leveldb <<storage>>
}

git --> dag : "graph mutations"
lsl --> dag : "graph mutations"
code --> dag : "DEFINES / DEPENDS_ON_EXTERNAL\nCONTAINS_FILE edges"

dag --> gds : "accumulated step outputs"
gds --> graphology : "write nodes & edges"
graphology --> leveldb : "flush() → single 'graph' key\n(monolithic JSON blob)"

@enduml