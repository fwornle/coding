@startuml
!include /Users/Q284340/Agentic/coding/docs/puml/_standard-style.puml

package "Input Sources" {
  component "Git History Extractor" as git <<core>>
  component "LSL Session Analyzer" as lsl <<core>>
  component "CodeGraphAgent" as cga <<agent>>
}

package "OnlineLearning Pipeline" {
  component "Batch Analysis DAG" as dag <<core>>
  component "LLM-Assisted Extractor" as llm <<core>>
  component "EntityTypeRegistry" as etr <<core>>
}

package "Knowledge Storage" {
  component "Graphology (in-memory)" as graphology <<storage>>
  database "LevelDB" as leveldb <<storage>>
}

cloud "Token Usage Dashboard" as tokenDash <<external>>

git --> dag : feeds
lsl --> dag : feeds
cga --> dag : AST index
dag --> llm : extraction steps
llm --> etr : ontology classification
etr --> graphology : typed entities
graphology --> leveldb : persistence
dag ..> tokenDash : meters token usage

@enduml