@startuml
!include /Users/Q284340/Agentic/coding/docs/puml/_standard-style.puml

package "Extraction Sources" {
    component "Git History" as git <<external>>
    component "LSL Sessions" as lsl <<external>>
    component "Code Analysis" as code <<external>>
}

package "OnlineLearning Pipeline" {
    component "batch-analysis.yaml\nOrchestrator" as orchestrator <<core>>
    component "Ontology Classifier" as classifier <<core>>
    component "Provenance Stamper" as provenance <<core>>
}

package "Knowledge Store" {
    database "GraphDatabaseService" as graph <<storage>>
    component "KnowledgeDecayTracker" as decay <<core>>
}

git --> orchestrator : "typed entities"
lsl --> orchestrator : "typed entities"
code --> orchestrator : "typed entities"

orchestrator --> classifier : "raw entities"
classifier --> provenance : "classified entities"
provenance --> graph : "source: pipeline"
provenance --> decay : "decay policy signal"

@enduml