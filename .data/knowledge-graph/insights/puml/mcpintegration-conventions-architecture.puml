}

semanalysis --> apiref : "publishes"
semanalysis --> archdocs : "includes"
semanalysis --> installdocs : "includes"
semanalysis --> readmepat : "follows"
semanalysis --> devtracker : "records violations in"
coderag --> ccsetup : "provides"
