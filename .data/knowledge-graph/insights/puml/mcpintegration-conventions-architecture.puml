}

package "Documentation Standards" {
  component "API Reference\n(docs/api/README.md)" as apiref <<api>>
  component "Architecture Docs\n(docs/architecture/)" as archdocs <<core>>
  component "Installation Docs\n(docs/installation/)" as installdocs <<core>>
