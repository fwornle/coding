@startuml
!include /coding/docs/puml/_standard-style.puml

package "Agent Adapters" {
  component "Claude Code Adapter" as claude <<agent>>
  component "Copilot CLI Adapter" as copilot <<agent>>
  component "transcript-api.js" as transcriptApi <<api>>
}

package "Configuration" {
  component "redaction-config.yaml" as redactionConfig <<external>>
  component "LSLConfigValidator" as validator <<core>>
}

package "LSL Pipeline" {
  component "lsl-converter.js\n(convertToLSL)" as lslConverter <<core>>
  component "RedactionLayer" as redactionLayer <<core>>
}

package "Persistence" {
  database "Storage" as storage <<storage>>
}

claude --> transcriptApi : "raw transcript"
copilot --> transcriptApi : "raw transcript"
transcriptApi --> lslConverter : "adapter output"
lslConverter --> redactionLayer : "LSL typed entries\n(user, assistant, tool_result)"
redactionConfig --> validator : "schema definition"
validator --> redactionLayer : "validated rules\n(startup check)"
redactionLayer --> storage : "redacted LSL entries"

@enduml