@startuml
!include /coding/docs/puml/_standard-style.puml

package "Bootstrap Layer" {
  component "Application Startup" as appStartup <<core>>
  component "Environment Variables\n(credentials, endpoints)" as envVars <<core>>
}

package "Agent Layer\n(mcp-server-semantic-analysis/src/agents)" {
  component "BaseAgent\n(base-agent.ts)" as baseAgent <<core>>
  component "ensureLLMInitialized()" as ensureInit <<api>>
  component "Concrete Agent Subclasses" as concreteAgents <<agent>>
}

package "LLM Provider" {
  component "LLM Client\n(nullable field, idempotent guard)" as llmClient <<external>>
}

package "Test Layer" {
  component "Unit Tests" as unitTests <<cli>>
  component "Mock LLM Client" as mockClient <<external>>
}

appStartup --> concreteAgents : "instantiates (no LLM yet)"
appStartup --> envVars : "resolves credentials"
concreteAgents --> baseAgent : "inherits"
baseAgent --> ensureInit : "defines single entry point"
concreteAgents --> ensureInit : "calls at each method entry"
ensureInit --> envVars : "reads after boot resolution"
ensureInit --> llmClient : "constructs lazily (once)"
unitTests --> concreteAgents : "constructs in isolation"
unitTests --> mockClient : "injects"
mockClient ..> ensureInit : "fulfills without outbound calls"

@enduml