@startuml
!include /coding/docs/puml/_standard-style.puml

package "Pipeline Configuration" {
  component "batch-analysis.yaml\n(DAG Definition)" as dagConfig <<core>>
}

package "Orchestration" {
  component "Coordinator Agent" as coordinator <<agent>>
}

package "Processing Pipeline" {
  component "BaseAgent<TInput, TOutput>" as baseAgent <<core>>
  component "Observation Agent" as obsAgent <<agent>>
  component "KG Operator Agent" as kgAgent <<agent>>
  component "Dedup Agent" as dedupAgent <<agent>>
  component "Persistence Agent" as persistAgent <<agent>>
}

package "Storage Layer" {
  database "Memgraph" as memgraph <<storage>>
  component "Shared Memory" as sharedMem <<storage>>
}

dagConfig --> coordinator : "defines DAG\nexecution order"

coordinator --> obsAgent : "routes typed input"
obsAgent --> kgAgent : "response envelope\n(confidence scored)"
kgAgent --> dedupAgent : "structured entity sets"
dedupAgent --> persistAgent : "deduplicated entities"

baseAgent ..> coordinator : "extends"
baseAgent ..> obsAgent : "extends"
baseAgent ..> kgAgent : "extends"
baseAgent ..> dedupAgent : "extends"
baseAgent ..> persistAgent : "extends"

persistAgent --> sharedMem : "mapEntityToSharedMemory()\nontology metadata pre-population"
persistAgent --> memgraph : "MEMGRAPH_BATCH_SIZE\nbatched flush"

@enduml