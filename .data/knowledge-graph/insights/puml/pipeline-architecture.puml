@startuml
!include /coding/docs/puml/_standard-style.puml

package "Pipeline (Batch Processing)" {
    component "Coordinator" as coordinator <<core>>
    component "Observation Generation" as obsgen <<agent>>
    component "KG Operators" as kgops <<core>>
    component "Deduplication" as dedup <<core>>
    component "Persistence" as persist <<storage>>
}

package "SemanticAnalysis" {
    component "Semantic Analysis" as semanalysis <<core>>
}

semanalysis --> coordinator : "orchestrates"
coordinator --> obsgen : "triggers"
obsgen --> kgops : "feeds"
kgops --> dedup : "passes"
dedup --> persist : "writes"

@enduml