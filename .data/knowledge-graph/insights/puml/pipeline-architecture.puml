@startuml
!include /coding/docs/puml/_standard-style.puml

cloud "Git Commits" as gitcommits <<external>>

package "Configuration" {
  component "batch-analysis.yaml" as yaml <<core>>
}

package "Pipeline Coordination" {
  component "Pipeline Coordinator" as coordinator <<core>>
}

package "Agent Pipeline" {
  component "SemanticAnalysisAgent" as semantic <<agent>>
  component "DeduplicationAgent" as dedup <<agent>>
  component "PersistenceAgent" as persistence <<agent>>
  component "KG Operator Agent" as kgop <<agent>>
}

package "Storage Layer" {
  component "Shared Memory" as sharedmem <<storage>>
  database "Memgraph" as memgraph
}

yaml --> coordinator : "defines DAG\n& depends_on edges"

gitcommits --> semantic : "raw commit arrays\n(TInput)"

coordinator --> semantic : "sequences"
coordinator --> dedup : "sequences"
coordinator --> persistence : "sequences"
coordinator --> kgop : "sequences via\nrouting output"

semantic --> dedup : "structured observations"
dedup --> persistence : "deduplicated\nclassified entities"
persistence --> sharedmem : "mapEntityToSharedMemory()\nontology metadata cache"
persistence --> kgop : "resolved entities"
kgop --> memgraph : "batch writes\n(MEMGRAPH_BATCH_SIZE)"

@enduml