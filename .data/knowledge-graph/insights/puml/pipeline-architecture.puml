@startuml
!include /Users/Q284340/Agentic/coding/docs/puml/_standard-style.puml

left to right direction

package "MCP Server Layer" {
  component "MCP Server\n(mcp-server-semantic-analysis)" as mcpServer <<api>>
}

package "Orchestration" {
  component "Coordinator Agent" as coordinator <<agent>>
}

package "Processing Pipeline" {
  component "Observation Generation Agent" as obsAgent <<agent>>
  component "KG Operator Agents" as kgOps <<agent>>
  component "Deduplication Agent" as dedupAgent <<agent>>
  component "Persistence Agent" as persistAgent <<agent>>
}

package "Input Sources" {
  component "Git History" as gitHistory <<external>>
  component "LSL Session Logs" as lslLogs <<external>>
}

package "Storage" {
  database "GraphKMStore" as graphStore <<storage>>
}

mcpServer --> coordinator : "triggers"
gitHistory --> obsAgent : "commit diffs"
lslLogs --> obsAgent : "session events"
coordinator --> obsAgent : "1. generate observations"
obsAgent --> kgOps : "candidate entities"
coordinator --> kgOps : "2. construct/mutate graph"
kgOps --> dedupAgent : "classified entities"
coordinator --> dedupAgent : "3. merge duplicates"
dedupAgent --> persistAgent : "deduplicated entities"
coordinator --> persistAgent : "4. persist"
persistAgent --> graphStore : "writes with ontology metadata"

@enduml