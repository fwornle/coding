@startuml
!include /coding/docs/puml/_standard-style.puml

package "Learning Sources" {
  component "ManualLearning" as ml <<agent>>
  component "OnlineLearning" as ol <<agent>>
}

package "Knowledge Graph" {
  database "LevelDB" as ldb <<storage>>
  component "entity:stored Event Bus" as evtbus <<core>>
  component "HTTP API" as httpapi <<api>>
}

package "Export Pipeline" {
  component "GraphKnowledgeExporter" as gke <<core>>
  component "Debounce Layer" as dbl <<core>>
  component "Domain-Partitioned JSON Files" as json <<storage>>
}

package "Downstream Consumers" {
  component "RAG Integrations" as rag <<external>>
}

ml --> ldb : "writes entity"
ol --> ldb : "batch writes"
ldb --> evtbus : "emits on\nsuccessful write"
ldb --> httpapi : "serves"
evtbus --> gke : "subscribes\n(all sources)"
gke --> dbl : "coalesces rapid\nupdates per domain"
dbl --> json : "exports\nper domain"
json --> rag : "file-based\nconsumption"
httpapi ..> rag : "not accessible\nto downstream"

@enduml