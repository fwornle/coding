@startuml
!include /coding/docs/puml/_standard-style.puml

package "MCP Semantic Analysis Server" {
    component "Agent Factory\n/ Dispatcher" as agentFactory <<core>>
    component "Agent (Global Mode)" as agentGlobal <<agent>>
    component "Agent (Per-Agent Override)" as agentOverride <<agent>>
}

package "mock/ Subdirectory" {
    component "LLMMockService\n(Singleton)" as llmMock <<core>>
    component "Mock Mode\n(Deterministic / Offline)" as modeMock <<api>>
    component "Local Mode\n(Local LLM Backend)" as modeLocal <<api>>
    component "Public Mode\n(External LLM API)" as modePublic <<api>>
}

package "Infrastructure" {
    component "Docker Container\n/ CI Pipeline" as docker <<external>>
    cloud "External LLM API" as externalLLM <<external>>
}

agentFactory --> llmMock : "get/set global mode"
agentGlobal --> llmMock : "reads global default"
agentOverride --> llmMock : "applies per-agent override"

llmMock --> modeMock : "routes to"
llmMock --> modeLocal : "routes to"
llmMock --> modePublic : "routes to"

docker --> modeMock : "offline / API-blocked CI"
modePublic --> externalLLM : "calls"

agentFactory --> agentGlobal : "instantiates"
agentFactory --> agentOverride : "instantiates"

@enduml