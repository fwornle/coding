@startuml
!include /coding/docs/puml/_standard-style.puml

top to bottom direction

cloud "Docker Container" as docker <<external>>

package "Service Wrappers" {
  component "dashboard-service.js" as dashSvc <<core>>
  component "api-service.js" as apiSvc <<core>>
}

package "Child Processes" {
  component "Next.js Process :3030" as nextjs <<api>>
  component "API Process :3031" as apiProc <<api>>
}

package "Infrastructure" {
  component "lib/service-starter.js" as starter <<core>>
  component "PSM" as psm <<storage>>
  component "health-coordinator.js" as healthCoord <<core>>
}

docker --> dashSvc : "SIGTERM / SIGINT"
docker --> apiSvc : "SIGTERM / SIGINT"

starter --> dashSvc : "restart / retry policy"
starter --> apiSvc : "restart / retry policy"

dashSvc --> nextjs : "spawn via child_process"
dashSvc --> nextjs : "forward signals"
dashSvc --> psm : "registerService / unregisterService"

apiSvc --> apiProc : "spawn via child_process"
apiSvc --> apiProc : "forward signals"
apiSvc --> psm : "registerService / unregisterService"

healthCoord ..> psm : "reads state"

@enduml