@startuml
!include /coding/docs/puml/_standard-style.puml

top to bottom direction

package "Managed Services" {
  component "Wrapper Scripts" as wrappers <<cli>>
  component "api-service.js" as apiService <<external>>
  component "dashboard-service.js" as dashService <<external>>
}

package "Process State" {
  component "PSM\n(Process State Manager)" as psm <<storage>>
}

package "Health Monitoring" {
  component "HealthCoordinator\n(health-coordinator.js)" as hc <<core>>
  component "ServiceProbe\n(lib/utils/service-probe.js)" as probe <<api>>
}

wrappers --> apiService : "spawns & owns handle"
wrappers --> dashService : "spawns & owns handle"
wrappers --> psm : "registers by name"

hc --> psm : "reads state by name"
hc --> probe : "delegates liveness checks"

probe --> apiService : "probes endpoint"
probe --> dashService : "probes endpoint"
probe --> hc : "normalized status envelopes"

@enduml