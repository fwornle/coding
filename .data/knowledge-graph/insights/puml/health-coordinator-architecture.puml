@startuml
!include /coding/docs/puml/_standard-style.puml

top to bottom direction

package "Health Coordination" {
  component "health-coordinator.js" as hc <<core>>
  component "State Machine\n(running | stopped | unknown)" as sm <<core>>
}

package "Probe Layer" {
  component "service-probe.js" as sp <<api>>
  component "probeHttpHealth()" as httpProbe <<api>>
  component "probeTcpPort()" as tcpProbe <<api>>
}

package "Monitored Services" {
  component "Next.js Dashboard" as nextjs <<external>>
  component "Node.js API" as nodeapi <<external>>
  database "Memgraph" as memgraph <<storage>>
  database "Redis" as redis <<storage>>
}

hc --> sm : "updates state"
hc --> sp : "polls every 5s"

sp --> httpProbe : "HTTP checks"
sp --> tcpProbe : "TCP checks"

httpProbe --> nextjs : "HTTP probe"
httpProbe --> nodeapi : "HTTP probe"
tcpProbe --> memgraph : "TCP probe"
tcpProbe --> redis : "TCP probe"

@enduml