@startuml
!include /coding/docs/puml/_standard-style.puml

top to bottom direction

package "Configuration" {
  component "health-verification-rules.json" as rules <<storage>>
}

package "DockerizedServices" {
  component "health-coordinator.js" as hc <<core>>
}

package "Service Probing" {
  component "ServiceProbeLibrary" as spl <<api>>
  component "Registered Services" as rs <<external>>
}

package "Runtime State" {
  database "currentState.services" as css <<storage>>
}

rules --> hc : "reads evaluation criteria\n(per poll cycle)"
hc --> spl : "drives polling\n(5s fixed interval)"
spl --> rs : "probes"
rs ..> spl : "probe responses"
hc --> css : "writes aggregated results"

@enduml