@startuml
!include /Users/Q284340/Agentic/coding/docs/puml/_standard-style.puml

package "Consumers" {
  component "Health Coordinator" as hc <<core>>
  component "Service Starter Framework\nlib/service-starter.js" as ssf <<core>>
}

package "ServiceProbeLibrary\nlib/utils/service-probe.js" {
  component "HTTP Probe Strategy" as http <<api>>
  component "TCP Probe Strategy" as tcp <<api>>
}

package "Monitored Services" {
  component "Constraint Monitor API" as cma <<api>>
  component "Dashboard Service" as dash <<api>>
  component "Port-Level Services" as ports <<external>>
}

hc --> http : "runtime liveness checks"
hc --> tcp : "runtime liveness checks"
ssf --> http : "startup health gating"
ssf --> tcp : "startup health gating"

http --> cma : "probes REST endpoint"
http --> dash : "probes REST endpoint"
tcp --> ports : "probes port reachability"

@enduml