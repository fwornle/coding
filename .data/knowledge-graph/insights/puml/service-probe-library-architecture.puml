@startuml
!include /coding/docs/puml/_standard-style.puml

package "Orchestration Layer" {
  component "health-coordinator.js" as hc <<core>>
}

package "lib/utils — ServiceProbeLibrary" {
  component "service-probe.js\n[Abstraction Boundary]" as sp <<core>>
  component "HTTP Probe Variant" as httpProbe <<api>>
  component "TCP Probe Variant" as tcpProbe <<api>>
}

package "External Probe Targets" {
  cloud "HTTP Endpoint" as httpExt <<external>>
  cloud "TCP Endpoint" as tcpExt <<external>>
}

hc --> sp : "invokes on 5s polling tick"
sp --> httpProbe : "delegates (HTTP path)"
sp --> tcpProbe : "delegates (TCP path)"
httpProbe --> httpExt : "HTTP liveness check"
tcpProbe --> tcpExt : "TCP liveness check"
httpProbe ..> sp : "reachable / unreachable"
tcpProbe ..> sp : "reachable / unreachable"
sp ..> hc : "liveness signal\n[SPEC R6: never returns healthy]"

@enduml