@startuml
!include /coding/docs/puml/_standard-style.puml

package "Structured Config Layer" {
  component "agent-profiles.json" as agentProfiles <<core>>
  component "health-verification-rules.json" as healthRules <<core>>
  component "llm-providers.yaml" as llmProviders <<core>>
  component "knowledge-management.json" as knowledgeMgmt <<core>>
  component "hooks-config.json" as hooksConfig <<core>>
}

package "MCP Integrations" {
  component "MCP Semantic Analysis" as mcpSemantic <<external>>
  component "MCP Constraint Monitor" as mcpConstraint <<external>>
}

package "Runtime Subsystems" {
  component "Agent System" as agentSystem <<agent>>
  component "Knowledge Pipeline" as knowledgePipeline <<core>>
  component "Hook Engine" as hookEngine <<core>>
}

agentProfiles --> agentSystem : "LLM tier + concurrency"
llmProviders --> mcpSemantic : "provider endpoints"
healthRules --> mcpConstraint : "verification rules"
knowledgeMgmt --> knowledgePipeline : "pipeline params"
hooksConfig --> hookEngine : "hook definitions"

mcpSemantic --> agentSystem : "model routing"
mcpConstraint --> agentSystem : "constraint checks"
knowledgePipeline --> agentSystem : "knowledge context"
hookEngine --> agentSystem : "lifecycle hooks"

@enduml