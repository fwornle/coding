@startuml
!include /coding/docs/puml/_standard-style.puml

' ── Layout ──────────────────────────────────────────────
top to bottom direction

' ── Config File Sources ──────────────────────────────────
package "User-Level Config" {
    database "~/.coding-tools/hooks.json" as userCfg <<storage>>
}

package "Project-Level Config" {
    database "{project}/.coding/hooks.json" as projCfg <<storage>>
}

' ── Core Loader ──────────────────────────────────────────
package "lib/agent-api/hooks" {
    component "HookConfigLoader" as loader <<core>>
    component "mergeConfigs()" as merge <<core>>
}

' ── Merged Output ────────────────────────────────────────
package "Runtime Hook Registry" {
    component "Handler Bindings" as handlers <<api>>
    component "Constraint Rules" as constraints <<api>>
    component "Hook Definitions" as hookDefs <<api>>
}

' ── Data Flow ────────────────────────────────────────────
userCfg  --> loader     : reads (machine-wide defaults)
projCfg  --> loader     : reads (repository overrides)
loader   --> merge      : delegates config resolution
merge    --> handlers   : project supersedes user
merge    --> constraints : project supersedes user
merge    --> hookDefs   : project supersedes user

' ── Precedence Annotation ────────────────────────────────
projCfg  --> userCfg    : unconditional precedence

@enduml