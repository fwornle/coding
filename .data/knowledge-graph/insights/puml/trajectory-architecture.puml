@startuml
!include /coding/docs/puml/_standard-style.puml

package "Trajectory" {
  component "Trajectory Component" as tc <<core>>
}

package "Data Storage" {
  component "Graphology" as graph <<storage>>
  component "LevelDB" as leveldb <<storage>>
  component "JSON Export" as json <<storage>>
}

package "External Services" {
  component "Specstory" as spec <<external>>
  component "Browser Access MCP Server" as bamcp <<external>>
  component "Code Graph RAG System" as cgr <<external>>
}

tc --> graph : uses
tc --> leveldb : uses
tc --> json : uses
tc --> spec : logs conversations
tc --> bamcp : connects via BROWSER_ACCESS_PORT
tc --> cgr : connects via CODE_GRAPH_RAG_SSE_PORT

@enduml