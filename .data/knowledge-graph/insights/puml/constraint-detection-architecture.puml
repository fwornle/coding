@startuml
!include /coding/docs/puml/_standard-style.puml

package "Constraint Detection" {
  component "ConstraintDetection" as cd <<core>>
}

package "Data Management" {
  component "GraphDatabaseAdapter" as gda <<storage>>
  database "GraphDatabase" as gd
  gda --> gd
}

package "Code Analysis" {
  component "CodeGraphConstructor" as cgc <<core>>
  cgc --> cd
}

cd --> gda : uses
cd --> cgc : provides

@enduml