@startuml
!include /coding/docs/puml/_standard-style.puml

package "Service Wrappers" {
    component "scripts/api-service.js" as apiWrapper <<api>>
    component "scripts/dashboard-service.js" as dashWrapper <<api>>
}

package "Managed Processes" {
    component "API Service Process" as apiProc <<core>>
    component "Dashboard Service Process" as dashProc <<core>>
}

package "PSM Coordination Layer" {
    component "PSM.registerService()" as psmReg <<external>>
    component "PSM.unregisterService()" as psmUnreg <<external>>
}

apiWrapper --> apiProc : "spawn (blocking)"
dashWrapper --> dashProc : "spawn (blocking)"

apiWrapper ..> psmReg : "post-spawn register\n(non-blocking, swallowed errors)"
dashWrapper ..> psmReg : "post-spawn register\n(non-blocking, swallowed errors)"

apiWrapper ..> psmUnreg : "exit handler cleanup"
dashWrapper ..> psmUnreg : "exit handler cleanup"

@enduml