@startuml
!include /Users/Q284340/Agentic/coding/docs/puml/_standard-style.puml

title Agent Persistent Memory Files - Interaction Sequence

participant "Agent" as Agent
participant "Memory Manager" as MemMgr
participant "Persistent Memory Files" as PMF
participant "Semantic Analyzer" as SemAnalyzer
participant "Knowledge Store" as KnowledgeStore

== Initialization ==
Agent -> MemMgr : initialize()
MemMgr -> PMF : loadMemoryFiles()
PMF --> MemMgr : memoryFilesLoaded
MemMgr --> Agent : ready

== Knowledge Retrieval ==
Agent -> MemMgr : retrieveContext(query)
MemMgr -> PMF : readMemoryFile(contextKey)
PMF --> MemMgr : rawMemoryData
MemMgr -> SemAnalyzer : analyzeSemantics(rawMemoryData)
SemAnalyzer --> MemMgr : enrichedContext
MemMgr --> Agent : contextResponse

== Knowledge Persistence ==
Agent -> MemMgr : persistKnowledge(data)
MemMgr -> SemAnalyzer : extractSemanticEntities(data)
SemAnalyzer --> MemMgr : semanticEntities
MemMgr -> KnowledgeStore : storeEntities(semanticEntities)
KnowledgeStore --> MemMgr : stored
MemMgr -> PMF : writeMemoryFile(data)
PMF --> MemMgr : written
MemMgr --> Agent : persistenceConfirmed

== Memory Update Cycle ==
loop Periodic Sync
    MemMgr -> PMF : syncMemoryFiles()
    PMF -> KnowledgeStore : reconcileKnowledge()
    KnowledgeStore --> PMF : reconciled
    PMF --> MemMgr : syncComplete
end

== Error Handling ==
alt Memory File Not Found
    Agent -> MemMgr : retrieveContext(unknownKey)
    MemMgr -> PMF : readMemoryFile(unknownKey)
    PMF --> MemMgr : fileNotFound
    MemMgr -> PMF : createMemoryFile(unknownKey)
    PMF --> MemMgr : fileCreated
    MemMgr --> Agent : emptyContext
else Semantic Analysis Failure
    MemMgr -> SemAnalyzer : analyzeSemantics(data)
    SemAnalyzer --> MemMgr : analysisError
    MemMgr --> Agent : fallbackRawData
end

@enduml