@startuml
!include /Users/Q284340/Agentic/coding/docs/puml/_standard-style.puml

package "CLI Entry Points" {
  component "coding / coding.bat" as cli <<cli>>
  component "llm / vkb" as llmcli <<cli>>
}

package "Agent Adapters" {
  component "claude.sh" as claude <<agent>>
  component "copilot.sh" as copilot <<agent>>
  component "mastra.sh" as mastra <<agent>>
  component "opencode.sh" as opencode <<agent>>
}

package "Externalized Configuration" {
  component "llm-providers.yaml" as llmprov <<core>>
  component "agent-profiles.json" as agentprof <<core>>
  component "hooks-config.json" as hooks <<core>>
  component "teams/coding.json\nteams/agentic.json" as teams <<core>>
}

package "Runtime & Storage" {
  component "Supervisor Process Manager\n(supervisord.conf)" as supervisor <<core>>
  component "GraphKMStore\n(graph-database-config.json)" as graphkm <<storage>>
}

cli --> claude : delegates
cli --> copilot : delegates
cli --> mastra : delegates
cli --> opencode : delegates
llmcli --> llmprov : routes via

llmprov --> claude : selects
llmprov --> copilot : selects
llmprov --> mastra : selects
llmprov --> opencode : selects

agentprof --> claude : configures
agentprof --> copilot : configures
hooks --> cli : lifecycle hooks
teams --> cli : assembles workflows

supervisor --> graphkm : manages
graphkm --> agentprof : persists agent state

@enduml