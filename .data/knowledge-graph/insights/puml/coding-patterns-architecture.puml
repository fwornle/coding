  component "ServiceStarter\nstartServiceWithRetry()" as ss <<core>>
  component "Process Registry\nregisterService()" as pr <<core>>
}

package "Integration & Schema" {
  component "Structured Envelope\nCLAUDE-CODE-HOOK-FORMAT.md" as se <<api>>
