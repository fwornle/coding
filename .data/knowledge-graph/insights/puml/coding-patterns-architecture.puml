@startuml
!include /coding/docs/puml/_standard-style.puml

package "Routing & Agent Layer" {
  component "LLM Tier Router" as router <<core>>
  component "Agent Backend" as agent <<agent>>
  component "Hook System" as hooks <<core>>
}

package "MCP Integrations" {
  component "mcp-constraint-monitor" as monitor <<api>>
  component "mcp-server-semantic-analysis" as semantic <<api>>
  component "code-graph-rag" as ragTool <<api>>
}

package "Knowledge & Graph Storage" {
  database "Knowledge Graph\n(Memgraph)" as kg <<storage>>
  component "Knowledge Pipeline" as pipeline <<core>>
}

router --> agent : "selects tier\n(fast / capable)"
agent --> hooks : "emits lifecycle events"
hooks --> monitor : "constraint callbacks"
monitor --> hooks : "registers handlers"
agent --> semantic : "semantic analysis queries"
agent --> ragTool : "RAG context queries"
ragTool --> kg : "graph traversal\n(CONTAINS_*, DEFINES, DEPENDS_ON)"
pipeline --> kg : "observe → store → retrieve"
pipeline --> agent : "injects context"
ragTool --> pipeline : "operationalizes retrieval"

@enduml