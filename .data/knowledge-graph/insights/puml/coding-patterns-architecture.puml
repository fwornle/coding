@startuml
!include /coding/docs/puml/_standard-style.puml

package "Execution Layer" {
  component "Agent\n(Lazy-Init)" as agent <<agent>>
  component "Hook System" as hookSystem <<core>>
  component "LLM Tier Router" as llmRouter <<core>>
}

package "Configuration" {
  component "llm-providers.yaml" as llmConfig <<external>>
  component "hooks-config.json" as hooksConfig <<external>>
  component "health-verification-rules.json" as healthRules <<external>>
}

package "MCP Integrations" {
  component "MCP Constraint Monitor" as constraintMonitor <<api>>
  component "MCP Semantic Analysis" as semanticAnalysis <<api>>
  component "Code Graph RAG" as codeGraphRag <<core>>
}

database "Graph Database\n(Memgraph)" as graphDB <<storage>>

llmConfig --> llmRouter : tier policy\n(primary / secondary / local)
hooksConfig --> hookSystem : hook registry
healthRules --> agent : health criteria

agent --> llmRouter : routes LLM calls via
agent --> hookSystem : triggers on execution

hookSystem --> constraintMonitor : constraint callbacks
hookSystem --> semanticAnalysis : analysis triggers

codeGraphRag --> graphDB : ingests\n(CONTAINS, DEFINES,\nDEPENDS_ON)
semanticAnalysis --> graphDB : queries structure
constraintMonitor --> graphDB : reads relationships

semanticAnalysis --> codeGraphRag : shared graph traversal

@enduml