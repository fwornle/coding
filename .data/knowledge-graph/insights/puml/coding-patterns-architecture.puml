puml --> sg : "specifies guard idiom"
puml ..> ba : "documents agent lifecycle"
ba ..> sg : "lazy-init gate\non first use"
ss --> pr : "registerService()\nbinds on spawn"
ss ..> sg : "singleton process\nownership"
vkb ..> se : "dynamic import()\nemits wrapped events"
se --> cv : "validates against\nclosed vocabulary"

