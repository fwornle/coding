@startuml
!include /coding/docs/puml/_standard-style.puml

component "PlantUML Diagrams\ndocs/puml/ (~150 files)" as puml <<core>>

package "Initialization & Lifecycle" {
  component "Singleton Guard\npsm-singleton-pattern.puml" as sg <<core>>
