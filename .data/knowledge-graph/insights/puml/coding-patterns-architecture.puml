@startuml
!include /coding/docs/puml/_standard-style.puml

package "CodingPatterns" {
  component "GraphDatabaseAdapter" as gda <<storage>>
  component "WaveAgent" as wa <<agent>>
  component "ConstraintMonitor" as cm <<core>>
  component "ProviderRegistry" as pr <<core>>
  component "CodeGraphRAG" as cgr <<core>>
  component "ContentValidationAgent" as cva <<agent>>
}

package "External Dependencies" {
  database "GraphDatabase" as gd
}

gda --> gd : uses
wa --> gda : uses
cm --> gda : uses
pr --> gda : uses
cgr --> gda : uses
cva --> gda : uses
wa --> cm : processes
wa --> cgr : processes
cva --> cm : processes

@enduml