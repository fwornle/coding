@startuml
!include /Users/Q284340/Agentic/coding/docs/puml/_standard-style.puml

title Planning and Execution Workflow\nDetail View

participant "External Client" as Client
participant "MCP Server" as MCP
participant "Workflow Orchestrator" as Orchestrator
participant "Planner" as Planner
participant "Execution Engine" as Executor
participant "Semantic Analyzer" as Semantic
participant "Knowledge Store" as Knowledge
participant "Incremental Monitor" as Monitor

== Trigger: MCP Tool Invocation ==

Client -> MCP : execute_workflow(params)
activate MCP

MCP -> Orchestrator : dispatch(workflow_request)
activate Orchestrator

Orchestrator -> Planner : create_plan(context)
activate Planner

Planner -> Knowledge : query_existing_knowledge()
activate Knowledge
Knowledge --> Planner : knowledge_context
deactivate Knowledge

Planner -> Planner : build_execution_plan()
Planner --> Orchestrator : execution_plan
deactivate Planner

== Execution Phase ==

Orchestrator -> Executor : run(execution_plan)
activate Executor

loop For each plan step
    Executor -> Semantic : analyze_step(step)
    activate Semantic

    Semantic -> Knowledge : retrieve_relevant_data(step)
    activate Knowledge
    Knowledge --> Semantic : relevant_data
    deactivate Knowledge

    Semantic --> Executor : analysis_result
    deactivate Semantic

    Executor -> Executor : process_step(analysis_result)

    alt Step succeeded
        Executor -> Knowledge : update_knowledge(result)
        activate Knowledge
        Knowledge --> Executor : ack
        deactivate Knowledge
    else Step failed
        Executor -> Orchestrator : report_failure(step, error)
        Orchestrator -> Planner : replan(failed_step)
        activate Planner
        Planner --> Orchestrator : revised_plan
        deactivate Planner
    end
end

Executor --> Orchestrator : execution_complete(summary)
deactivate Executor

Orchestrator --> MCP : workflow_result
deactivate Orchestrator

MCP --> Client : response(workflow_result)
deactivate MCP

== Trigger: Automatic Incremental Analysis ==

Monitor -> Monitor : detect_change(codebase / data)
activate Monitor

Monitor -> Orchestrator : trigger_incremental_analysis(delta)
activate Orchestrator

Orchestrator -> Semantic : incremental_analyze(delta)
activate Semantic

Semantic -> Knowledge : fetch_baseline()
activate Knowledge
Knowledge --> Semantic : baseline_context
deactivate Knowledge

Semantic -> Semantic : compute_diff_analysis()

Semantic -> Knowledge : persist_incremental_updates()
activate Knowledge
Knowledge --> Semantic : ack
deactivate Knowledge

Semantic --> Orchestrator : incremental_analysis_done
deactivate Semantic

Orchestrator --> Monitor : analysis_ack
deactivate Orchestrator
deactivate Monitor

@enduml