@startuml
!include /coding/docs/puml/_standard-style.puml

package "Orchestration (scripts/)" {
  component "HealthCoordinator" as hc <<core>>
}

package "Process Registry" {
  component "ProcessStateManager" as psm <<storage>>
}

package "Probe Utilities (lib/utils/)" {
  component "ServiceProbe" as sp <<core>>
  component "HTTP Probe" as httpProbe <<api>>
  component "TCP Probe" as tcpProbe <<api>>
  component "Status Envelope" as envelope <<api>>
}

hc --> sp : "invokes probe"
hc --> psm : "resolves service identity"
hc ..> envelope : "consumes uniform result"

sp --> httpProbe : "REST / HTTP services"
sp --> tcpProbe : "raw TCP socket services"

httpProbe --> envelope : "normalizes to"
tcpProbe --> envelope : "normalizes to"

@enduml