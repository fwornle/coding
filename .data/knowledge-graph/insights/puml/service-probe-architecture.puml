@startuml
!include /Users/Q284340/Agentic/coding/docs/puml/_standard-style.puml

package "Health Coordination" {
  component "Health Coordinator" as hc <<core>>
}

package "ServiceProbe (lib/utils/service-probe.js)" {
  component "HTTP Endpoint Probe" as http <<api>>
  component "TCP Port Probe" as tcp <<api>>
  component "ServiceProbe" as sp <<core>>
}

package "Monitored Services" {
  component "Semantic Analysis MCP" as mcp <<external>>
  component "Constraint Monitor" as cm <<external>>
  component "Code Graph RAG" as cgr <<external>>
  database "Memgraph" as mg <<storage>>
  database "Redis" as redis <<storage>>
}

hc --> sp : "polls liveness"
sp --> http : "dispatches"
sp --> tcp : "dispatches (fallback)"

http --> mcp : "HTTP check"
http --> cm : "HTTP check"
http --> cgr : "HTTP check"
tcp --> mg : "TCP check"
tcp --> redis : "TCP check"

sp --> hc : "running / stopped / unknown"

@enduml