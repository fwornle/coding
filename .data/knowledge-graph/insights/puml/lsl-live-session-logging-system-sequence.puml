@startuml
!include /Users/Q284340/Agentic/coding/docs/puml/_standard-style.puml

title LSL Live Session Logging System - Config Sequence

participant "Client Application" as Client
participant "LSL Config Manager" as Config
participant "System Health Dashboard" as Dashboard
participant "Session Logger" as Logger
participant "Integration Layer" as Integration

== Initialization ==

Client -> Config : loadConfig()
activate Config
Config -> Config : parseConfigFile()
Config -> Integration : registerIntegration("system-health-dashboard")
activate Integration
Integration --> Config : integrationRegistered
deactivate Integration
Config --> Client : configLoaded
deactivate Config

== Live Session Start ==

Client -> Logger : startLiveSession(sessionId)
activate Logger
Logger -> Config : getSessionConfig(sessionId)
activate Config
Config --> Logger : sessionConfig
deactivate Config
Logger -> Integration : initializeIntegration(sessionConfig)
activate Integration
Integration -> Dashboard : connectDashboard()
activate Dashboard
Dashboard --> Integration : connectionEstablished
deactivate Dashboard
Integration --> Logger : integrationReady
deactivate Integration
Logger --> Client : sessionStarted
deactivate Logger

== Session Logging ==

loop Every Log Interval
    Client -> Logger : logEvent(eventData)
    activate Logger
    Logger -> Integration : forwardEvent(eventData)
    activate Integration
    Integration -> Dashboard : updateHealthMetrics(eventData)
    activate Dashboard
    Dashboard --> Integration : metricsUpdated
    deactivate Dashboard
    Integration --> Logger : eventForwarded
    deactivate Integration
    Logger --> Client : eventLogged
    deactivate Logger
end

== Health Check ==

alt Dashboard Unreachable
    Dashboard -> Integration : healthCheckFailed()
    activate Integration
    Integration -> Config : getRetryConfig()
    activate Config
    Config --> Integration : retryPolicy
    deactivate Config
    Integration -> Logger : pauseLogging()
    activate Logger
    Logger --> Integration : loggingPaused
    deactivate Logger
    Integration -> Dashboard : reconnect()
    activate Dashboard
    Dashboard --> Integration : reconnected
    deactivate Dashboard
    Integration -> Logger : resumeLogging()
    activate Logger
    Logger --> Integration : loggingResumed
    deactivate Logger
    deactivate Integration
else Dashboard Healthy
    Dashboard -> Integration : healthCheckPassed()
    activate Integration
    Integration -> Logger : confirmStatus("healthy")
    activate Logger
    Logger --> Integration : statusConfirmed
    deactivate Logger
    deactivate Integration
end

== Session End ==

Client -> Logger : stopLiveSession(sessionId)
activate Logger
Logger -> Integration : finalizeSession(sessionId)
activate Integration
Integration -> Dashboard : flushMetrics(sessionId)
activate Dashboard
Dashboard --> Integration : metricsFlushed
deactivate Dashboard
Integration --> Logger : sessionFinalized
deactivate Integration
Logger -> Config : clearSessionConfig(sessionId)
activate Config
Config --> Logger : configCleared
deactivate Config
Logger --> Client : sessionStopped
deactivate Logger

@enduml