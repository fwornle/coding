@startuml
!include /Users/Q284340/Agentic/coding/docs/puml/_standard-style.puml

top to bottom direction

package "System Health Dashboard" {
    component "Health Dashboard UI" as dashboardUI <<core>>
    component "Metrics Collector" as metricsCollector <<core>>
    component "Alert Manager" as alertManager <<core>>
}

package "Semantic Analysis Infrastructure" {
    component "Semantic Analyzer" as semanticAnalyzer <<core>>
    component "Knowledge Manager" as knowledgeManager <<core>>
    component "MCP Tools" as mcpTools <<api>>
}

package "Storage Layer" {
    database "Knowledge Graph" as knowledgeGraph <<storage>>
    database "Metrics Store" as metricsStore <<storage>>
}

package "External Integrations" {
    cloud "External Services" as externalServices <<external>>
    component "Agent Orchestrator" as agentOrchestrator <<agent>>
}

dashboardUI --> metricsCollector : "collects"
dashboardUI --> alertManager : "triggers"
metricsCollector --> metricsStore : "persists"
semanticAnalyzer --> knowledgeManager : "updates"
knowledgeManager --> knowledgeGraph : "stores"
mcpTools --> semanticAnalyzer : "feeds"
agentOrchestrator --> mcpTools : "invokes"
agentOrchestrator --> externalServices : "integrates"
metricsCollector --> semanticAnalyzer : "monitors"
alertManager --> agentOrchestrator : "notifies"

@enduml