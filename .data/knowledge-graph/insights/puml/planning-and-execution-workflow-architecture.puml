@startuml
!include /Users/Q284340/Agentic/coding/docs/puml/_standard-style.puml

top to bottom direction

package "Trigger Layer" {
  component "MCP Tools" as mcp <<api>>
  component "execute_workflow" as exec_tool <<cli>>
  component "Incremental Analysis" as incremental <<core>>
}

package "Workflow Core" {
  component "Planning and Execution Workflow" as workflow <<core>>
}

package "Semantic Infrastructure" {
  component "Semantic Analysis Engine" as semantic <<core>>
  component "Knowledge Management" as knowledge <<storage>>
}

mcp --> exec_tool : "exposes"
exec_tool --> workflow : "triggers"
incremental --> workflow : "auto-triggers"
workflow --> semantic : "drives"
semantic --> knowledge : "updates"
workflow --> knowledge : "reads/writes"

@enduml