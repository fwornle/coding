@startuml
!include /coding/docs/puml/_standard-style.puml

package "Specification Layer" {
  component "CLAUDE-CODE-HOOK-FORMAT" as hookFormat <<core>>
}

package "Core Patterns" {
  component "StructuredEventEnvelopePattern" as seep <<core>>
  component "ClosedVocabularyPattern" as cvp <<core>>
  component "ServiceStartupPattern" as ssp <<core>>
  component "Typed Versioned Envelopes" as tve <<core>>
}

package "MCP Integrations" {
  component "mcp-constraint-monitor" as mcm <<agent>>
  component "Pipeline Stage Outputs" as pso <<api>>
  component "mcp-server-semantic-analysis" as mssa <<api>>
}

hookFormat --> seep : "specifies format"
hookFormat --> pso : "enforces via"

seep --> tve : "produces"
seep --> cvp : "works with"
seep --> ssp : "integrates with"

mcm --> pso : "owns"
pso --> seep : "conforms to"
mssa --> seep : "references in API"

tve --> seep : "versioned by"
cvp --> tve : "constrains vocabulary"
ssp --> tve : "initializes handling"

@enduml