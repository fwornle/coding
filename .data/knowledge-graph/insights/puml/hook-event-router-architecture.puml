@startuml
!include /coding/docs/puml/_standard-style.puml

top to bottom direction

package "Claude Code Integration" {
    component "Claude Code\nHook Events" as hookEvents <<external>>
    component "Hook Format\nDocumentation" as hookFormat <<external>>
}

package "Configuration" {
    component "HookConfigurationLoader" as configLoader <<core>>
}

package "HookEventRouter (Core Dispatch)" {
    component "HookEventRouter" as router <<core>>
}

package "Violation Detection" {
    component "Pattern-Based\nViolation Detector" as patternDetector <<core>>
    component "Semantic\nViolation Detector" as semanticDetector <<core>>
}

package "Persistence & Dashboard" {
    database "Violation Storage" as violationDB <<storage>>
    component "Dashboard\nConsumer" as dashboard <<external>>
}

hookEvents --> router : "pre-tool /\npost-tool /\nstartup / shutdown"
hookFormat ..> router : "defines event\nenvelope schema"
configLoader --> router : "loaded config"
router --> patternDetector : "dispatches events"
router --> semanticDetector : "dispatches events"
patternDetector --> violationDB : "writes violations"
semanticDetector --> violationDB : "writes violations"
router --> violationDB : "persists in real time"
violationDB --> dashboard : "feeds records"

@enduml