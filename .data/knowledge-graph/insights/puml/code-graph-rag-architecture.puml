@startuml
!include /coding/docs/puml/_standard-style.puml

package "CodeGraphRAG" {
  component "Graph Database" as graphDB <<storage>>
  component "Caching Mechanism" as cache <<core>>
  component "API" as api <<api>>
  component "Versioning System" as versioning <<core>>
  component "Logging Mechanism" as logging <<core>>
}

package "Data Flow" {
  graphDB --> cache : stores
  cache --> api : provides
  api --> graphDB : queries
  versioning --> graphDB : tracks
  logging --> graphDB : logs
}

package "Update Mechanism" {
  component "Code Graph Updater" as updater <<core>>
  updater --> graphDB : updates
}

api --> updater : triggers

@enduml