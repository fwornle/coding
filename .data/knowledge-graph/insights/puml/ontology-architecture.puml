@startuml
!include /Users/Q284340/Agentic/coding/docs/puml/_standard-style.puml

top to bottom direction

package "Configuration" {
  component "OntologyConfigManager" as ocm <<core>>
}

package "Ontology Definitions" {
  component "Upper Ontology" as upper <<storage>>
  component "Lower Ontology" as lower <<storage>>
}

package "Classification Pipeline" {
  component "OntologyClassifier" as classifier <<core>>
  component "LegacyOntologyAdapter" as adapter <<external>>
  component "OntologyRegistry" as registry <<core>>
  component "OntologyValidator" as validator <<core>>
}

package "Output" {
  component "Classified Entity\n(entity Type, ontologyClass)" as entity <<api>>
}

ocm --> upper : "configures path"
ocm --> lower : "configures path"
ocm --> classifier : "thresholds"

upper --> classifier : "upper definitions"
lower --> classifier : "lower definitions"

registry --> adapter : "Phase 42-03\nmigration"
adapter --> validator : "feeds entities"
classifier --> registry : "resolves types"

validator --> entity : "attaches metadata"

@enduml