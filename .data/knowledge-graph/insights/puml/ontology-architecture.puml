@startuml
!include /coding/docs/puml/_standard-style.puml

top to bottom direction

package "Ontology Interfaces" {
  component "OntologyClassifier" as classifier <<api>>
  component "OntologyValidator" as validator <<api>>
}

package "Adapter & Core" {
  component "LegacyOntologyAdapter" as adapter <<core>>
  component "OntologyRegistry\n(km-core)" as registry <<external>>
  component "OntologyConfigManager" as configMgr <<core>>
}

package "Taxonomy Storage" {
  database "Upper Ontology\n(Module, Package, Concept)" as upperOnt
  database "Lower Ontology\n(Domain Subtypes)" as lowerOnt
}

package "Pipeline" {
  component "Insight Agents" as insightAgents <<agent>>
  component "Entity Type Resolver" as resolver <<core>>
  component "Persistence Step" as persistence <<core>>
}

classifier --> adapter : "backed by"
validator --> adapter : "backed by"
adapter --> registry : "wraps"
configMgr --> upperOnt : "manages"
configMgr --> lowerOnt : "manages"
configMgr --> registry : "triggers hot-reload"
insightAgents --> resolver : "semantic signals"
resolver --> classifier : "resolve ontologyClass"
resolver --> persistence : "entity + ontologyClass"
validator --> persistence : "schema gate"

@enduml