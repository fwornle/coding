@startuml
!include /coding/docs/puml/_standard-style.puml

' Ontology SubComponent Architecture

package "Ontology Definition Layer" {
  component "Ontology Definition Files" as ontoDefs <<core>>
  component "LegacyOntologyAdapter" as legacyAdapter <<core>>
}

package "Classification" {
  component "OntologyClassificationAgent" as classAgent <<agent>>
  component "BaseAgent" as baseAgent <<core>>
}

package "Validation & Persistence" {
  component "ContentValidationAgent" as validAgent <<agent>>
  component "PersistenceAgent" as persistAgent <<agent>>
}

' Ontology layer relationships
ontoDefs --> legacyAdapter : "loads class hierarchies"

' Classification relationships
classAgent --> baseAgent : "extends"
classAgent --> ontoDefs : "resolves entity types"
baseAgent --> classAgent : "confidence scoring\n& metadata construction"

' Validation relationships
validAgent --> ontoDefs : "uses as validation rules"
baseAgent --> validAgent : "detectIssues() surfaces\nontology mismatches"

' Persistence relationships
classAgent --> persistAgent : "ontologyClass metadata"
persistAgent --> classAgent : "mapEntityToSharedMemory()\nprevents redundant classification"

@enduml