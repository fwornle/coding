@startuml
!include /coding/docs/puml/_standard-style.puml

package "SemanticAnalysis" {
    package "Ontology" {
        component "Upper Ontology\nDefinitions" as upperOntology <<core>>
        component "Lower Ontology\nDefinitions" as lowerOntology <<core>>
        component "Entity Type\nResolution" as entity Resolution <<core>>
        component "Ontology\nValidation" as validation <<core>>
    }
}

upperOntology --> lowerOntology : "specializes"
lowerOntology --> entity Resolution : "informs"
entity Resolution --> validation : "validates against"
upperOntology --> validation : "constrains"

@enduml