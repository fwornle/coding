@startuml
!include /coding/docs/puml/_standard-style.puml

package "Ontology Definitions" {
    component "Upper Ontology" as upperOnt <<core>>
    component "Lower Ontology" as lowerOnt <<core>>
    upperOnt --> lowerOnt : "refinement"
}

package "Classification Pipeline" {
    component "OntologyClassificationBatch" as batch <<core>>
    component "OntologyClassificationAgent" as classAgent <<agent>>
    component "Entity Type Resolution" as typeRes <<core>>
}

package "Validation & Output" {
    component "Validation Rules" as valRules <<core>>
}

package "MCP Tool Integration" {
    component "Tool Extensions" as toolExt <<external>>
}

batch --> classAgent : "pre-batched entities"
classAgent --> typeRes : "resolve entity types"
upperOnt --> typeRes : "broad abstract categories"
lowerOnt --> typeRes : "concrete type refinement"
typeRes --> valRules : "classified entities"
valRules --> toolExt : "validated entity types"
toolExt ..> typeRes : "shared classification path"

@enduml