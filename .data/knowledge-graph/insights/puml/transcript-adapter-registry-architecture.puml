@startuml
!include /Users/Q284340/Agentic/coding/docs/puml/_standard-style.puml

package "Agent API Layer" {
  component "TranscriptAdapter\n(Base Class)" as base <<core>>
  component "TranscriptAdapterRegistry" as registry <<core>>
}

package "Adapter Contract Methods" {
  component "getAgentType()" as agentType <<api>>
  component "getTranscriptDirectory()" as transcriptDir <<api>>
  component "readTranscripts()" as readTranscripts <<api>>
  component "convertToLSL()" as convertLSL <<api>>
  component "getCurrentSession()" as currentSession <<api>>
}

package "Polling & Watch System" {
  component "watchTranscripts()" as watcher <<core>>
  component "Diff Engine\n(Stable ID Check)" as diff <<core>>
}

component "ClaudeCode Adapter\n('claude-code')" as claudeAdapter <<agent>>

base --> agentType : defines
base --> transcriptDir : defines
base --> readTranscripts : defines
base --> convertLSL : defines
base --> currentSession : defines

registry --> base : dispatches via\ngetAgentType()
registry --> claudeAdapter : registers

claudeAdapter --> base : implements

watcher --> readTranscripts : polls via\nsetInterval
watcher --> diff : compares results
diff --> readTranscripts : requires stable\nentry IDs

@enduml