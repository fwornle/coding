@startuml
!include /coding/docs/puml/_standard-style.puml

' ── Agent Layer ──────────────────────────────────────────────
package "Agent Layer" {
  component "BaseAgent" as baseAgent <<agent>>
  component "OntologyClassificationAgent" as classAgent <<agent>>
}

' ── OntologyEngine Service ───────────────────────────────────
package "OntologyEngine (src/ontology/)" {
  component "OntologyEngine" as engine <<core>>
  component "OntologyConfigManager" as configMgr <<core>>
  component "OntologyValidator" as validator <<core>>
  component "OntologyClassifier" as classifier <<core>>
  component "Heuristics Module\n(heuristics/index.ts)" as heuristics <<core>>
}

' ── Compatibility Layer ───────────────────────────────────────
package "Compatibility Layer" {
  component "LegacyOntologyAdapter" as legacyAdapter <<external>>
}

' ── Relationships ─────────────────────────────────────────────
classAgent --> baseAgent
classAgent --> engine : "calls into"

engine --> configMgr : "loads config"
engine --> validator : "validates schema"
engine --> classifier : "delegates classification"
engine --> legacyAdapter : "ingests legacy schemas"

classifier --> heuristics : "fallback rules"
configMgr --> validator : "feeds config"
legacyAdapter --> validator : "adapts to current schema"

@enduml