@startuml
!include /coding/docs/puml/_standard-style.puml

package "Base Adapter Layer (transcript-api.js)" {
  component "TranscriptAdapter" as base <<core>>
  component "watchTranscripts()" as watcher <<core>>
  component "Callback Set" as callbacks <<core>>
  component "lastEntryCount Cursor" as cursor <<core>>
}

package "Concrete Adapters" {
  component "Claude Code Adapter" as claudeAdapter <<agent>>
  component "Copilot CLI Adapter" as copilotAdapter <<agent>>
}

package "Output and Storage" {
  database "Transcript Directory" as transcriptDir <<storage>>
  component "LSL Schema Output" as lsl <<api>>
}

base --> watcher : "drives (1000ms interval)"
watcher --> cursor : "compares entry count"
watcher --> callbacks : "fires on new entries"
watcher --> transcriptDir : "polls via readTranscripts()"

claudeAdapter ..> base : "extends"
copilotAdapter ..> base : "extends"

claudeAdapter --> transcriptDir : "getTranscriptDirectory()"
copilotAdapter --> transcriptDir : "getTranscriptDirectory()"

claudeAdapter --> lsl : "convertToLSL()"
copilotAdapter --> lsl : "convertToLSL()"

@enduml