@startuml
!include /coding/docs/puml/_standard-style.puml

top to bottom direction

package "Application Layer" {
  component "Application Processes\n(Concurrent Writers)" as procs <<agent>>
}

package "Adapter Layer" {
  component "GraphDatabaseAdapter" as gda <<core>>
}

package "Unified Library Layer\n(lib/ukb-unified/core/)" {
  component "VkbApiClient" as vkb <<api>>
}

package "Infrastructure Layer" {
  component "HTTP API Server" as httpapi <<external>>
  database "LevelDB" as leveldb <<storage>>
}

procs --> gda : "read / write requests"

gda --> vkb : "isServerAvailable()\n[startup — determines routing mode]"
gda --> vkb : "all reads & writes\n[live mode]"
gda ..> leveldb : "direct access\n[direct mode — risk: lock collision]"

vkb --> httpapi : "HTTP requests\n[implicit write queue / serialization]"
httpapi --> leveldb : "serialized single-writer\naccess"

@enduml