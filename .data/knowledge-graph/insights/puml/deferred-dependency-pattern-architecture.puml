@startuml
!include /coding/docs/puml/_standard-style.puml

' DeferredDependencyPattern - SubComponent Architecture

package "Service Startup" {
    component "service-starter" as starter <<core>>
    component "ServiceStartupPattern" as ssp <<core>>
}

package "Deferred Loading" {
    component "DeferredDependencyPattern" as ddp <<core>>
    component "dynamic-import" as dynimport <<core>>
}

package "Dynamically Loaded Modules" {
    component "VkbApiClient" as vkbclient <<api>>
    component "ClosedVocabularyPattern" as cvp <<core>>
}

package "Documentation & Integration" {
    component "mcp-server-semantic-analysis" as mcpserver <<external>>
}

starter --> ssp : "orchestrates"
ssp --> ddp : "uses"
ddp --> dynimport : "loads via"
dynimport --> vkbclient : "deferred load"
vkbclient --> cvp : "enforces vocabulary with"
ddp --> mcpserver : "documented in"
starter ..> vkbclient : "conditionally initializes"

@enduml