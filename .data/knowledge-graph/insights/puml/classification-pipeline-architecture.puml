@startuml
!include /coding/docs/puml/_standard-style.puml

package "Entry Ingestion" {
  component "TranscriptAdapter" as transcriptAdapter <<api>>
  component "watchTranscripts Cursor" as watchCursor <<core>>
}

package "Runtime Configuration" {
  component "live-logging-config.json" as configJson <<storage>>
}

package "5-Layer Classification Pipeline" {
  component "Syntactic Layer" as layer1 <<core>>
  component "Semantic Layer" as layer2 <<core>>
  component "Intent Layer" as layer3 <<core>>
  component "Context Layer" as layer4 <<core>>
  component "Output-Type Layer" as layer5 <<core>>
}

package "Serialization & Redaction" {
  component "LSLConverter" as lslConverter <<core>>
}

transcriptAdapter --> watchCursor : polls on setInterval
watchCursor --> layer1 : new transcript entry

configJson ..> layer1 : governs thresholds & categories

layer1 --> layer2 : syntactic labels
layer2 --> layer3 : semantic labels
layer3 --> layer4 : intent labels
layer4 --> layer5 : context labels
layer5 --> lslConverter : fully labeled entry

@enduml