@startuml
!include /coding/docs/puml/_standard-style.puml

package "Consumer Layer" {
  component "Consumer Process" as consumer <<cli>>
}

package "Adapter Layer" {
  component "GraphDatabaseAdapter" as adapter <<core>>
  component "isServerAvailable() Probe" as probe <<core>>
}

package "Backend Implementations" {
  component "VkbApiClient" as vkbApi <<api>>
  component "GraphDatabaseService" as dbService <<core>>
}

package "External Process" {
  component "VKB Server Process" as vkbServer <<external>>
}

database "LevelDB Files" as leveldb <<storage>>

consumer --> adapter : "unified interface"
adapter --> probe : "once on initialize()"
probe ..> vkbApi : "routes (API mode)"
probe ..> dbService : "routes (Direct mode)"
vkbApi --> vkbServer : "HTTP calls"
vkbServer --> leveldb : "holds file lock"
dbService --> leveldb : "direct LevelDB ops"

@enduml