@startuml
!include /coding/docs/puml/_standard-style.puml

top to bottom direction

package "Adapter Layer" {
    component "GraphDatabaseAdapter" as gda <<core>>
}

package "Live Mode (HTTP)" {
    component "VkbApiClient" as vkb <<api>>
    cloud "VKB HTTP Server" as server <<external>>
}

package "Direct Mode (Local)" {
    component "GraphDatabaseService" as gds <<core>>
    database "LevelDB" as ldb <<storage>>
}

gda --> vkb : "isServerAvailable()\n[once at init]"
gda --> vkb : "delegates all ops\n[live mode]"
gda --> gds : "calls directly\n[direct mode,\nsingle-process only]"

vkb --> server : "HTTP requests"

gds --> ldb : "file handle\n(single-writer lock)"

@enduml