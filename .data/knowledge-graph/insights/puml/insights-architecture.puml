@startuml
!include /coding/docs/puml/_standard-style.puml

package "Insights Generation" {
  component "InsightGenerator" as ig <<core>>
  component "InsightValidator" as iv <<core>>
  component "Templates" as t <<storage>>
  component "Insights" as i <<storage>>
}

package "Semantic Analysis" {
  component "SemanticAnalysisAgent" as saa <<agent>>
}

package "Data Flow" {
  ig --> i : generates
  iv --> i : validates
  saa --> ig : uses
  ig --> t : uses
  i --> saa : processed by
}

@enduml