@startuml
!include /coding/docs/puml/_standard-style.puml

package "Post-Persistence Input" {
  database "Knowledge Graph" as kg <<storage>>
}

package "Insights SubComponent" {
  component "Pattern Catalog Extractor" as patternExtractor <<agent>>
  component "Pattern Catalog" as patternCatalog <<storage>>
  component "Knowledge Report Authoring" as reportAuthoring <<agent>>
}

package "BaseAgent Contract" {
  component "calculateConfidence()" as calcConfidence <<core>>
  component "generateRouting()" as genRouting <<core>>
}

package "Output" {
  component "Knowledge Report" as knowledgeReport <<core>>
  cloud "Delivery Channels" as deliveryChannels
}

kg --> patternExtractor : "consumes"
kg --> reportAuthoring : "consumes"
patternExtractor --> patternCatalog : "produces"
patternCatalog --> reportAuthoring : "input"
reportAuthoring --> knowledgeReport : "produces"
patternExtractor ..> calcConfidence : "scores"
reportAuthoring ..> calcConfidence : "scores"
reportAuthoring ..> genRouting : "routes"
genRouting --> deliveryChannels : "directs by confidence"

@enduml