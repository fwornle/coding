@startuml
!include /Users/Q284340/Agentic/coding/docs/puml/_standard-style.puml

package "Upstream Configuration" {
  component "OntologyConfigManager" as ocm <<core>>
  component "Ontology Classification" as ontClass <<core>>
}

package "Insights SubComponent" {
  component "Insights Agents" as agents <<agent>>
  component "Pattern Catalog Extractor" as patCat <<core>>
  component "Knowledge Report Authoring" as kbReport <<core>>
}

package "Observability & Output" {
  component "Token Usage Dashboard" as tokenDash <<external>>
  database "Pattern Catalog" as catalog <<storage>>
  component "Knowledge Report" as report <<storage>>
}

ocm --> agents : "LLM budget constraints"
ontClass --> agents : "ontologyClass metadata"
agents --> patCat : "batch entities"
agents --> kbReport : "batch findings"
agents --> tokenDash : "token usage tracking"
patCat --> catalog : "produces"
kbReport --> report : "authors"
catalog ..> ontClass : "informs future classification"

@enduml