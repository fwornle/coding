@startuml
!include /coding/docs/puml/_standard-style.puml

package "Input Sources" {
  component "AST Code Graph" as astGraph <<storage>>
}

package "Insight Generation" {
  component "LLM Tier Router" as llmRouter <<core>>
  component "Pattern Catalog Extractor" as patternExtractor <<core>>
  component "Insight Generation Agent" as insightAgent <<agent>>
  component "BaseAgent Response Envelope" as responseEnvelope <<api>>
}

package "Output Pipeline" {
  component "Quality Gate" as qualityGate <<core>>
  component "Knowledge Report" as knowledgeReport <<storage>>
  component "KG Operator Agent" as kgOperator <<agent>>
}

astGraph --> patternExtractor : "parses structural motifs"
patternExtractor --> insightAgent : "surfaces named patterns"
llmRouter --> insightAgent : "routes to LLM tier"
insightAgent --> responseEnvelope : "emits structured output"
responseEnvelope --> qualityGate : "carries confidence score"
qualityGate --> knowledgeReport : "accepted insights"
knowledgeReport --> kgOperator : "consumed by"

@enduml