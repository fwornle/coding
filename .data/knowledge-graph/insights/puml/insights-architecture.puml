@startuml
!include /Users/Q284340/Agentic/coding/docs/puml/_standard-style.puml

package "Upstream Pipeline" {
    component "OntologyClassificationAgent" as oca <<agent>>
}

package "Insights SubComponent" {
    component "InsightGeneratorAgent" as iga <<agent>>
    component "PatternCatalogExtractor" as pce <<core>>
    component "KnowledgeReportAuthor" as kra <<core>>
}

package "LLM Infrastructure" {
    component "LLMService" as llm <<external>>
    component "attachTokenLogger" as atl <<core>>
}

component "BaseAgent<TInput, TOutput>" as base <<core>>
component "AgentResponse" as ar <<api>>

oca --> iga : "classified & validated entities"
base --> iga : "extends"
iga --> pce : "delegates pattern extraction"
iga --> kra : "delegates report authoring"
kra --> llm : "routes LLM calls"
llm --> atl : "token tracking"
iga --> ar : "wraps output"
pce --> ar : "wraps output"

@enduml