@startuml
!include /coding/docs/puml/_standard-style.puml

package "Classification Layer" {
    component "OntologyClassificationAgent" as oca <<agent>>
    component "AgentResponse Envelope" as envelope <<core>>
}

package "Insights" {
    component "SemanticAnalysisAgent" as saa <<agent>>
    component "Pattern Catalog" as catalog <<storage>>
    component "Knowledge Report" as report <<core>>
}

package "Base Infrastructure" {
    component "BaseAgent" as base <<core>>
}

oca --> envelope : "produces\n(entity Type + ontologyClass)"
envelope --> saa : "consumes"
base ..> saa : "enforces calculateConfidence()"
saa --> catalog : "accumulates patterns"
saa --> report : "authors"
catalog ..> report : "feeds recurring patterns"

@enduml