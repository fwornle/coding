@startuml
!include /coding/docs/puml/_standard-style.puml

package "SemanticAnalysis" {
    package "Insights" {
        component "Insight Generation" as ig <<core>>
        component "Pattern Catalog Extraction" as pce <<core>>
        component "Knowledge Report Authoring" as kra <<core>>
    }
}

package "Knowledge Hierarchy" {
    component "Coding (L0)" as l0 <<external>>
    component "SemanticAnalysis (L1)" as l1 <<api>>
    component "Insights (L2)" as l2 <<core>>
}

l0 --> l1 : contains
l1 --> l2 : contains

ig --> pce : feeds
pce --> kra : informs
kra --> l2 : produces

@enduml