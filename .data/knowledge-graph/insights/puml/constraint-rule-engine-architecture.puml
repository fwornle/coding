@startuml
!include /coding/docs/puml/_standard-style.puml

package "Constraint Configuration" {
  database "Constraint Config" as cc <<storage>>
  component "File Restriction Rules" as fr <<storage>>
  component "Code Pattern Rules" as cp <<storage>>
  component "Operation Policy Rules" as op <<storage>>
}

package "Rule Engine Core" {
  component "Constraint Rule Engine" as cre <<core>>
}

package "Evaluation Strategies" {
  component "Exact / Pattern Matcher" as epm <<core>>
  component "Semantic Constraint Detector" as scd <<core>>
}

package "Semantic Infrastructure" {
  component "Embedding Model" as emb <<external>>
}

cc --> fr : "defines"
cc --> cp : "defines"
cc --> op : "defines"

fr --> cre : "loaded by"
cp --> cre : "loaded by"
op --> cre : "loaded by"

cre --> epm : "dispatches exact rules"
cre --> scd : "dispatches semantic rules"

scd --> emb : "computes embeddings"

@enduml