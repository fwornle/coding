@startuml
!include /Users/Q284340/Agentic/coding/docs/puml/_standard-style.puml

top to bottom direction

package "Session Capture Layer" {
  component "TranscriptAdapter" as adapter <<core>>
  component "SessionWindowManager" as swm <<core>>
  component "getCurrentSession()" as gcs <<api>>
}

package "Metadata & Routing" {
  component "LSLMetadata" as lslmeta <<core>>
}

package "Storage" {
  database "Window-Keyed\nDirectory Hierarchy" as dirstore <<storage>>
}

package "Downstream Consumers" {
  component "transcript-api.js" as transcriptapi <<api>>
}

adapter --> swm : "requests window label"
swm --> lslmeta : "stamps window field\n(e.g. '0800-0900')"
gcs --> swm : "assigns window\nat capture time"
gcs --> lslmeta : "populates session metadata"
lslmeta --> dirstore : "routes file by\nwindow label key"
transcriptapi --> dirstore : "retrieves transcripts\nby hour window"
transcriptapi --> gcs : "calls getCurrentSession()"

@enduml