@startuml
!include /coding/docs/puml/_standard-style.puml

package "Transcript Input" {
  component "TranscriptAdapter" as ta <<api>>
}

package "Session Context" {
  component "getCurrentSession()" as gcs <<api>>
}

package "Processing Pipeline" {
  component "LSLConfigValidator" as lcv <<core>>
  component "RedactionEngine" as re <<core>>
  component "SessionWindowManager" as swm <<core>>
}

package "Persistence" {
  database "LSL Window Files\n(hourly buckets)" as lwf <<storage>>
}

ta --> swm : "replays entries\non restart"
gcs --> swm : "provides start\ntimestamp"
lcv --> re : "validates config"
re --> swm : "redacted content"
swm --> lwf : "routes to\nhourly bucket"

@enduml