@startuml
!include /coding/docs/puml/_standard-style.puml

package "Adapter Base Class (transcript-api.js)" as base {
  component "TranscriptAdapter" as adapter <<core>>
  component "watchTranscripts()\nPolling Engine" as polling <<core>>
  component "lastEntryCount\nCursor" as cursor <<core>>
}

package "Abstract Interface\n(5 Required Methods)" as iface {
  component "getAgentType()\nconvertToLSL()\ngetCurrentSession()" as agentMethods <<api>>
  component "getTranscriptDirectory()\nreadTranscripts()" as fsMethods <<api>>
}

package "Concrete Integration" as concrete {
  component "ClaudeCodeAdapter\n(Example Subclass)" as claudeAdapter <<agent>>
}

package "Filesystem Layer" as fsLayer {
  database "Transcript Directory" as transcriptDir <<storage>>
  component "Append-Only Log Files" as logFiles <<storage>>
}

adapter --> polling : "provides"
adapter --> agentMethods : "declares abstract"
adapter --> fsMethods : "declares abstract"
polling --> cursor : "maintains"
polling --> logFiles : "reads delta entries"

claudeAdapter --> adapter : "subclasses"
claudeAdapter --> agentMethods : "implements"
claudeAdapter --> fsMethods : "implements"

fsMethods --> transcriptDir : "resolves path"
transcriptDir --> logFiles : "contains"
cursor --> logFiles : "tracks offset in"

@enduml