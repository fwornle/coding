@startuml
!include /coding/docs/puml/_standard-style.puml

package "LLM Providers" {
  component "AnthropicProvider" as ap <<api>>
  component "DMRProvider" as dmr <<api>>
  component "LLMProvider" as llmp <<core>>
}

package "Provider Registry" {
  component "ProviderRegistry" as pr <<core>>
}

ap --> llmp : extends
dmr --> llmp : extends
pr --> ap : manages
pr --> dmr : manages

llmp --> ap : defines
llmp --> dmr : defines

@enduml