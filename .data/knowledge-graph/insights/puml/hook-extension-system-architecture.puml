@startuml
!include /coding/docs/puml/_standard-style.puml

package "Configuration" {
  component "hooks-config.json" as hooksConfig <<core>>
}

package "Hook Infrastructure" {
  component "Hook Dispatcher" as hookDispatcher <<core>>
  component "Hook Payload Contract\n(CLAUDE-CODE-HOOK-FORMAT.md)" as hookPayload <<api>>
}

component "Target Agents" as agents <<agent>>

package "Out-of-Process Observers" {
  component "MCP Constraint Monitor" as constraintMonitor <<external>>
  component "Status-Line Handler" as statusLine <<external>>
}

package "In-Process Extensions" {
  component "Tool Extensions\n(mcp-server-semantic-analysis)" as toolExtensions <<core>>
}

hooksConfig --> hookDispatcher : "registers handlers\nby event type & agent"
agents --> hookDispatcher : "emits JSON payload\non tool call entry/exit"
hookPayload ..> agents : "defines emit format"
hookPayload ..> constraintMonitor : "defines receive format"
hookDispatcher --> constraintMonitor : "pre-tool / post-tool events"
hookDispatcher --> statusLine : "pre-tool / post-tool events"
agents --> toolExtensions : "augmented in-process"

@enduml