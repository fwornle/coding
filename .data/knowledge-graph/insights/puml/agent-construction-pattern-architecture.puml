@startuml
!include /coding/docs/puml/_standard-style.puml

package "Agent Lifecycle" {
  component "Agent Constructor" as constructor <<core>>
  component "ensureLLMInitialized()" as ensureLLM <<core>>
  component "execute()" as execute <<core>>
}

package "LLM Provider Layer" {
  component "llm-providers.yaml" as providerConfig <<storage>>
  cloud "LLM Provider" as llmProvider <<external>>
}

package "Extension Points" {
  component "Tool Extensions" as toolExt <<api>>
}

package "Dev & Test Modes" {
  component "Unit Test Mode" as unitTest <<cli>>
  component "Dry-Run Mode" as dryRun <<cli>>
}

constructor --> ensureLLM : "lazy init gate"
ensureLLM --> providerConfig : "reads credentials"
ensureLLM --> llmProvider : "resolves provider"
constructor --> execute : "triggers lifecycle"
execute --> toolExt : "extension point"
constructor ..> unitTest : "enables"
constructor ..> dryRun : "enables"

@enduml