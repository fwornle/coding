@startuml
!include /coding/docs/puml/_standard-style.puml

cloud "External Clients" as clients <<external>>

package "API Service Layer" {
  component "api-service.js" as wrapper <<core>>
  component "API Child Process" as childProc <<api>>
}

package "Process Coordination" {
  component "ProcessStateManager" as psm <<external>>
  database "PID / Port Records" as pidRecords <<storage>>
}

clients --> childProc : "HTTP traffic"
wrapper --> childProc : "spawns"
wrapper ..> psm : "registerService() [post-spawn, exceptions swallowed]"
wrapper ..> psm : "unregisterService() [on exit, best-effort]"
psm --> pidRecords : "manages"

@enduml