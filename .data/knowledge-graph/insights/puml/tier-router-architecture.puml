@startuml
!include /coding/docs/puml/_standard-style.puml

top to bottom direction

package "Request Inputs" {
  component "Agent Identity" as agentId <<agent>>
  component "Request Context" as reqCtx <<api>>
  component "Env / Config Flags" as envFlags <<cli>>
}

package "LLMAbstraction" {
  component "TierRouter" as tr <<core>>
  component "Mode Control" as mc <<core>>
}

package "LLM Provider Tiers" {
  component "Mock Provider" as mockProv <<external>>
  component "Local Provider" as localProv <<external>>
  cloud "Public Provider" as pubProv
}

agentId --> tr : "resolves identity"
reqCtx  --> tr : "provides context"
envFlags --> mc : "configures gates"
mc --> tr : "controls tier transitions"

tr --> mockProv : "tier 1 · test"
tr --> localProv : "tier 2 · local"
tr --> pubProv   : "tier 3 · public"

@enduml