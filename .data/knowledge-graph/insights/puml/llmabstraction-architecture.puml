@startuml
!include /coding/docs/puml/_standard-style.puml

package "Agent Layer" {
  component "wave-agent / wave-controller" as waveAgent <<agent>>
}

package "LLM Abstraction Layer" {
  component "llm-mock-service\n(getLLMMode)" as mockService <<core>>
  component "llm-with-process\n(MetricsTrackerLike)" as llmProcess <<core>>
}

package "Proxy Layer" {
  component "rapid-llm-proxy\n(port 12435)" as proxy <<api>>
}

package "Provider Layer" {
  component "dmr-provider" as dmrProvider <<core>>
  cloud "Anthropic / OpenAI / Groq" as publicAPIs
  component "Docker Model Runner (DMR)" as dmr <<external>>
}

database "workflow-progress.json" as workflowConfig <<storage>>
database "token-usage.db\n(.data/llm-proxy)" as tokenDb <<storage>>

waveAgent --> mockService : "getLLMMode()\n(mock / local / public)"
waveAgent --> llmProcess : "LLM completion calls"
mockService --> workflowConfig : "reads llmState\n& per-agent overrides"
llmProcess --> proxy : "POST /api/complete\n(+process field)"
proxy --> dmrProvider : "local mode"
proxy --> publicAPIs : "public mode"
dmrProvider --> dmr : "localhost:DMR_PORT\n/engines/v1"
proxy --> tokenDb : "per-step token\nattribution"

@enduml