@startuml
!include /Users/Q284340/Agentic/coding/docs/puml/_standard-style.puml

package "LLM Mode Control" {
  component "llm-mock-service.ts" as mockSvc <<core>>
  database "workflow-progress.json" as wpJson <<storage>>
}

package "Provider Layer" {
  component "dmr-provider.ts" as dmrProv <<core>>
  component "llm-with-process.ts" as llmProc <<core>>
  cloud "Anthropic / OpenAI" as publicCloud <<external>>
  component "Docker Model Runner" as dmr <<external>>
  component "rapid-llm-proxy" as proxy <<api>>
  component "Mock Service" as mock <<external>>
}

package "Consumers" {
  component "Wave Agents" as agents <<agent>>
  component "MetricsTracker" as metrics <<core>>
}

wpJson --> mockSvc : "globalMode\n& perAgentOverrides"
mockSvc --> llmProc : "resolves provider"
mockSvc --> dmrProv : "resolves provider"
mockSvc --> mock : "mock mode"

llmProc --> proxy : "POST /api/complete\n(with process tag)"
llmProc --> metrics : "records token usage"
dmrProv --> dmr : "OpenAI-compatible API\nhttp://DMR_HOST:DMR_PORT"
proxy --> publicCloud : "routes to cloud"

agents --> mockSvc : "getLLMMode()"
agents --> llmProc : "direct-fetch calls"
agents --> metrics : "getMetricsTracker()"

@enduml