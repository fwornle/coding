@startuml
!include /coding/docs/puml/_standard-style.puml

package "LLM Abstraction Layer" {
  component "LLMAbstraction" as llmabs <<core>>
  component "LLMMockService\n(llm-mock-service.ts)" as mockSvc <<core>>
}

package "Inference Providers" {
  component "DMR Provider\n(dmr-provider.ts)" as dmrProv <<api>>
  component "Mock Provider" as mockProv <<api>>
  component "Public Providers" as pubProv <<api>>
}

package "Persistence" {
  database "workflow-progress.json\n(.data/)" as wpJson <<storage>>
  database "dmr-config.yaml" as dmrCfg <<storage>>
}

cloud "Public Cloud APIs" as cloudGroup {
  component "Anthropic / OpenAI / Groq" as cloudApis <<external>>
}

component "Docker Model Runner\n(DMR)" as dmr <<external>>

llmabs --> mockSvc : "resolves mode\n(per-agent > global > legacy > default)"
llmabs --> dmrProv : "local mode"
llmabs --> mockProv : "mock mode"
llmabs --> pubProv : "public mode"

mockSvc --> wpJson : "reads / writes\nllmState + mockLLM flag"
dmrProv --> dmrCfg : "loadDMRConfig()\n+ expandEnvVars()"
dmrProv --> dmr : "OpenAI-compatible\nAPI (engines/v1)"
pubProv --> cloudApis : "provider API calls"

@enduml