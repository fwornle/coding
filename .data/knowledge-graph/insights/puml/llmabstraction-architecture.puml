@startuml
!include /Users/Q284340/Agentic/coding/docs/puml/_standard-style.puml

package "Execution Modes" {
  component "Mock LLM Service" as mock <<core>>
  component "DMR Provider" as dmr <<core>>
  component "LLM With Process" as lwp <<core>>
}

package "Configuration & State" {
  database "workflow-progress.json" as wpj <<storage>>
  component "dmr-config.yaml" as dmrcfg <<storage>>
}

package "External Endpoints" {
  cloud "rapid-llm-proxy\n/api/complete" as proxy <<external>>
  cloud "DMR Engine\nOpenAI-compatible API" as dmrengine <<external>>
  cloud "Public LLM Providers\n(Anthropic / OpenAI / Groq)" as publlm <<external>>
}

component "wave-controller.ts" as wc <<agent>>

wc --> mock : "mock mode"
wc --> dmr : "local mode"
wc --> lwp : "public mode\n(with process tag)"

mock --> wpj : "getLLMMode()\nsetGlobalLLMMode()"
dmr --> dmrcfg : "expandEnvVars()"
dmr --> dmrengine : "OpenAI-compat client\nhealth-check cached"

lwp --> proxy : "POST /api/complete\ninject process field"
proxy --> publlm : "routes to provider"

wpj ..> mock : "per-agent overrides\n+ legacy mockLLM flag"

@enduml