@startuml
!include /coding/docs/puml/_standard-style.puml

package "Entry Point" {
  component "UnifiedHookManager\n(lib/agent-api/hooks/hook-manager.js)" as hookManager <<api>>
}

package "Configuration Sources" {
  database "User Config\n~/.coding-tools/hooks.json" as userConfig <<storage>>
  database "Project Config\n.coding/hooks.json" as projectConfig <<storage>>
}

package "Merge Processing" {
  component "Scalar Flag Merge\nenableLogging · stopOnError · timeout" as mergeAlgo <<core>>
  component "Effective Configuration" as effectiveConfig <<core>>
}

component "constraint-configuration.md\n(integrations/mcp-constraint-monitor/docs/)" as constraintDoc <<external>>

hookManager --> userConfig : "reads global default"
hookManager --> projectConfig : "resolves via projectPath"
userConfig --> mergeAlgo : "base values"
projectConfig --> mergeAlgo : "project overrides scalars"
mergeAlgo --> effectiveConfig : "produces blended config"
constraintDoc ..> effectiveConfig : "documents configurable keys"

@enduml