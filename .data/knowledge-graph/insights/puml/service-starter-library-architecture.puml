@startuml
!include /coding/docs/puml/_standard-style.puml

package "Wrapper Scripts" {
  component "api-service.js" as apiService <<cli>>
  component "dashboard-service.js" as dashService <<cli>>
}

package "ServiceStarterLibrary" {
  component "service-starter.js" as serviceStarter <<core>>
  package "Startup Mechanisms" {
    component "Exponential Backoff" as backoff <<core>>
    component "Timeout Manager" as timeout <<core>>
    component "Service Classifier\n(required / optional)" as classifier <<core>>
  }
}

package "External Dependencies" {
  component "ServiceProbeLibrary" as probeLib <<external>>
}

apiService --> serviceStarter : "spawn & register"
dashService --> serviceStarter : "spawn & register"

serviceStarter --> backoff : "retry delay"
serviceStarter --> timeout : "per-service deadline"
serviceStarter --> classifier : "evaluates priority"
serviceStarter --> probeLib : "liveness health probe"

@enduml