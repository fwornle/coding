@startuml
!include /coding/docs/puml/_standard-style.puml

package "Knowledge Management" {
  component "Knowledge Graph" as kg <<storage>>
  component "GraphDatabaseAdapter" as gda <<core>>
  component "CheckpointManager" as cm <<core>>
  component "CodeGraphAgent" as cga <<agent>>
  component "PersistenceAgent" as pa <<agent>>
}

package "Ontology System" {
  component "OntologySystem" as os <<core>>
  database "LevelDB" as ldb
}

package "External Services" {
  cloud "VKB API" as vkb <<external>>
}

kg --> gda : uses
gda --> ldb : stores
cga --> gda : uses
pa --> gda : uses
cm --> gda : tracks
os --> kg : classifies
vkb --> gda : interacts
cga --> cm : updates
pa --> cm : updates

@enduml