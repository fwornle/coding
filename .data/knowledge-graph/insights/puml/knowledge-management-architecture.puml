@startuml
!include /coding/docs/puml/_standard-style.puml

package "MCP Semantic Analysis" {
  component "PersistenceAgent" as pa <<agent>>
  component "GraphDatabaseAdapter" as gda <<core>>
}

package "VKB Unified" {
  component "VkbApiClient" as vkbc <<api>>
  component "VKB HTTP API Server" as vkbapi <<api>>
}

package "Knowledge Management Core" {
  component "GraphDatabaseService\n(Graphology)" as gds <<storage>>
  database "LevelDB" as ldb <<storage>>
  component "GraphKnowledgeExporter" as gke <<core>>
  database ".data/knowledge-export/\n(JSON files)" as jef <<storage>>
}

pa --> gda : storeEntity()\n[enforces ontology type]
gda --> vkbc : "API mode\n(server available)"
gda --> gds : "direct mode\n(fallback, no lock)"
vkbc --> vkbapi : HTTP requests
vkbapi --> gds : routes writes
gds --> ldb : _persistGraphToLevel()\n[nodes/edges/metadata blob]
gds ..> gke : entity:stored event
gke --> jef : sync export\n(2s debounce)

@enduml