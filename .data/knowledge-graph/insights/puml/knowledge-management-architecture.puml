@startuml
!include /coding/docs/puml/_standard-style.puml

package "Core Knowledge Store" {
  component "GraphDatabaseService" as gds <<core>>
  component "Graphology Graph" as graphology <<storage>>
  database "LevelDB" as leveldb
}

package "Migration Pipeline" {
  component "Entity Type Migration" as etm <<cli>>
  component "LevelDB to km-core Migration" as kmcmig <<cli>>
}

package "Code Intelligence" {
  component "CodeGraphAgent" as cga <<agent>>
  database "Memgraph" as memgraph
}

component "UKB Trace Report" as ukb <<core>>

gds --> graphology : "manages in-memory graph"
gds --> leveldb : "batch-writes single-key JSON blob"
etm --> gds : "canonicalizes entity types\n(System / Project / Pattern)"
kmcmig --> leveldb : "reads B-shape blobs"
kmcmig --> ukb : "emits provenance traces"
cga --> memgraph : "indexes AST entities (Cypher/Bolt)"
gds ..> ukb : "knowledge lifecycle events"

@enduml