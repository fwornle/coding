@startuml
!include /Users/Q284340/Agentic/coding/docs/puml/_standard-style.puml

package "Core Knowledge Graph" {
  component "GraphDatabaseService" as gds <<core>>
  database "LevelDB" as leveldb <<storage>>
  component "GraphKMStore" as gkmstore <<storage>>
}

package "Integration & Indexing" {
  component "CodeGraphAgent" as cga <<agent>>
  cloud "Memgraph" as memgraph <<external>>
}

package "Migration & Observability" {
  component "migrate-leveldb-to-kmcore" as migrator <<cli>>
  component "UKB Trace Report" as ukbtrace <<core>>
  component "ukbSlice / Dashboard" as ukbslice <<core>>
}

gds --> leveldb : "persists graph (JSON blob)"
gds --> gkmstore : "exports per-domain JSON"
cga --> gds : "indexes via Tree-sitter AST"
cga ..> memgraph : "optional external graph"
migrator --> leveldb : "reads entities"
migrator --> gds : "migrates to km-core"
ukbtrace --> gds : "tracks pipeline data loss"
ukbslice --> ukbtrace : "monitors workflow state"

@enduml