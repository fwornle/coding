@startuml
!include /Users/Q284340/Agentic/coding/docs/puml/_standard-style.puml

package "Knowledge Stores" {
  component "GraphDatabaseService" as gds <<storage>>
  database "LevelDB" as leveldb
  component "GraphKMStore" as kmstore <<storage>>
}

package "Graph Engine" {
  component "Graphology In-Memory Graph" as graphology <<core>>
}

package "Migration & Export" {
  component "migrate-graph-db-entity-types" as migrateTypes <<cli>>
  component "migrate-leveldb-to-kmcore" as migrateLKM <<cli>>
  component "Per-Domain JSON Exports" as exports <<storage>>
}

package "Agents & Observability" {
  component "CodeGraphAgent" as cga <<agent>>
  component "UKBTraceReport" as ukb <<core>>
  database "Memgraph" as memgraph <<external>>
}

graphology --> leveldb : persists via\n_persistGraphToLevel()
gds --> graphology : manages
gds --> leveldb : stores {nodes,edges,metadata}

migrateTypes --> gds : remaps legacy\nentity types
migrateLKM --> leveldb : reads node keys\n'{team}:{entity Name}'
migrateLKM --> kmstore : writes canonical\nentities
migrateLKM --> exports : produces\n<domain>.json

cga --> memgraph : TCP connection\nhealth check
cga --> ukb : reports pipeline\ndata loss

ukb ..> migrateLKM : audits inputCount\n/ outputCount

@enduml