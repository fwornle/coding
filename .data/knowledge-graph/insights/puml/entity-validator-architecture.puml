@startuml
!include /coding/docs/puml/_standard-style.puml

package "EntityValidator" {
  component "EntityValidator" as ev <<core>>
  component "Entity Cache" as ec <<storage>>
  component "Entity Versioning" as evs <<agent>>
  component "Entity Logger" as el <<agent>>
  component "Entity Updater" as eu <<agent>>
  component "Entity Staleness Detector" as esd <<agent>>
}

package "API" {
  component "Entity API" as ea <<api>>
}

package "Dependencies" {
  component "MCP Server" as mcp <<external>>
  component "Graph Database" as gd <<storage>>
}

ev --> ec : uses
ev --> evs : uses
ev --> el : uses
ev --> eu : uses
ev --> esd : uses
ev --> ea : provides
ea --> ev : uses
ev --> mcp : integrates
ev --> gd : stores

@enduml