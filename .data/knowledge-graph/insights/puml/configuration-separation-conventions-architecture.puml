@startuml
!include /coding/docs/puml/_standard-style.puml

top to bottom direction

package "Canonical Reference" {
    component "configuration.md" as configdoc <<core>>
}

package "Configuration Layers" {
    component "agent-profiles.json" as profiles <<storage>>
    component "teams/*.json" as teams <<storage>>
    component "agents/*.sh" as scripts <<cli>>
}

package "Runtime" {
    component "Agent Process" as agent <<agent>>
}

configdoc ..> profiles : "documents schema"
configdoc ..> teams : "documents schema"
configdoc ..> scripts : "documents schema"

profiles --> agent : "behavioral config\n(model, params, capabilities)"
teams --> agent : "topology\n(team assignment)"
scripts --> agent : "launch\n(env & startup)"

@enduml