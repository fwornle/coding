@startuml
!include /coding/docs/puml/_standard-style.puml

package "External Sources" {
  component "Claude Code Hook Events" as hook <<external>>
}

package "McpConstraintMonitor Service" {
  component "McpConstraintMonitor" as monitor <<core>>
  component "SemanticConstraintDetector" as detector <<core>>
  component "Constraint Configuration" as config <<core>>
  component "Dashboard" as dashboard <<api>>
}

package "Consumer Integrations" {
  component "Status Line Integration" as statusline <<cli>>
  component "Editor / Terminal" as editor <<external>>
}

hook --> monitor : "hook events [CLAUDE-CODE-HOOK-FORMAT]"
config --> monitor : "configures"
monitor --> detector : "composes detection"
monitor --> dashboard : "constraint status"
monitor --> statusline : "real-time state updates"
statusline --> editor : "surfaces state"

@enduml