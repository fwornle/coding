@startuml
!include /coding/docs/puml/_standard-style.puml

package "MCP Server" {
  component "MCP Server\n(mcp-server-semantic-analysis)" as mcpServer <<core>>
}

package "Network Availability Guard" {
  component "isServerAvailable()" as isa <<core>>
  component "VkbApiClient" as vkb <<external>>
}

package "Storage Availability Guard" {
  component "GraphDatabaseAdapter\n(graph-database-adapter.ts)" as gda <<storage>>
  database "Graph Database" as graphDb
}

component "AdapterAndWrapperPatterns" as awp <<core>>

mcpServer --> isa : "checks availability\nbefore dynamic import"
isa ..> vkb : "dynamic import()\n[conditional — only if reachable]"
mcpServer --> gda : "initializes adapter"
gda --> graphDb : "probe-at-init\n[detects unavailability\nat construction time]"
awp ..> gda : "defines convention"

@enduml