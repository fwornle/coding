@startuml
!include /coding/docs/puml/_standard-style.puml

package "Ontology Classification" {
  component "OntologyClassificationModule" as ocm <<core>>
  component "OntologySystem" as os <<api>>
  component "GraphDatabaseModule" as gdm <<storage>>
  component "InsightGenerationModule" as igm <<core>>
}

package "Utilities" {
  component "UtilitiesModule" as um <<external>>
  database "UKB Trace Report" as utr
}

ocm --> os : uses
ocm --> gdm : stores/query
ocm --> igm : generates
ocm --> um : tracks
um --> utr : uses

@enduml