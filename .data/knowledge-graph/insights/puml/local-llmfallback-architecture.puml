@startuml
!include /coding/docs/puml/_standard-style.puml

package "Request Entry" {
  component "Workflow Request" as workflow <<core>>
  component "LLM Mode Controller" as modeCtrl <<core>>
}

package "Fallback Logic" {
  component "Local LLM Fallback" as fallback <<core>>
}

package "Proxy Layer" {
  component "@rapid/llm-proxy" as rapidProxy <<api>>
  component "LLM Proxy Bridge" as proxyBridge <<api>>
}

package "Provider Endpoints" {
  component "DMR\n(Local Inference)" as dmr <<external>>
  component "Public Providers" as pubProviders <<external>>
}

workflow --> modeCtrl : "getLLMMode()"
modeCtrl --> fallback : "mode == 'local'"
modeCtrl --> proxyBridge : "mode == 'public'"
pubProviders ..> fallback : "provider failure\n(resilience trigger)"
fallback --> rapidProxy : "bypass public dispatch"
rapidProxy --> proxyBridge : "routes via proxy"
proxyBridge --> dmr : "targets DMR endpoint"
proxyBridge --> pubProviders : "targets public endpoint"

@enduml