@startuml
!include /coding/docs/puml/_standard-style.puml

package "SemanticAnalysis" {
  component "OntologyRegistry" as registry <<core>>
  component "LegacyOntologyAdapter" as adapter <<api>>
}

package "km-core Module" {
  component "@fwornle/km-core" as kmcore <<external>>
  component "Directory Scanner" as scanner <<core>>
  component "Atomic Reload" as reload <<core>>
}

kmcore --> scanner : provides
kmcore --> reload : provides
scanner --> registry : "single-level scan"
reload --> registry : "atomic reload"
registry --> adapter : wrapped by
adapter --> registry : "backward compatibility"

@enduml