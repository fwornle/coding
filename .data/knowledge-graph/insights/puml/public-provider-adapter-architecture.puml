@startuml
!include /coding/docs/puml/_standard-style.puml

top to bottom direction

package "LLMAbstraction" {

  component "PublicProviderAdapter" as ppa <<core>>

  package "src/providers/" as provPkg {
    component "anthropic-provider.ts" as anthProv <<api>>
    component "openai-provider.ts" as oaiProv <<api>>
    component "groq-provider.ts" as groqProv <<api>>
    component "dmr-provider.ts" as dmrProv <<core>>
  }
}

cloud "Anthropic Cloud API" as anthAPI
cloud "OpenAI Cloud API" as oaiAPI
cloud "Groq Cloud API" as groqAPI
component "Internal DMR Proxy" as dmrProxy <<external>>

anthProv --> ppa : "implements"
oaiProv --> ppa : "implements"
groqProv --> ppa : "implements"

anthProv --> anthAPI : "direct auth & routing"
oaiProv --> oaiAPI : "direct auth & routing"
groqProv --> groqAPI : "direct auth & routing"

dmrProv --> dmrProxy : "proxy routing"

@enduml