@startuml
!include /coding/docs/puml/_standard-style.puml

package "Shared Resources" {
    component "_standard-style.puml" as style <<core>>
}

package "Integration Projects" {
    component "mcp-server-semantic-analysis" as mcp_sem <<core>>
    component "code-graph-rag" as cgr <<core>>
    component "mcp-constraint-monitor" as mcp_con <<core>>
}

package "Documentation Layer" {
    database "docs/puml/ Diagram Files" as puml_files <<storage>>
    component "Architecture README" as arch_readme <<api>>
    component "CONTRIBUTING.md" as contributing <<cli>>
}

mcp_sem --> puml_files : "authors .puml diagrams"
cgr --> puml_files : "authors .puml diagrams"
mcp_con --> puml_files : "authors .puml diagrams"

puml_files --> style : "!include"

arch_readme --> puml_files : "indexes"
contributing --> style : "documents convention"

@enduml