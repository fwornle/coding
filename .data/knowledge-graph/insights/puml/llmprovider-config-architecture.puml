@startuml
!include /coding/docs/puml/_standard-style.puml

package "Configuration" {
  component "llm-providers.yaml" as yamlFile <<storage>>
  component "Premium Tier Models\n(tier: premium)" as premiumTier <<core>>
  component "Standard Tier Models\n(tier: standard)" as standardTier <<core>>
}

package "LLMAbstraction Layer" {
  component "LLMProviderConfig\nLoader" as configLoader <<core>>
  component "Token Limit\nValidator" as tokenValidator <<core>>
  component "LLMAbstraction\nRouter" as llmAbstraction <<api>>
}

cloud "Provider Client" as providerClient <<external>>

yamlFile --> premiumTier : "organizes"
yamlFile --> standardTier : "organizes"
yamlFile --> configLoader : "loaded by"
configLoader --> tokenValidator : "enforces context_window\n& max_tokens"
configLoader --> llmAbstraction : "supplies tier\nrouting config"
llmAbstraction --> tokenValidator : "pre-dispatch\nvalidation"
llmAbstraction --> providerClient : "routes by tier\n(cost / capability)"
tokenValidator --> providerClient : "dispatches\nvalidated calls"

@enduml