@startuml
!include /coding/docs/puml/_standard-style.puml

package "Producers" {
  component "Hook Handlers" as hooks <<external>>
}

package "ViolationCaptureService" {
  component "ViolationCaptureService" as vcs <<core>>
  database "violation-log.jsonl" as jsonl <<storage>>
  database ".mcp-sync/violation-history.json\n(capped 1000 entries)" as capjson <<storage>>
}

package "ConstraintMonitorDashboard" {
  component "ConstraintMonitorDashboard" as dashboard <<core>>
  component "Status-Line Integration" as statusline <<api>>
}

hooks --> vcs : "writes violations"
vcs --> jsonl : "appends (unbounded)"
vcs --> capjson : "maintains capped array"
capjson --> dashboard : "reads (predictable performance)"
dashboard --> statusline : "exposes display contract"

@enduml