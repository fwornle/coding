@startuml
!include /coding/docs/puml/_standard-style.puml

package "LLMManager Components" {
  component "LLMManager" as llm <<core>>
  component "LLMService" as llms <<api>>
  component "ServiceStarter" as ss <<core>>
  component "ServiceOrchestrator" as so <<core>>
}

package "Dependency Injection" {
  component "Dependency Injector" as di <<core>>
}

llm --> llms : uses
llm --> ss : uses
llm --> so : uses
llm --> di : uses
ss --> so : manages
so --> llms : manages

@enduml