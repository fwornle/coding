@startuml
!include /Users/Q284340/Agentic/coding/docs/puml/_standard-style.puml

package "Configuration Core" {
  component "OntologyConfigManager" as ocm <<core>>
}

package "Ontology Files" {
  component "Upper Ontology Definition" as upper <<storage>>
  component "Lower Ontology Definition" as lower <<storage>>
}

package "Consumers" {
  component "OntologyClassificationAgent" as oca <<agent>>
  component "MCP Server Process" as mcp <<api>>
}

package "Test Support" {
  component "Unit Test Harness" as tests <<cli>>
}

upper --> ocm : "file path registered"
lower --> ocm : "file path registered"

ocm --> oca : "LLM budget cap\n& confidence thresholds"
ocm --> mcp : "hot-reload config\non file change"

tests --> ocm : "reset() restores defaults"

ocm ..> upper : "reloads on disk change"
ocm ..> lower : "reloads on disk change"

@enduml