@startuml
!include /Users/Q284340/Agentic/coding/docs/puml/_standard-style.puml

package "Pipeline Agents" {
    component "OntologyClassifier" as classifier <<agent>>
    component "OntologyValidator" as validator <<agent>>
    component "Insights Subsystem" as insights <<agent>>
}

package "OntologyConfigManager" {
    component "OntologyConfigManager\n<<singleton>>" as ocm <<core>>
    component "LLM Budget Parameters" as budget <<core>>
    component "Caching Parameters" as cache <<core>>
    component "Classification Thresholds" as threshold <<core>>
}

package "Ontology Resources" {
    database "Upper Ontology\nDefinition File" as upper <<storage>>
    database "Lower Ontology\nDefinition File" as lower <<storage>>
}

classifier --> ocm : "reads config"
validator --> ocm : "reads config"
insights --> budget : "consumes budget"

ocm --> budget : "exposes"
ocm --> cache : "controls"
ocm --> threshold : "stores"
ocm --> upper : "resolves path"
ocm --> lower : "resolves path"

classifier --> threshold : "applies decision boundary"
classifier --> cache : "memoizes results"
classifier --> upper : "loads definitions"
classifier --> lower : "loads definitions"
validator --> upper : "validates against"
validator --> lower : "validates against"

@enduml