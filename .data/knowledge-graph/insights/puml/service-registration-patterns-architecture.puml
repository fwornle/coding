@startuml
!include /coding/docs/puml/_standard-style.puml

top to bottom direction

package "Orchestrator" {
  component "Process Spawner" as spawner <<core>>
  component "ProcessStateManager" as psm <<core>>
}

package "Registration API" {
  component "registerService()" as regApi <<api>>
}

package "Managed Services (Child Processes)" {
  component "api-service.js" as apiService <<api>>
  component "dashboard-service.js" as dashService <<api>>
}

package "Conventions & Docs" {
  component "integration.md" as intDoc <<external>>
}

spawner --> apiService : "spawns"
spawner --> dashService : "spawns"
apiService --> regApi : "post-spawn call\n(push model)"
dashService --> regApi : "post-spawn call\n(push model)"
regApi --> psm : "announces liveness"
intDoc ..> regApi : "documents convention"

@enduml