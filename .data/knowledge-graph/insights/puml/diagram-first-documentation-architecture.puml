@startuml
!include /coding/docs/puml/_standard-style.puml

title DiagramFirstDocumentation — Diagram-First Architecture Workflow

package "Shared Style Foundation" {
  component "_standard-style.puml" as styleSheet <<core>>
}

package "Architecture Diagram Repository" {
  component "docs/puml/ Directory" as pumlDir <<storage>>
  component "llm-tier-routing.puml" as ltrDiag <<core>>
}

package "Subsystem Integrations" {
  component "mcp-server-semantic-analysis" as mcpSA <<api>>
  component "code-graph-rag" as cgrRAG <<api>>
  component "TieredLLMRouting" as tieredLLM <<core>>
}

package "Configuration & Governance" {
  component "llm-providers.yaml" as llmConfig <<storage>>
  component "CONTRIBUTING.md" as contribGuide <<core>>
}

styleSheet --> pumlDir : "imported by all diagrams"
pumlDir --> ltrDiag : "mirrors subsystem layout"
pumlDir --> mcpSA : "primary architecture artifacts"
pumlDir --> cgrRAG : "diagram update required"

ltrDiag --> tieredLLM : "documents routing logic"
tieredLLM --> llmConfig : "encoded into config"

cgrRAG --> contribGuide : "gates diagram maintenance"
contribGuide --> pumlDir : "enforces updates"

@enduml