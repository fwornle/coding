@startuml
!include /coding/docs/puml/_standard-style.puml

package "Agent Layer" {
    component "BaseAgent<TInput, TOutput>" as baseAgent <<core>>
}

package "Response Envelope" {
    component "Confidence Score" as confidence <<core>>
    component "Detected Issues" as issues <<core>>
    component "Routing Suggestions" as routing <<core>>
    component "Corrections" as corrections <<core>>
}

package "Pipeline Orchestration" {
    component "Pipeline Coordinator" as coordinator <<core>>
    component "DAG Step" as dagStep <<core>>
}

package "Downstream Targets" {
    component "Downstream Agent" as downstreamAgent <<external>>
    component "Human Review" as humanReview <<external>>
}

baseAgent --> confidence : "reports"
baseAgent --> issues : "reports"
baseAgent --> routing : "self-reports"
baseAgent --> corrections : "self-proposes"

coordinator --> confidence : "quality-gates"
coordinator --> corrections : "evaluates self-heal"
coordinator --> dagStep : "advances on threshold met"

routing --> downstreamAgent : "routes accepted output"
routing --> humanReview : "flags low-confidence entities"

@enduml