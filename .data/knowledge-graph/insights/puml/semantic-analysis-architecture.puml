@startuml
!include /coding/docs/puml/_standard-style.puml

package "Pipeline Coordination" {
  component "Pipeline Coordinator" as coordinator <<core>>
  component "BaseAgent<TInput,TOutput>" as baseAgent <<core>>
}

package "Specialized Agents" {
  component "CodeGraphAgent" as codeGraphAgent <<agent>>
  component "SemanticAnalysisAgent" as semanticAgent <<agent>>
  component "OntologyClassificationAgent" as ontologyAgent <<agent>>
  component "ContentValidationAgent" as contentAgent <<agent>>
}

package "Adapters" {
  component "LegacyOntologyAdapter" as legacyAdapter <<core>>
  component "KmCoreAdapter" as kmAdapter <<core>>
}

package "External Infrastructure" {
  database "Memgraph" as memgraph <<storage>>
  component "LLMService\n(@rapid/llm-proxy)" as llmService <<external>>
  component "OntologyRegistry\n(km-core)" as ontologyReg <<external>>
}

coordinator --> baseAgent : "template-method execute()"
coordinator --> codeGraphAgent : "invokes"
coordinator --> semanticAgent : "invokes"
coordinator --> ontologyAgent : "invokes"
coordinator --> contentAgent : "invokes"

baseAgent --> codeGraphAgent : "base contract"
baseAgent --> semanticAgent : "base contract"
baseAgent --> ontologyAgent : "base contract"
baseAgent --> contentAgent : "base contract"

codeGraphAgent --> memgraph : "TCP probe + queries"
semanticAgent --> llmService : "LLM synthesis\n(attachTokenLogger)"
ontologyAgent --> legacyAdapter : "legacy API surface"
legacyAdapter --> ontologyReg : "wraps (migration shim)"
contentAgent --> kmAdapter : "graphDB alias\n+ persistenceAgent alias"

@enduml