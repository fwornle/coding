@startuml
!include /coding/docs/puml/_standard-style.puml

package "Pipeline Orchestration" {
  component "Batch Analysis Workflow" as baw <<core>>
  component "BaseAgent<TInput, TOutput>" as base <<core>>
}

package "Specialized Agents" {
  component "SemanticAnalysisAgent" as saa <<agent>>
  component "OntologyClassificationAgent" as oca <<agent>>
  component "CodeGraphAgent" as cga <<agent>>
  component "ContentValidationAgent" as cva <<agent>>
}

package "Ontology Layer" {
  component "OntologyRegistry" as reg <<core>>
}

package "Infrastructure" {
  database "Memgraph" as memgraph <<storage>>
  component "GitStalenessDetector" as gsd <<core>>
  cloud "code-graph-rag MCP" as cgrag <<external>>
}

baw --> saa : "orchestrates"
baw --> oca : "orchestrates"
baw --> cga : "orchestrates"
baw --> cva : "orchestrates"

saa ..> base : "extends"
oca ..> base : "extends"
cga ..> base : "extends"
cva ..> base : "extends"

oca --> reg : "constructs via\nLegacyOntologyAdapter"

cga --> cgrag : "TCP socket check"
cgrag --> memgraph : "queries graph"

cva --> gsd : "staleness detection\n(60s cache)"

@enduml