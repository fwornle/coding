@startuml
!include /Users/Q284340/Agentic/coding/docs/puml/_standard-style.puml

title SemanticAnalysis MCP Server — Component Architecture

package "Ingestion Layer" {
  component "GitHistoryAgent" as gitAgent <<agent>>
  component "VibeSessionAgent" as vibeAgent <<agent>>
}

package "Analysis & Classification" {
  component "CodeGraphAgent\n(Tree-sitter + Memgraph)" as codeGraph <<agent>>
  component "SemanticAnalysisAgent\n(LLM-based)" as semAgent <<agent>>
  component "OntologyClassificationAgent" as ontoAgent <<agent>>
}

package "Validation & Persistence" {
  component "ContentValidationAgent\n(GitStalenessDetector)" as validAgent <<agent>>
  component "KmCoreAdapter" as kmCore <<core>>
}

package "Cross-Cutting Infrastructure" {
  component "BaseAgent<TInput,TOutput>" as baseAgent <<core>>
  cloud "LLMService\n(@rapid/llm-proxy)" as llmSvc <<external>>
  component "OntologyRegistry\n(@fwornle/km-core)" as ontoReg <<core>>
  component "LegacyOntologyAdapter" as legacyAdapt <<core>>
  database "Memgraph" as memgraph <<storage>>
}

gitAgent --> baseAgent : extends
vibeAgent --> baseAgent : extends
codeGraph --> baseAgent : extends
semAgent --> baseAgent : extends
ontoAgent --> baseAgent : extends
validAgent --> baseAgent : extends

gitAgent --> semAgent : git history
vibeAgent --> semAgent : vibe/LSL sessions

semAgent --> codeGraph : code graph context
semAgent --> llmSvc : LLM calls\n(token telemetry)
semAgent --> ontoAgent : classify entities

codeGraph --> memgraph : AST index

ontoAgent --> legacyAdapt : classify
legacyAdapt --> ontoReg : OntologyRegistry

ontoAgent --> validAgent : classified entities
validAgent --> kmCore : persist
validAgent --> llmSvc : validation calls

@enduml