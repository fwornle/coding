@startuml
!include /coding/docs/puml/_standard-style.puml

top to bottom direction

component "Running Server" as server <<external>>

package "Legacy Storage" {
  database "LevelDB" as leveldb <<storage>>
}

package "Migration Pipeline" {
  component "migrate-leveldb-to-kmcore.mjs" as runner <<cli>>
  component "UUIDv7 ID Assigner" as uuidv7 <<core>>
  component "Provenance Stamper" as provenance <<core>>
  component "Error Budget Policy" as errorbudget <<core>>
}

package "Target Graph" {
  database "km-core Graph" as kmcore <<storage>>
}

component "Integration Test Suite" as tests <<core>>

server ..> leveldb : "holds file lock\n(standalone runner avoids contention)"
leveldb -down-> runner : "reads legacy blobs"
runner -down-> uuidv7 : "assigns time-ordered IDs"
runner -down-> provenance : "stamps legacy origin"
runner -down-> errorbudget : "tracks failure count"
errorbudget ..> runner : "abort on threshold breach"
uuidv7 -down-> kmcore : "migrated entities"
provenance -down-> kmcore : "with audit lineage"
tests ..> uuidv7 : "tests transformation in isolation"
tests ..> provenance : "tests transformation in isolation"

@enduml