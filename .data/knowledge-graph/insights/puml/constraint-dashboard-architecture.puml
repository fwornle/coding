@startuml
!include /Users/Q284340/Agentic/coding/docs/puml/_standard-style.puml

package "Constraint System" {
  component "ViolationCaptureService" as vcs <<core>>
  component "ConstraintMonitor" as cm <<core>>
}

package ".mcp-sync (Integration Boundary)" {
  database "JSON History File" as jsonHistory <<storage>>
  database "JSONL Logs" as jsonlLogs <<storage>>
}

package "Visualization Layer" {
  component "ConstraintDashboard" as dashboard <<cli>>
}

cm --> vcs : "triggers"
vcs --> jsonHistory : "writes violation history"
vcs --> jsonlLogs : "writes log entries"
jsonHistory --> dashboard : "read-only"
jsonlLogs --> dashboard : "parses structured logs"

@enduml