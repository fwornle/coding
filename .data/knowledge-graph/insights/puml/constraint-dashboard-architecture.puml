package "Enforcement Pipeline" {
  component "Hook Pipeline" as hooks <<core>>
  component "Violation Classifier" as classifier <<core>>
}

package "MCP Sync Layer" {
  database "violation-history.json" as violationDB <<storage>>
}

package "ConstraintDashboard" {
  component "ConstraintDashboard" as dashboard <<cli>>
  component "Session Statistics" as sessionStats <<core>>
  component "Severity Breakdown" as severityView <<core>>
}

