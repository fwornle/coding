  component "constraint-monitoring-system.md" as docs <<external>>
}

hooks --> classifier : classifies
classifier --> violationDB : writes tagged violations
violationDB --> dashboard : reads history
dashboard --> sessionStats : surfaces
dashboard --> severityView : surfaces
docs ..> dashboard : documents

