@startuml
!include /coding/docs/puml/_standard-style.puml

' DiagramAsDocumentation SubComponent Architecture

package "Documentation Sources" {
    component "docs/puml/" as pumlDir <<storage>>
    component "_standard-style.puml" as styleSheet <<core>>
    component "CLAUDE-CODE-HOOK-FORMAT.md" as hookDoc <<core>>
}

package "Architectural Patterns" {
    component "DiagramAsDocumentation" as diaDoc <<core>>
    component "StructuredEventEnvelopePattern" as seep <<core>>
    component "ServiceStartupPattern" as ssp <<core>>
}

package "Integration Layer" {
    component "mcp-constraint-monitor" as mcpMonitor <<external>>
    component "Codebase References" as codeRefs <<api>>
}

styleSheet --> pumlDir : "styles"
pumlDir --> diaDoc : "provides"
diaDoc --> seep : "visualizes"
diaDoc --> ssp : "ensures consistency"
diaDoc --> hookDoc : "referenced in"
hookDoc --> mcpMonitor : "documents"
pumlDir --> codeRefs : "consumed by"
codeRefs --> mcpMonitor : "referenced across"
seep --> ssp : "coordinates with"

@enduml