@startuml
!include /Users/Q284340/Agentic/coding/docs/puml/_standard-style.puml

package "Environment Variables" {
  component "RAPID_LLM_PROXY_URL" as rapid <<external>>
  component "LLM_CLI_PROXY_URL" as cli <<external>>
  component "LLM_PROXY_URL" as generic <<external>>
  component "localhost:PORT (default)" as localport <<external>>
}

package "URL Resolution Core" {
  component "ProxyUrlResolver" as resolver <<core>>
  component "llm-with-process.ts" as lwp <<api>>
}

package "Execution Modes" {
  component "Mock Mode" as mock <<cli>>
  component "Local Mode" as local <<cli>>
  component "Public Mode" as public <<cli>>
}

cloud "rapid-llm-proxy" as proxy <<external>>

rapid --> resolver : "1st priority"
cli --> resolver : "2nd priority"
generic --> resolver : "3rd priority"
localport --> resolver : "4th fallback"

resolver --> lwp : "resolved URL"

lwp --> proxy : "direct fetch\n+ telemetry tags"

mock --> lwp : "routes via"
local --> lwp : "routes via"
public --> lwp : "routes via"

@enduml