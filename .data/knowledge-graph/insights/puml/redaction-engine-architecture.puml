@startuml
!include /coding/docs/puml/_standard-style.puml

package "LiveLoggingSystem" {
    component "LSLConverter" as lslconv <<core>>
    component "LSLConfigValidator" as lslval <<core>>
    component "RedactionEngine" as redact <<core>>
}

package "Configuration" {
    database "redaction-config.yaml" as redactcfg <<storage>>
}

redactcfg --> redact : "provides category-based\npattern rules"
lslval --> redact : "validates options"
lslconv --> redact : "applies redaction\ntransformation"

@enduml