@startuml
!include /Users/Q284340/Agentic/coding/docs/puml/_standard-style.puml

package "Configuration" {
  component "redaction-config.yaml" as config <<storage>>
}

package "Transcript Pipeline" {
  component "readTranscripts()" as reader <<api>>
  component "convertToLSL()" as converter <<core>>
  component "RedactionEngine" as engine <<core>>
  component "LSL Output Files" as lsl <<storage>>
}

package "Transcript Adapters" {
  component "ClaudeCode Adapter" as claude <<agent>>
  component "Other Agent Adapters" as others <<agent>>
}

component "transcript-api.js" as transcriptApi <<api>>

config --> engine : "loads rules"
reader --> converter : "raw transcripts"
claude --> reader
others --> reader
converter --> engine : "LSL typed format"
transcriptApi --> converter
engine --> lsl : "sanitized output"

@enduml