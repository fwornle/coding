@startuml
!include /Users/Q284340/Agentic/coding/docs/puml/_standard-style.puml

package "Environment Configuration" {
    component "RAPID_LLM_PROXY_URL" as rapid_env <<cli>>
    component "LLM_CLI_PROXY_URL" as cli_env <<cli>>
    component "LLM_PROXY_URL" as proxy_env <<cli>>
}

package "Routing Core" {
    component "ProviderRouter" as router <<core>>
    component "rapid-llm-proxy" as middleware <<api>>
}

package "Backend Providers" {
    cloud "Public Cloud Providers" as cloud_providers
    component "Docker Model Runner" as dmr <<external>>
    component "Mock Service" as mock <<external>>
}

rapid_env --> router : "priority 1"
cli_env --> router : "priority 2"
proxy_env --> router : "priority 3"

router --> middleware : "intercepts via\nRAPID_LLM_PROXY_URL"
middleware --> cloud_providers : "proxies to"
router --> dmr : "local HTTP target"
router --> mock : "test override"

@enduml