!include /Users/Q284340/Agentic/coding/docs/puml/_standard-style.puml

' System Health Dashboard and Service Architecture
' Part of semantic analysis and knowledge management infrastructure

package "Health Dashboard Core" {

  interface IHealthMonitor <<interface>> {
    +checkHealth(): HealthStatus
    +getMetrics(): MetricCollection
    +subscribe(observer: IHealthObserver): void
    +unsubscribe(observer: IHealthObserver): void
  }

  interface IHealthObserver <<interface>> {
    +onHealthChange(event: HealthEvent): void
    +onAlert(alert: HealthAlert): void
  }

  abstract class AbstractHealthService <<service>> {
    #serviceId: String
    #serviceName: String
    #status: ServiceStatus
    #lastChecked: DateTime
    #checkIntervalMs: int
    +getServiceId(): String
    +getStatus(): ServiceStatus
    +getLastChecked(): DateTime
    #performHealthCheck(): HealthStatus
    #recordMetric(key: String, value: Object): void
  }

  class HealthDashboard <<service>> {
    -services: Map<String, IHealthMonitor>
    -alertManager: AlertManager
    -metricsAggregator: MetricsAggregator
    -refreshIntervalMs: int
    +registerService(monitor: IHealthMonitor): void
    +deregisterService(serviceId: String): void
    +getOverallStatus(): SystemStatus
    +getDashboardSnapshot(): DashboardSnapshot
    +startMonitoring(): void
    +stopMonitoring(): void
  }

  class DashboardSnapshot {
    +snapshotId: String
    +timestamp: DateTime
    +overallStatus: SystemStatus
    +serviceStatuses: List<ServiceStatusEntry>
    +activeAlerts: List<HealthAlert>
    +keyMetrics: MetricCollection
  }

}

package "Service Monitors" {

  class SemanticAnalysisMonitor <<service>> {
    -analysisPipelineStatus: PipelineStatus
    -modelLoadStatus: ModelStatus
    -processingQueueDepth: int
    -averageLatencyMs: double
    +checkHealth(): HealthStatus
    +getMetrics(): MetricCollection
    +getQueueDepth(): int
    +getModelStatus(): ModelStatus
  }

  class KnowledgeGraphMonitor <<service>> {
    -graphDbConnection: ConnectionStatus
    -node Count: long
    -edgeCount: long
    -queryLatencyMs: double
    -indexHealth: IndexStatus
    +checkHealth(): HealthStatus
    +getMetrics(): MetricCollection
    +validateGraphIntegrity(): boolean
    +getGraphStats(): GraphStats
  }

  class InferenceEngineMonitor <<service>> {
    -engineStatus: EngineStatus
    -activeInferences: int
    -cacheHitRate: double
    -errorRate: double
    +checkHealth(): HealthStatus
    +getMetrics(): MetricCollection
    +getCacheStats(): CacheStats
    +getErrorRate(): double
  }

  class DataPipelineMonitor <<service>> {
    -pipelineStages: List<PipelineStage>
    -throughputPerSecond: double
    -backpressureLevel: double
    -failedRecords: long
    +checkHealth(): HealthStatus
    +getMetrics(): MetricCollection
    +getStageSummary(): List<StageHealth>
    +getBackpressureLevel(): double
  }

}

package "Alerting & Metrics" {

  class AlertManager {
    -activeAlerts: List<HealthAlert>
    -alertRules: List<AlertRule>
    -notificationChannels: List<INotificationChannel>
    +evaluateRules(metrics: MetricCollection): void
    +raiseAlert(alert: HealthAlert): void
    +resolveAlert(alertId: String): void
    +getActiveAlerts(): List<HealthAlert>
    +addRule(rule: AlertRule): void
  }

  class MetricsAggregator {
    -metricsStore: Map<String, MetricTimeSeries>
    -retentionPeriodMs: long
    +recordMetric(serviceId: String, metric: Metric): void
    +getMetrics(serviceId: String): MetricCollection
    +getAggregated(window: TimeWindow): MetricCollection
    +purgeExpiredMetrics(): void
  }

  class HealthAlert {
    +alertId: String
    +severity: AlertSeverity
    +serviceId: String
    +message: String
    +triggeredAt: DateTime
    +resolvedAt: DateTime
    +isActive: boolean
  }

  class AlertRule {
    +ruleId: String
    +ruleName: String
    +metricKey: String
    +threshold: double
    +operator: ComparisonOperator
    +severity: AlertSeverity
    +cooldownMs: long
    +evaluate(value: double): boolean
  }

  class MetricCollection {
    +serviceId: String
    +collectedAt: DateTime
    +metrics: Map<String, Object>
    +get(key: String): Object
    +put(key: String, value: Object): void
    +merge(other: MetricCollection): MetricCollection
  }

}

package "Status Model" {

  enum SystemStatus {
    HEALTHY
    DEGRADED
    CRITICAL
    UNKNOWN
    MAINTENANCE
  }

  enum ServiceStatus {
    UP
    DOWN
    STARTING
    STOPPING
    UNHEALTHY
    UNKNOWN
  }

  enum AlertSeverity {
    INFO
    WARNING
    ERROR
    CRITICAL
  }

  class HealthStatus {
    +status: ServiceStatus
    +checkedAt: DateTime
    +message: String
    +details: Map<String, Object>
    +isHealthy(): boolean
  }

  class ServiceStatusEntry {
    +serviceId: String
    +serviceName: String
    +status: ServiceStatus
    +lastChecked: DateTime
    +alertCount: int
  }

}

' Inheritance
AbstractHealthService ..|> IHealthMonitor
SemanticAnalysisMonitor --|> AbstractHealthService
KnowledgeGraphMonitor --|> AbstractHealthService
InferenceEngineMonitor --|> AbstractHealthService
DataPipelineMonitor --|> AbstractHealthService

' Dashboard compositions
HealthDashboard --> AlertManager : manages
HealthDashboard --> MetricsAggregator : uses
HealthDashboard --> IHealthMonitor : monitors
HealthDashboard ..> DashboardSnapshot : produces

' Observer pattern
HealthDashboard ..|> IHealthObserver
AlertManager ..|> IHealthObserver

' Alert relationships
AlertManager --> AlertRule : evaluates
AlertManager --> HealthAlert : raises
AlertManager ..> MetricCollection : reads

' Metric relationships
MetricsAggregator --> MetricCollection : aggregates

' Status model usage
AbstractHealthService --> HealthStatus : returns
AbstractHealthService --> ServiceStatus : tracks
DashboardSnapshot --> SystemStatus : reflects
DashboardSnapshot --> ServiceStatusEntry : contains
DashboardSnapshot --> HealthAlert : includes
HealthAlert --> AlertSeverity : has
AlertRule --> AlertSeverity : defines

@enduml