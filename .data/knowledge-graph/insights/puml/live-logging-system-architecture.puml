@startuml
!include /coding/docs/puml/_standard-style.puml

package "Agent Adapter Layer" {
  component "TranscriptAdapter" as adapter <<api>>
  component "Claude Code Adapter" as claude <<agent>>
  component "Copilot CLI Adapter" as copilot <<agent>>
}

package "LSL Core" {
  component "LSLConverter" as converter <<core>>
  component "LSLMetadata" as metadata <<core>>
}

package "Configuration & Validation" {
  component "LSLConfigValidator" as validator <<cli>>
  database "lsl-config.json" as lslconfig <<storage>>
  database "redaction-config.yaml" as redactconfig <<storage>>
}

package "Output Storage" {
  database "JSONL Log Files" as jsonllogs <<storage>>
  database "Markdown Logs" as mdlogs <<storage>>
}

claude --> adapter : "extends"
copilot --> adapter : "extends"
adapter --> converter : "converts transcripts"
converter --> metadata : "annotates with userHash+timeWindow"
metadata --> jsonllogs : "routes per-user file paths"
converter --> redactconfig : "reads redaction patterns"
converter --> jsonllogs : "toJSONL()"
converter --> mdlogs : "toMarkdown()"
validator --> lslconfig : "validates schema"
validator --> redactconfig : "validates patterns"
validator --> converter : "configures maxContentLength"
validator --> metadata : "enforces userHashLength 6-12"

@enduml