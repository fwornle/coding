@startuml
!include /Users/Q284340/Agentic/coding/docs/puml/_standard-style.puml

package "Agent Adapters" {
  component "TranscriptAdapter" as adapter <<api>>
  component "ClaudeCodeAdapter" as claude <<agent>>
}

package "LSL Core" {
  component "LSLConverter" as converter <<core>>
  component "LSLConfigValidator" as validator <<core>>
  component "watchTranscripts()" as watcher <<core>>
}

package "Semantic Analysis" {
  component "OntologyClassificationAgent" as ontology <<agent>>
  component "AsyncLoggingSubsystem" as asynclog <<core>>
}

package "Storage" {
  database "LSL Log Files\n(by userHash/project/timeWindow)" as logfiles <<storage>>
  database "Semantic Analysis Logs\n(CODING_REPO/.data/logs)" as semlogs <<storage>>
}

component "LSLConfigValidator\n(lsl-config.json\nredaction-config.yaml)" as config <<external>>

claude --> adapter : implements
adapter --> watcher : readTranscripts()
watcher --> converter : raw entries
converter --> logfiles : toMarkdown()\ntoJSONL()
validator --> converter : validates config\n& redaction rules
config --> validator : reads

converter --> ontology : LSL typed entries
ontology --> asynclog : classification results
asynclog --> semlogs : buffered writes\n(50 entries / 100ms)

@enduml