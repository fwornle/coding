@startuml
!include /coding/docs/puml/_standard-style.puml

package "Adapter Layer" {
  component "TranscriptAdapter\n[Abstract Base Class]" as ta <<core>>
  component "AgentImpl\n(Claude Code / other agents)" as ai <<agent>>
  component "LSLConverter" as lslc <<core>>
}

package "Configuration & Validation" {
  component "LSLConfigValidator" as lcv <<cli>>
  database "lsl-config.json" as lslcfg <<storage>>
  database "redaction-config.yaml" as redcfg <<storage>>
}

package "Runtime Backend" {
  component "AsyncLogBuffer\n(100ms / 50-entry flush)" as alb <<core>>
  component "FileManager\n(Routing & Rotation)" as fm <<storage>>
}

package "5-Layer Classification" {
  component "Ontology\nClassification Pipeline" as clp <<api>>
}

ai --> ta : extends contract\n(5-method interface)
ta --> lslc : delegates\nformat conversion
lslc --> redcfg : applies\nredaction rules
lcv --> lslcfg : validates schema\n(size & batch bounds)
lcv --> redcfg : validates schema\n(enabled & categories)
lslcfg --> ta : configures session\nwindowing & multiUser
ta --> fm : routes LSL output\n(timeWindow / userHash)
ta --> clp : classifies\nlog entries
alb --> fm : buffered\nappendFile write

@enduml