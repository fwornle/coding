@startuml
!include /Users/Q284340/Agentic/coding/docs/puml/_standard-style.puml

left to right direction

package "Ingestion Layer" {
  component "TranscriptAdapter" as ta <<api>>
  component "LSLConverter" as conv <<core>>
}

package "Configuration & Validation" {
  component "LSLConfigValidator" as val <<cli>>
  component "lsl-config.json" as cfg <<storage>>
  component "redaction-config.yaml" as red <<storage>>
}

package "Semantic Analysis Backend" {
  component "SemanticLoggingBackend" as slb <<core>>
  component "OntologyClassificationAgent" as oca <<agent>>
}

database "LSL Session Files" as lsl <<storage>>

ta --> conv : "convertToLSL()"
conv --> lsl : "toMarkdown() / toJSONL()"
val --> cfg : "validates"
val --> red : "validates"
red ..> conv : "PII redaction gates"
conv --> slb : "normalized LSL records"
slb --> oca : "raw observations"
oca --> lsl : "persists OntologyMetadata"

@enduml