@startuml
!include /coding/docs/puml/_standard-style.puml

package "Config & Validation" {
  component "LSLConfigValidator" as validator <<cli>>
  database "lsl-config.json" as lslcfg <<storage>>
  database "redaction-config.yaml" as redactcfg <<storage>>
}

package "Agent Integration Layer" {
  component "TranscriptAdapter" as ta <<api>>
  component "ClaudeCode Adapter" as cca <<agent>>
  component "CopilotCLI Adapter" as copa <<agent>>
}

package "Core LSL Pipeline" {
  component "watchTranscripts\n(Poll Engine)" as wt <<core>>
  component "LSLConverter" as conv <<core>>
  component "LSLSession" as sess <<core>>
}

database "JSONL Session Files" as jsonlfiles <<storage>>

validator --> lslcfg : "validates schema"
validator --> redactcfg : "validates schema"
validator ..> sess : "injects userHash\n(SHA-256 prefix)"

cca --> ta : "implements contract"
copa --> ta : "implements contract"
wt --> ta : "polls readTranscripts()\ngetCurrentSession()"
wt --> conv : "dispatches entry delta\n(1000ms interval)"
conv --> sess : "serializes / deserializes"
sess --> jsonlfiles : "toJSONL()\nmetadata-first layout"

@enduml