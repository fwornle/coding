@startuml
!include /Users/Q284340/Agentic/coding/docs/puml/_standard-style.puml

package "Orchestration Layer" {
  component "ServiceStarter" as ss <<core>>
  component "Retry + Backoff Engine" as retry <<core>>
}

package "Health Verification" {
  component "ServiceProbe" as probe <<api>>
}

package "Services" {
  component "Memgraph" as memgraph <<external>>
  component "Redis" as redis <<external>>
}

package "Infrastructure" {
  component "Docker Compose" as docker <<external>>
}

ss --> retry : "manages"
ss --> probe : "gates startup via"
probe --> memgraph : "probes"
probe --> redis : "probes"
docker --> memgraph : "starts container"
docker --> redis : "starts container"
ss --> docker : "post-start convergence"
ss --> memgraph : "startup lifecycle"
ss --> redis : "startup lifecycle"

@enduml