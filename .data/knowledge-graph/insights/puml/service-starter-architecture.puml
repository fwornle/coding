@startuml
!include /coding/docs/puml/_standard-style.puml

cloud "OS Signals (SIGTERM/SIGINT)" as signals <<external>>

package "Service Starter" {
  component "service-starter.js" as starter <<core>>
  component "Retry Policy" as retry <<core>>
}

package "Wrapper Scripts" {
  component "api-service.js" as apiSvc <<api>>
  component "dashboard-service.js" as dashSvc <<api>>
}

package "Process Management" {
  component "PSM" as psm <<storage>>
}

signals --> apiSvc : "handled by"
signals --> dashSvc : "handled by"

starter --> retry : "centralizes"
starter --> apiSvc : "triggers spawn"
starter --> dashSvc : "triggers spawn"

apiSvc --> psm : "registers new PID"
dashSvc --> psm : "registers new PID"

@enduml