@startuml
!include /coding/docs/puml/_standard-style.puml

package "SpecstoryAdapter" {
  component "SpecstoryAdapter" as sa <<core>>
  component "Logging Module" as lm <<api>>
  component "Cache" as cache <<storage>>
  component "EnvironmentConfigurator" as ec <<api>>
  component "GraphDatabaseManager" as gdm <<storage>>
  component "WorkStealer" as ws <<agent>>
  component "Trajectory" as t <<external>>
}

sa --> lm : uses
lm --> cache : stores
cache --> gdm : retrieves
sa --> ec : configures
ec --> cache : caches
ws --> sa : synchronizes
sa --> t : notifies

@enduml