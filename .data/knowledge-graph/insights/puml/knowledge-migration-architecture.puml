@startuml
!include /coding/docs/puml/_standard-style.puml

top to bottom direction

package "KnowledgeMigration Scripts" {
  component "Entity Type Migration\n(migrate-graph-db-entity-types.js)" as etMigrate <<cli>>
  component "Storage Backend Migration\n(migrate-leveldb-to-kmcore.mjs)" as storageMigrate <<cli>>
}

package "Storage Layer" {
  database "LevelDB\n(Raw Backend)" as leveldb <<storage>>
  database "km-core\n(Canonical Shape)" as kmcore <<storage>>
}

package "Runtime Path (Bypassed)" {
  component "GraphDatabaseAdapter\n(probe-once, lock-free)" as gdbAdapter <<core>>
}

component "Entity Taxonomy\n(System / Project / Pattern)" as taxonomy <<core>>

etMigrate --> leveldb : "direct file access\n(bypasses adapter)"
etMigrate --> taxonomy : "consolidates types to"
etMigrate ..> storageMigrate : "sequencing dependency\n(schema version ordering)"

storageMigrate --> leveldb : "reads directly\n(dry-run + idempotent)"
storageMigrate --> kmcore : "migrates to\ncanonical shape"

gdbAdapter ..> leveldb : "normal routing\n(lock conflict during migration)"
gdbAdapter ..> kmcore : "post-migration\ntarget backend"

@enduml