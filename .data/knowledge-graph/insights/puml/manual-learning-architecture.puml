@startuml
!include /coding/docs/puml/_standard-style.puml

' ManualLearning SubComponent Architecture

package "Manual Input" {
  component "Human-Authored Entities" as humanInput <<external>>
}

package "Graph Service Layer" {
  component "GraphDatabaseService.js" as gds <<core>>
  component "Graphology In-Memory Graph" as graphology <<core>>
  component "isDirty Deferred-Write Flag" as dirtyFlag <<core>>
  component "_persistGraphToLevel()" as flushFn <<api>>
}

package "Canonical Schema" {
  component "KmCoreStore Format\n(UUIDv7 + Ontology)" as kmCore <<core>>
}

package "Persistence Layer" {
  database "LevelDB" as leveldb <<storage>>
  component "Single 'graph' Blob Key" as graphBlob <<storage>>
}

humanInput --> gds : "write entities"
gds --> graphology : "mutates in-memory graph"
gds --> dirtyFlag : "sets isDirty=true"
dirtyFlag ..> flushFn : "explicit flush required\n(no auto-trigger)"
flushFn --> leveldb : "full deserialize/mutate/reserialize"
leveldb --> graphBlob : "stores under key 'graph'\n(no manual/automated partition)"
humanInput ..> kmCore : "must conform to"
gds ..> kmCore : "no schema gate enforced"

@enduml