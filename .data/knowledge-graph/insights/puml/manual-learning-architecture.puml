@startuml
!include /Users/Q284340/Agentic/coding/docs/puml/_standard-style.puml

package "Manual Input Channel" {
    component "ManualLearning" as ml <<core>>
    component "Provenance Metadata" as prov <<core>>
}

package "Graph Layer" {
    component "Graphology In-Memory Graph" as graphology <<storage>>
    component "GraphDatabaseService" as gds <<api>>
    database "Knowledge Graph" as kg <<storage>>
}

package "Lifecycle Management" {
    component "KnowledgeDecayTracker" as kdt <<core>>
}

ml --> prov : "stamps at creation"
ml --> graphology : "direct write\n(bypasses batch pipeline)"
ml --> gds : "persists via"
graphology --> kg : "syncs to"
gds --> kg : "stores entities\n(System/Project/Pattern)"
kdt --> kg : "applies validFrom/\nvalidUntil lifecycle"
prov --> kdt : "supplies timestamps"

@enduml