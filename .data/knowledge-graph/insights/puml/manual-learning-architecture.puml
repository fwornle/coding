@startuml
!include /coding/docs/puml/_standard-style.puml

package "Human-Curated Write Path" {
  component "ManualLearning" as ml <<core>>
  component "GraphDatabaseAdapter" as gda <<api>>
}

package "Storage Layer" {
  cloud "VKB HTTP API" as vkb <<api>>
  database "LevelDB" as ldb <<storage>>
}

package "Event & Export Pipeline" {
  component "entity:stored Event" as evt <<core>>
  component "GraphKnowledgeExporter" as gke <<core>>
  database "Domain JSON Exports" as djson <<storage>>
}

package "Automated Pipeline" {
  component "OnlineLearning" as ol <<agent>>
  component "CheckpointManager" as cm <<core>>
}

ml --> gda : "writes (highest trust)"
gda --> vkb : "live mode routing"
gda ..> ldb : "direct mode (lock collision risk)"
vkb --> ldb : "persists to"

ml --> evt : "triggers entity:stored"
evt --> gke : "notifies (per domain)"
gke --> djson : "regenerates (debounced)"

ol --> cm : "commit-hash incremental tracking"
ol --> gda : "batch writes"
ml ..> ol : "bypasses batch pipeline"

@enduml