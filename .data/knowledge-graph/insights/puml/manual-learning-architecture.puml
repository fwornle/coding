@startuml
!include /Users/Q284340/Agentic/coding/docs/puml/_standard-style.puml

package "Manual Authoring Layer" {
    component "ManualLearning" as ml <<core>>
    component "Direct Observation API" as api <<api>>
}

package "Schema & Identity" {
    component "EntityTypeRegistry" as etr <<core>>
    component "UUIDv7 ID Generator" as uuid <<core>>
    component "Provenance Metadata" as prov <<core>>
}

package "Persistence Layer" {
    component "GraphKMStore" as gkms <<storage>>
    database "LevelDB" as ldb <<storage>>
}

component "Agent" as agent <<agent>>
component "KMCoreMigration" as kmcm <<external>>

agent --> api : "injects observations"
api --> ml : "asserts facts"
ml --> etr : "validates typed attributes"
ml --> uuid : "generates IDs"
ml --> prov : "stamps human-authored origin"
prov ..> kmcm : "contrasts with automated provenance"
ml --> gkms : "persists entities & edges"
gkms --> ldb : "writes to backend"

@enduml