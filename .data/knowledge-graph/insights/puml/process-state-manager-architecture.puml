@startuml
!include /coding/docs/puml/_standard-style.puml

package "DockerizedServices" {

    package "ProcessStateManager" {
        component "process-state-manager.js" as psm <<core>>
        component "In-Memory PID Registry" as registry <<storage>>
    }

    package "Wrapper Scripts" {
        component "Wrapper Script A" as wrapperA <<cli>>
        component "Wrapper Script B" as wrapperB <<cli>>
        component "Wrapper Script C" as wrapperC <<cli>>
    }

    package "Child Processes" {
        component "Child Process" as childProc <<external>>
    }

}

psm --> registry : "maintains"

wrapperA --> psm : "registerService / unregisterService"
wrapperB --> psm : "registerService / unregisterService"
wrapperC --> psm : "registerService / unregisterService"

wrapperA --> childProc : "spawns"
wrapperB --> childProc : "spawns"
wrapperC --> childProc : "spawns"

childProc --> psm : "PID mapped to\n{port, type, script}"

@enduml