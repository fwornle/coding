@startuml
!include /Users/Q284340/Agentic/coding/docs/puml/_standard-style.puml

left to right direction

package "Hook Layer" {
    component "Pre-Tool Hook" as preHook <<external>>
    component "Post-Tool Hook" as postHook <<external>>
}

package "Capture Layer" {
    component "ViolationCaptureService" as vcs <<core>>
}

package "Output Layer" {
    database "violations.jsonl\n(Streaming Log)" as jsonl <<storage>>
    database "violations-history.json\n(Dashboard Snapshot)" as jsonHistory <<storage>>
}

package "Consumer Layer" {
    component "ConstraintDashboard" as dashboard <<cli>>
    component ".mcp-sync Directory" as mcpSync <<storage>>
}

preHook --> vcs : "evaluated violations"
postHook --> vcs : "evaluated violations"
vcs --> jsonl : "append write"
vcs --> jsonHistory : "snapshot write"
jsonl --> mcpSync : "persisted to"
jsonHistory --> mcpSync : "persisted to"
mcpSync --> dashboard : "filesystem handoff"

@enduml