@startuml
!include /Users/Q284340/Agentic/coding/docs/puml/_standard-style.puml

title System Health Dashboard — Service Interaction Sequence

actor User as user
participant "Health Dashboard\n:3032" as dashboard
participant "Health API\n:3033" as healthapi
participant "Semantic Analysis\nSSE :3848" as ssa
participant "Constraint Monitor\n(Docker)" as constraint
participant "Coding Services\n(Docker)" as docker
database "LevelDB\nKnowledge Graph" as leveldb
participant "VKB Viewer\n:8080" as vkb

== Dashboard Load ==
user -> dashboard : Open browser
dashboard -> healthapi : GET /api/health
healthapi -> docker : Check container status
docker --> healthapi : services status map
healthapi --> dashboard : JSON health payload
dashboard --> user : Render service tiles

== UKB Workflow Execution ==
user -> dashboard : Trigger wave-analysis
dashboard -> ssa : POST /workflow/wave-analysis\n{team: "coding"}
activate ssa
ssa -> docker : Spawn workflow runner
ssa --> dashboard : 202 Accepted {workflow_id}

loop Progress polling
    dashboard -> ssa : GET /progress
    ssa --> dashboard : {status, currentStep, subSteps}
    dashboard --> user : Update progress tiles
end

ssa -> leveldb : Persist entities / relations
ssa --> dashboard : {status: "completed"}
deactivate ssa

== Constraint Check Flow ==
user -> dashboard : Edit / write file
dashboard -> constraint : POST /check {content, type}
constraint -> constraint : Evaluate rules
alt Violation found
    constraint --> dashboard : {severity: "error", message}
    dashboard --> user : Red badge + violation detail
else All clear
    constraint --> dashboard : {violations: []}
    dashboard --> user : Green badge
end

== Knowledge Graph Inspection ==
user -> vkb : Open VKB at :8080
vkb -> leveldb : Query nodes + edges
leveldb --> vkb : Graphology graph payload
vkb --> user : Sigma.js interactive graph

== Health Heartbeat (background) ==
loop Every 30 s
    docker -> healthapi : POST /lsl_heartbeat {sid, project}
    healthapi -> healthapi : Update state.lsl[sid:project]
    healthapi --> docker : 200 OK
end

@enduml