@startuml
!include /coding/docs/puml/_standard-style.puml

package "Initialization" {
  component "LLMInitialization" as llim <<core>>
}

package "Agents" {
  component "LLMAgents" as llma <<agent>>
}

package "System" {
  component "SystemResources" as sr <<external>>
  component "MemoryManager" as mm <<core>>
}

llim --> llma : initializes
llim --> mm : optimizes
mm --> sr : manages
llma --> sr : uses

@enduml