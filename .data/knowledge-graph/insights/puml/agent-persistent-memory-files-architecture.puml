@startuml
!include /Users/Q284340/Agentic/coding/docs/puml/_standard-style.puml

top to bottom direction

package "Agent Layer" {
    component "AI Agent" as agent <<agent>>
}

package "Persistent Memory Infrastructure" {
    component "Memory Manager" as memMgr <<core>>
    component "Semantic Analyzer" as semAnalyzer <<core>>
    component "Knowledge Manager" as knowMgr <<core>>
}

package "Storage Layer" {
    database "Persistent Memory Files" as memFiles <<storage>>
    database "Knowledge Base" as knowBase <<storage>>
}

agent --> memMgr : "reads/writes"
memMgr --> semAnalyzer : "processes"
semAnalyzer --> knowMgr : "enriches"
memMgr --> memFiles : "persists"
knowMgr --> knowBase : "stores"
knowBase --> memMgr : "retrieves"

@enduml