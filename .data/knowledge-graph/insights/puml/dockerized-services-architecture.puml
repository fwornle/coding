@startuml
!include /coding/docs/puml/_standard-style.puml

top to bottom direction

package "Service Orchestration" {
  component "service-starter.js" as serviceStarter <<core>>
  component "ProcessStateManager" as psm <<core>>
  component "api-service.js" as apiWrapper <<cli>>
  component "dashboard-service.js" as dashWrapper <<cli>>
}

package "Microservices" {
  component "MCP Semantic Analysis" as mcpServer <<api>>
  component "Constraint Monitor API :3031" as constraintAPI <<api>>
  component "Constraint Monitor Dashboard :3030" as constraintDash <<api>>
  component "llm-mock-service" as llmMock <<core>>
}

package "Data Stores" {
  database "Memgraph" as memgraph <<storage>>
  database "Redis" as redis <<storage>>
}

' Startup orchestration with retry-with-backoff
serviceStarter --> apiWrapper : "starts (required)"
serviceStarter --> dashWrapper : "starts (optional)"
serviceStarter --> mcpServer : "starts (required)"

' Process identity management
apiWrapper --> psm : "register PID / unregister on exit"
dashWrapper --> psm : "register PID / unregister on exit"

' Child process spawning
apiWrapper --> constraintAPI : "spawns child process"
dashWrapper --> constraintDash : "spawns w/ NEXT_PUBLIC_API_BASE_URL"

' Fixed coupling between dashboard and API backend
constraintDash --> constraintAPI : "hardcoded :3031"

' MCP Semantic Analysis dependencies
mcpServer --> llmMock : "LLM mode (mock/local/public)"
mcpServer --> memgraph : "Bolt protocol"
mcpServer --> redis : "cache"
constraintAPI --> memgraph : "queries"

@enduml