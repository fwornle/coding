@startuml
!include /Users/Q284340/Agentic/coding/docs/puml/_standard-style.puml

package "Docker Compose Environment" {
  component "docker-compose.yml" as compose <<core>>
  component "Dockerfile.coding-services" as dockerfile <<core>>
  component "supervisord.conf" as supervisord <<core>>
  component "entrypoint.sh" as entrypoint <<cli>>
}

package "Co-located Services (single container)" {
  component "Semantic Analysis MCP" as mcp <<api>>
  component "Constraint Monitor API\n:3031" as constraintApi <<api>>
  component "Next.js Dashboard\n:3030" as dashboard <<api>>
  component "code-graph-rag" as rag <<core>>
}

package "Infrastructure" {
  database "Memgraph\n(Bolt TCP)" as memgraph <<storage>>
  database "Redis\n(TCP cache)" as redis <<storage>>
}

package "Service Lifecycle" {
  component "service-starter.js\n(retry + backoff)" as starter <<core>>
  component "service-probe.js\n(HTTP / TCP probes)" as probe <<core>>
  component "ProcessStateManager" as psm <<core>>
}

compose --> dockerfile : builds
compose --> memgraph : orchestrates
compose --> redis : orchestrates
dockerfile --> entrypoint : runs
entrypoint --> supervisord : delegates supervision

supervisord --> mcp : manages
supervisord --> constraintApi : manages
supervisord --> dashboard : manages
supervisord --> rag : manages

starter --> probe : uses
starter --> memgraph : waits for (TCP)
starter --> redis : waits for (TCP)
probe --> memgraph : probeTcpPort()
probe --> redis : probeTcpPort()
probe --> mcp : probeHttpHealth()

constraintApi --> psm : registers
dashboard --> psm : registers
dashboard ..> constraintApi : "http://localhost:3031"

mcp --> memgraph : graph queries
rag --> memgraph : graph queries
mcp --> redis : caching

@enduml