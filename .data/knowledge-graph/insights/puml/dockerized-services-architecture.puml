@startuml
!include /Users/Q284340/Agentic/coding/docs/puml/_standard-style.puml

package "Docker Compose Deployment" {
  component "docker-compose.yml" as compose <<core>>
  component "Dockerfile.coding-services" as dockerfile <<core>>
  component "supervisord.conf" as supervisord <<core>>
}

package "Containerized Services" {
  component "Semantic Analysis MCP" as mcp <<api>>
  component "Constraint Monitor API\n(port 3031)" as constraint <<api>>
  component "Next.js Dashboard\n(port 3030)" as dashboard <<api>>
  component "code-graph-rag" as rag <<core>>
  database "Memgraph" as memgraph <<storage>>
  database "Redis" as redis <<storage>>
}

package "Process Management" {
  component "ProcessStateManager" as psm <<core>>
  component "service-starter.js\n(retry + backoff)" as starter <<core>>
  component "service-probe.js\n(running/stopped/unknown)" as probe <<core>>
}

package "LLM Mode Control" {
  component "llm-mock-service.ts" as llmmock <<core>>
  component "workflow-progress.json" as wpjson <<storage>>
}

compose --> dockerfile : builds
dockerfile --> supervisord : managed by
supervisord --> mcp : spawns
supervisord --> constraint : spawns
supervisord --> dashboard : spawns
supervisord --> rag : spawns

constraint --> psm : registers
dashboard --> psm : registers
psm --> starter : delegates lifecycle
starter --> probe : health check
probe ..> constraint : TCP/HTTP check
probe ..> mcp : TCP/HTTP check

mcp --> memgraph : queries
rag --> memgraph : queries
mcp --> redis : caches

llmmock --> wpjson : reads/writes llmState
llmmock ..> mcp : path translation via CODING_ROOT

@enduml