@startuml
!include /coding/docs/puml/_standard-style.puml

package "Script Wrappers" {
  component "api-service.js" as apiScript <<cli>>
  component "dashboard-service.js" as dashScript <<cli>>
}

package "Service Management" {
  component "ProcessStateManager" as psm <<core>>
  component "service-starter.js" as starter <<core>>
}

package "Health Monitoring" {
  component "health-coordinator.js" as healthCoord <<core>>
  component "service-probe.js" as probe <<core>>
}

package "Running Services" {
  component "API Service (3031)" as apiSvc <<api>>
  component "Next.js Dashboard (dev)" as dashboard <<api>>
  database "Memgraph (Bolt)" as memgraph <<storage>>
}

component "llm-mock-service\n(Semantic Analysis MCP)" as llmMock <<external>>

starter --> apiScript : "startWithRetry()\nexponential backoff"
starter --> dashScript : "startWithRetry()\nexponential backoff"

apiScript --> psm : "register / unregister"
dashScript --> psm : "register / unregister"
apiScript --> apiSvc : "spawns child process"
dashScript --> dashboard : "spawns (NODE_ENV=dev)"

healthCoord --> psm : "dynamic service discovery"
healthCoord --> probe : "5-second tick cycle"

probe --> apiSvc : "probeHttpHealth()\n{status, latency_ms, error}"
probe --> memgraph : "probeTcpPort()\nBolt protocol"

dashboard --> apiSvc : "NEXT_PUBLIC_API_BASE_URL\nlocalhost:3031"

llmMock --> memgraph : "staged startup dependency"
llmMock ..> psm : "registered at runtime"

@enduml