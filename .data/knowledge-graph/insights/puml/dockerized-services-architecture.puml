@startuml
!include /coding/docs/puml/_standard-style.puml

package "Supervision Layer" {
  component "api-service.js\nSupervisor" as apiSupervisor <<core>>
  component "dashboard-service.js\nSupervisor" as dashSupervisor <<core>>
}

package "Health & Lifecycle" {
  component "health-coordinator.js" as healthCoord <<core>>
  component "service-probe.js\n(HTTP + TCP dual-probe)" as serviceProbe <<core>>
  component "service-starter.js\nstartServiceWithRetry()" as serviceStarter <<core>>
  component "ProcessStateManager\n(PSM Singleton)" as psm <<core>>
}

package "Dockerized Services" {
  component "Next.js Dashboard\n:3030" as nextjs <<api>>
  component "Constraint API\ndashboard-server.js :3031" as constraintApi <<api>>
  database "Memgraph\n(Bolt Protocol)" as memgraph
  database "Redis" as redis
}

' Health coordinator polls service-probe
healthCoord --> serviceProbe : "polls every 5s\n(running/stopped/unknown)"

' Service probe targets
serviceProbe --> nextjs : "probeHttpHealth()"
serviceProbe --> constraintApi : "probeHttpHealth()"
serviceProbe --> memgraph : "probeTcpPort()"
serviceProbe --> redis : "probeTcpPort()"

' Supervision relationships
apiSupervisor --> constraintApi : "spawns & forwards SIGTERM"
dashSupervisor --> nextjs : "spawns & forwards SIGTERM"
apiSupervisor --> serviceStarter : "retry + backoff\n(maxRetries=3, 30s timeout)"
dashSupervisor --> serviceStarter : "retry + backoff\n(maxRetries=3, 30s timeout)"
apiSupervisor ..> psm : "registers child\n(non-fatal)"
dashSupervisor ..> psm : "registers child\n(non-fatal)"

' Frontend-to-backend wiring
nextjs --> constraintApi : "NEXT_PUBLIC_API_BASE_URL\nhttp://localhost:3031"

@enduml