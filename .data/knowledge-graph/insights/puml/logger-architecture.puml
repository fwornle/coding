@startuml
!include /coding/docs/puml/_standard-style.puml

package "Logging Mechanism" {
  component "Logger" as logger <<core>>
}

package "Configuration" {
  component "ConfigurationValidator" as configValidator <<api>>
}

package "Log Storage" {
  database "Log Database" as logDb
}

logger --> configValidator : uses
configValidator --> logger : configures
logger --> logDb : writes
logDb --> logger : reads

@enduml