@startuml
!include /Users/Q284340/Agentic/coding/docs/puml/_standard-style.puml

title Agent Persistent Memory Files - Use Case Diagram

actor "AI Agent" as Agent
actor "Knowledge Manager" as KM
actor "Semantic Analyzer" as SA

rectangle "Agent Persistent Memory Files" {
    usecase "Store Memory File" as UC1
    usecase "Retrieve Memory File" as UC2
    usecase "Update Memory Content" as UC3
    usecase "Delete Memory File" as UC4
    usecase "Index Memory for Search" as UC5
    usecase "Perform Semantic Search" as UC6
    usecase "Analyze Knowledge Patterns" as UC7
    usecase "Persist Session Context" as UC8
    usecase "Load Historical Context" as UC9
    usecase "Validate Memory Integrity" as UC10
}

Agent --> UC1 : writes
Agent --> UC2 : reads
Agent --> UC3 : modifies
Agent --> UC8 : saves session
Agent --> UC9 : restores context

KM --> UC4 : manages
KM --> UC10 : validates
KM --> UC3 : curates

SA --> UC5 : indexes
SA --> UC6 : queries
SA --> UC7 : analyzes

UC1 ..> UC5 : <<include>>
UC2 ..> UC6 : <<include>>
UC6 ..> UC7 : <<extend>>
UC8 ..> UC1 : <<include>>
UC9 ..> UC2 : <<include>>
UC3 ..> UC10 : <<include>>

@enduml