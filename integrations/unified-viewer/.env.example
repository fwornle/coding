# Per D-45-02 + D-55-01a/b — multi-base-URL routing for /viewer/{system}.
# Phase 55: 2-system viewer (coding + okb); CAP dropped (D-55-01b).
# Vite inlines VITE_* at build time. Do NOT place secrets here (they end up in the bundle).
# Both are optional — SYSTEM_ENDPOINTS in src/config/system-endpoints.ts provides
# localhost defaults for dev.

VITE_BACKEND_CODING_URL=http://localhost:12436
# OKM Express on :8090 (was :3848 / semantic-analysis in Phase 45 — that exposed the
# coding KG, not OKM data; corrected per D-55-01a).
VITE_BACKEND_OKB_URL=http://localhost:8090
