# Per D-45-02 — multi-base-URL routing for /viewer/{system}.
# Vite inlines VITE_* at build time. Do NOT place secrets here (they end up in the bundle).
# All three are optional — SYSTEM_ENDPOINTS in src/config/system-endpoints.ts provides
# localhost defaults for dev.

VITE_BACKEND_CODING_URL=http://localhost:12436
VITE_BACKEND_OKB_URL=http://localhost:3848
VITE_BACKEND_CAP_URL=https://okm.cc.bmwgroup.net
