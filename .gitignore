.data/knowledge-graph/insights/*
!.data/knowledge-graph/insights/puml/
!.data/knowledge-graph/insights/images/
!.data/knowledge-graph/exports/
!.data/knowledge-graph/exports/**
# ...but never the timestamped backups repair/migration scripts drop there
# (the exports/** re-include above otherwise overrides the global *.bak rule).
.data/knowledge-graph/exports/*.bak
.data/knowledge-graph/exports/*.bak-*
.data/knowledge-graph-migrated/
.data/knowledge.db
.data/knowledge.db-shm
.data/knowledge.db-wal
.data/backups/
.data/exports/*.pre-*-backup

# Track knowledge exports (git-reviewable JSON)
!.data/
!.data/knowledge-export/
!.data/observation-export/
!.data/llm-proxy-export/
!.data/knowledge-config.json

# Per-machine local — proxy settings (dashboard's Settings dialog persists
