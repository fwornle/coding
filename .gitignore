# macOS
.DS_Store
.AppleDouble
.LSOverride

# Machine-specific MCP config (contains absolute paths)
claude-code-mcp-docker.json

# Playwright MCP server artifacts (page snapshots, console logs)
.playwright-mcp/

# Phase 44 — Playwright E2E spec audit-trail screenshots (T-44-02-02).
# Specs in tests/e2e/*.spec.ts write screenshots under tests/e2e/_artifacts/
# for post-run inspection; not source-controlled.
tests/e2e/_artifacts/

# Editor directories and files
.idea
.vscode/*
!.vscode/settings.json
*.swp
*.swo
*~

# Logs
*.log
/logs/
# Note: Use /logs/ (with leading slash) to only match top-level logs directory.
# Classification logs now live in the private history repo at
# .specstory/history/logs/classification/ (covered by line 53).

# Temporary files
*.tmp
*.temp
.tmp/

# Backup files
*.bak
*.bak.*
*.backup

# Local configuration (includes .claude/settings.local.json with platform-specific paths)
*.local
.claude/settings.local.json

# Claude Code Agent-tool isolation worktrees (transient — created per-agent,
# deleted automatically when the agent makes no changes; only the path/branch
# is reported on completion).
.claude/worktrees/

# Runtime heartbeat written by the consolidator while it's processing — pid +
# timestamps + last error message. Refreshed every few seconds; not source.
.observations/consolidation-heartbeat.json

# Cache directories
.cache/
__pycache__/
.serena/cache/

# Prevent future staging/committing of these large files
.specstory/archive/
.obsolete/workflow-archives/specstory-archive/2025-10-05_0800-0900_g9b30a.md

# Session-history is private — verbatim Claude transcripts that may contain
# secrets, internal paths, or stakeholder names. Lives in a separate private
# repo (see install.sh + bin/init-history.sh, and CODING_HISTORY_REPO in
# .env). The folder is created locally by init-history.sh so LSL services
# don't crash on a fresh public checkout, but its contents are never
# committed to this repo.
.specstory/history/

# Knowledge base data (if you want to exclude the actual data)
# Uncomment the line below if you don't want to track the knowledge base content
# /knowledge-management/coding-knowledge-base/

# claude mcp servers etc. (fw-250601)
node_modules/
dist/

# Environment variables and secrets
.env
.env.local
.env.*.local

