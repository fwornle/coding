vkb-server.log
semantic-analysis.log

# MCP Constraint Monitor now standalone - no local ignore patterns needed

# Browserbase MCP server (cloned from public repo, not a submodule)
integrations/mcp-server-browserbase/

# Live logging runtime data
.mcp-sync/
.transcript-monitor-health
.global-lsl-registry.json
.specstory/trajectory/live-state.json

# Centralized health monitoring files
.health/

# Workflow checkpoints (timestamps that change frequently but don't need git tracking)
.data/workflow-checkpoints.json
.data/workflow-progress.json
.data/workflow-runner-progress.json

# Workflow execution configs (per-run configs with unique IDs)
.data/workflow-configs/

# LLM usage cost tracking (runtime, written by BudgetTracker)
.data/llm-usage-costs.json
.data/llm-usage-costs.json.tmp

# Batch processing runtime state
.data/batch-*.json
.data/ukb-*.json
.data/ukb-trace-reports/
.data/step-timing-statistics.json

# One-shot repair / backfill / soak session logs — timestamped, disposable run
# artifacts written by scripts/{repair-*,backfill-*,poll-orphan-floor-soak}.mjs.
# Kept on disk for the run, never needed in git.
.data/backfill-*.json
.data/repair-*.json
.data/orphan-floor-soak-*.json
.data/*-dry-runs/

# Phase 51 sub-agent live-tier runtime state (heartbeats rewritten every 30s
# by the live-{claude,copilot,opencode} daemons; slot-state is the slot
# allocator's persistent mapping but is regenerable from .specstory/history/
# listings via scripts/write-sub-agent-lsl.mjs --historical).
.data/sub-agent-live-state.json
.data/sub-agent-live-state-*.json
.data/sub-agent-slot-state.json
.data/sub-agent-sweep-state.json

# Ontology suggestions (runtime-generated, not needed in git)
.data/ontologies/suggestions/

# Code graph RAG index (binary, regenerated on indexing)
.data/code-graph-index/

# Workflow execution reports and logs (generated on each UKB run, not needed in git)
.data/workflow-reports/
.data/trace-history/
.data/workflow-logs/

# 4-Layer Monitoring Architecture runtime files
.global-service-registry.json
.mcp-sync/session-registry.json
*-report-*.json
.specstory/validation-report.json
.specstory/change-log.json
.specstory/logs/*
# Classification logs moved into the private history repo at
# .specstory/history/logs/classification/ (covered by .specstory/history/ at line 53).
# .specstory/logs/ itself remains for runtime artifacts (system.log, metrics-*.json).
.logs/
scripts/monitoring-*.log
scripts/watchdog-*.log
*-health-*.json

