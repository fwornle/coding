.data/llm-proxy/llm-settings.json

# PlantUML validation errors (transient, regenerated on diagram validation)
knowledge-management/insights/plantuml_errors.json

# Package lock files (optional - some prefer to track these)
package-lock.json
**/package-lock.json

# Build and compiled files
build/
dist/
*.tsbuildinfo

# Compiled TypeScript output (should only be in dist/)
src/**/*.js
src/**/*.d.ts
!src/**/*.test.js
!src/**/*.spec.js
!src/retrieval/**/*.js
!src/hooks/**/*.js
# src/live-logging/ is hand-written JS (ObservationConsolidator, ObservationWriter,
# MentionsClassifier, etc.) — not compiled TS output. Phase 58 Plan 01 adds
# MentionsClassifier.js as a host-side module shared by writer-path + backfill;
# the rest of the directory is already tracked.
!src/live-logging/**/*.js

# Editor and IDE files (.vscode/ already ignored above with explicit exception
# for settings.json so the workspace SCM ignore-list ships with the repo)
.vscode/launch.json

# Temporary and swap files
*.tmp
*.temp
.tmp/
